<script is:inline>
  (function() {
    const path = window.location.pathname;
    document.querySelectorAll('.nav-link').forEach(link => {
      const href = link.getAttribute('href');
      if ((path === '/' && href === '/') || href === path || href === path + '/') {
        link.classList.add('text-primary', 'dark:text-primary');
      }
    });
  })();
</script>

<!-- Mobile Menu Panel -->
<div id="mobile-menu" class="fixed inset-0 z-40 bg-background-light dark:bg-background-dark transform translate-x-full transition-transform duration-300 md:hidden">
  <div class="flex flex-col h-full pt-20 px-6">
