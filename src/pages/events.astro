---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pageTitle = "Events - Ormeau Table Tennis Club";
const pageDescription = "Discover upcoming events at Ormeau Table Tennis Club. From tournaments to coaching clinics and social nights, find your next table tennis experience in Belfast.";
---

<Layout title={pageTitle} description={pageDescription}>
  <Header />

  <!-- Hero Section -->
  <section class="relative bg-background-dark text-white overflow-hidden min-h-[60vh] flex items-center justify-center">
    <div class="absolute inset-0 z-0">
      <img alt="Action Shot" class="w-full h-full object-cover scale-105 filter brightness-50 contrast-125" src="https://xkwg7luliofrc1cs.public.blob.vercel-storage.com/Images/JO%20Waldner%20Ormeau.jpg"/>
      <div class="absolute inset-0 bg-gradient-to-b from-black/50 via-black/20 to-black/50"></div>
    </div>
    <div class="relative z-20 max-w-5xl mx-auto px-6 py-24 flex flex-col items-center text-center">
      <span class="inline-block py-2 px-6 rounded-full bg-primary/20 border border-primary/40 backdrop-blur-md text-sm font-bold mb-8 uppercase tracking-[0.25em] text-primary">What's On at Ormeau</span>
      <h1 class="text-5xl md:text-8xl font-bold tracking-tight mb-8 leading-[1.05] max-w-4xl">Experience The<br/><span class="text-primary">Energy Of Ormeau</span></h1>
      <p class="text-lg md:text-2xl text-gray-200 max-w-3xl mb-12 font-light leading-relaxed">From intense regional tournaments to community social nights, our calendar is packed with opportunities to play, improve, and connect.</p>
      <div class="flex flex-col items-center w-full max-w-md gap-6 mt-4">
        <a class="w-full px-12 py-5 rounded-full bg-primary text-white font-bold text-xl hover:bg-primary-hover transition-all duration-300 shadow-2xl shadow-primary/40 transform hover:-translate-y-1 text-center" href="#featured">Next Club Event</a>
      </div>
    </div>
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-20 animate-bounce">
      <span class="material-icons text-white/50 text-3xl">expand_more</span>
    </div>
  </section>

  <!-- Featured Event -->
  <section class="py-20 bg-[#1a1a1a]" id="featured">
    <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-10">
      <div class="featured-event-card relative rounded-3xl overflow-hidden bg-surface-dark text-white min-h-[400px] flex flex-col md:flex-row shadow-2xl border-4 border-primary data-event-date="2099-12-31">
        <div class="md:w-1/2 relative min-h-[300px]">
          <img alt="British League" class="featured-event-image absolute inset-0 w-full h-full object-cover" loading="lazy" src="https://xkwg7luliofrc1cs.public.blob.vercel-storage.com/Images/493933685_1241133241351877_5480171846768564305_n.jpg"/>
          <div class="absolute inset-0 bg-gradient-to-r from-surface-dark/40 to-transparent"></div>
        </div>
        <div class="md:w-1/2 p-8 md:p-12 flex flex-col justify-center featured-event-details text-center">
          <div class="flex items-center justify-center gap-2 mb-4">
            <span class="px-3 py-1 bg-primary text-white text-xs font-bold rounded uppercase">Featured Event</span>
          </div>
          <h2 class="featured-event-title text-3xl md:text-5xl font-bold mb-4">Sunday Rumble</h2>
          <div class="space-y-4 mb-8 text-left bg-white/5 border border-white/10 rounded-2xl p-5">
            <div class="flex items-start gap-3">
              <span class="material-icons text-primary mt-0.5">event</span>
              <div>
                <div class="text-sm text-gray-400 uppercase tracking-widest">Date</div>
                <div class="text-lg font-semibold">Next one — TBC</div>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="material-icons text-primary mt-0.5">schedule</span>
              <div>
                <div class="text-sm text-gray-400 uppercase tracking-widest">Time</div>
                <div class="text-lg font-semibold">13:00 - 16:30</div>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="material-icons text-primary mt-0.5">place</span>
              <div>
                <div class="text-sm text-gray-400 uppercase tracking-widest">Location</div>
                <div class="text-lg font-semibold">Ormeau Table Tennis Club</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

<style>
  @media (max-width: 768px) {
    .featured-event-card {
      border-width: 2px;
    }
    .featured-event-title {
      font-size: 1.75rem;
      font-weight: 800;
    }
    .featured-event-details {
      background: rgba(255,255,255,0.03);
      border-radius: 16px;
      padding: 24px;
    }
    .featured-register-btn {
      padding: 16px;
      font-size: 1.1rem;
      width: 100%;
    }
    .event-card {
      border-radius: 12px;
      overflow: hidden;
    }
    .event-card-date {
      padding: 16px;
    }
    .event-card-date span {
      font-size: 1.5rem;
    }
    .calendar-link {
      padding: 10px 16px;
      border: 1px solid var(--brand-pink, #ec4899);
      border-radius: 8px;
      font-size: 0.85rem;
      display: inline-block;
      color: var(--brand-pink, #ec4899);
    }
    .ttu-events-section {
      padding-top: 40px;
    }
    .ttu-events-heading {
      margin-bottom: 12px;
    }
    .featured-event-image {
      aspect-ratio: 16/10;
      border-radius: 12px;
    }
    .filter-bar {
      display: flex;
      overflow-x: auto;
      gap: 8px;
      padding: 0 16px;
      -webkit-overflow-scrolling: touch;
      justify-content: flex-start;
    }
    .filter-bar .filter-btn {
      flex-shrink: 0;
      white-space: nowrap;
      padding: 8px 20px;
      font-size: 0.85rem;
      border-radius: 20px;
    }
  }
</style>

  
  <!-- Unified Events Calendar -->
