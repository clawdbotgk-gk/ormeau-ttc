---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pageTitle = "Events - Ormeau Table Tennis Club";
const pageDescription = "Discover upcoming events at Ormeau Table Tennis Club. From tournaments to coaching clinics and social nights, find your next table tennis experience in Belfast.";
---

<Layout title={pageTitle} description={pageDescription}>
  <Header />
<script is:inline>
    (function() {
      const menuBtn = document.getElementById('mobile-menu-btn');
      const closeBtn = document.getElementById('mobile-menu-close');
      const mobileMenu = document.getElementById('mobile-menu');
      
      function toggleMenu() {
        if (mobileMenu.classList.contains('translate-x-full')) {
          mobileMenu.classList.remove('translate-x-full');
        } else {
          mobileMenu.classList.add('translate-x-full');
        }
      }
      
      if (menuBtn) {
        menuBtn.addEventListener('click', toggleMenu);
      }
      
      if (closeBtn) {
        closeBtn.addEventListener('click', function() {
          mobileMenu.classList.add('translate-x-full');
        });
      }
    })();
  </script><script is:inline>
    (function() {
      const path = window.location.pathname;
      document.querySelectorAll('.nav-link').forEach(link => {
        const href = link.getAttribute('href');
        if ((path === '/' && href === '/') || href === path || href === path + '/') {
          link.classList.add('text-primary', 'dark:text-primary');
        }
      });
    })();
  </script>

  <!-- Hero Section -->
  <section class="relative bg-background-dark text-white overflow-hidden min-h-[60vh] flex items-center justify-center">
    <div class="absolute inset-0 z-0">
      <img alt="Action Shot" class="w-full h-full object-cover scale-105 filter brightness-50 contrast-125" src="https://xkwg7luliofrc1cs.public.blob.vercel-storage.com/Images/JO%20Waldner%20Ormeau.jpg"/>
      <div class="absolute inset-0 bg-gradient-to-b from-black/50 via-black/20 to-black/50"></div>
    </div>
    <div class="relative z-20 max-w-5xl mx-auto px-6 py-24 flex flex-col items-center text-center">
      <span class="inline-block py-2 px-6 rounded-full bg-primary/20 border border-primary/40 backdrop-blur-md text-sm font-bold mb-8 uppercase tracking-[0.25em] text-primary">What's On at Ormeau</span>
      <h1 class="text-5xl md:text-8xl font-bold tracking-tight mb-8 leading-[1.05] max-w-4xl">Experience The<br/><span class="text-primary">Energy Of Ormeau</span></h1>
      <p class="text-lg md:text-2xl text-gray-200 max-w-3xl mb-12 font-light leading-relaxed">From intense regional tournaments to community social nights, our calendar is packed with opportunities to play, improve, and connect.</p>
      <div class="flex flex-col items-center w-full max-w-md gap-6 mt-4">
        <a class="w-full px-12 py-5 rounded-full bg-primary text-white font-bold text-xl hover:bg-primary-hover transition-all duration-300 shadow-2xl shadow-primary/40 transform hover:-translate-y-1 text-center" href="#featured">Next Club Event</a>
      </div>
    </div>
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-20 animate-bounce">
      <span class="material-icons text-white/50 text-3xl">expand_more</span>
    </div>
  </section>

  <!-- Featured Event -->
  <section class="py-20 bg-[#1a1a1a]" id="featured">
    <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-10">
      <div class="featured-event-card relative rounded-3xl overflow-hidden bg-surface-dark text-white min-h-[400px] flex flex-col md:flex-row shadow-2xl border-4 border-primary">
        <div class="md:w-1/2 relative min-h-[300px]">
          <img alt="British League" class="featured-event-image absolute inset-0 w-full h-full object-cover" src="https://xkwg7luliofrc1cs.public.blob.vercel-storage.com/Images/493933685_1241133241351877_5480171846768564305_n.jpg"/>
          <div class="absolute inset-0 bg-gradient-to-r from-surface-dark/40 to-transparent"></div>
        </div>
        <div class="md:w-1/2 p-8 md:p-12 flex flex-col justify-center featured-event-details">
          <div class="flex items-center gap-2 mb-4">
            <span class="px-3 py-1 bg-primary text-white text-xs font-bold rounded uppercase">Featured Event</span>
            <span class="px-3 py-1 bg-white/10 text-white text-xs font-bold rounded uppercase">Club Event</span>
          </div>
          <h2 class="featured-event-title text-3xl md:text-5xl font-bold mb-4">Sunday Rumble</h2>
          <div class="space-y-4 mb-8">
            <div class="flex items-center gap-3">
              <span class="material-icons text-primary">event</span>
              <div>
                <div class="text-sm text-gray-400">Date</div>
                <div class="text-lg font-semibold">Sunday, 29 March 2026</div>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <span class="material-icons text-primary">schedule</span>
              <div>
                <div class="text-sm text-gray-400">Time</div>
                <div class="text-lg font-semibold">13:00 - 16:30</div>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <span class="material-icons text-primary">place</span>
              <div>
                <div class="text-sm text-gray-400">Location</div>
                <div class="text-lg font-semibold">Ormeau Table Tennis Club</div>
              </div>
            </div>
          </div>
          <a href="https://ormeautt.com/events/cbb3a897-87dc-4c76-8e40-06e451fa74fa" target="_blank" rel="noopener noreferrer" class="featured-register-btn bg-primary hover:bg-primary-hover text-white font-bold py-4 px-8 rounded-full transition-all text-center inline-block">Register Now</a>
        </div>
      </div>
    </div>
  </section>

<style>
  @media (max-width: 768px) {
    .featured-event-card {
      border-width: 2px;
    }
    .featured-event-title {
      font-size: 1.75rem;
      font-weight: 800;
    }
    .featured-event-details {
      background: rgba(255,255,255,0.03);
      border-radius: 16px;
      padding: 24px;
    }
    .featured-register-btn {
      padding: 16px;
      font-size: 1.1rem;
      width: 100%;
    }
    .event-card {
      border-radius: 12px;
      overflow: hidden;
    }
    .event-card-date {
      padding: 16px;
    }
    .event-card-date span {
      font-size: 1.5rem;
    }
    .calendar-link {
      padding: 10px 16px;
      border: 1px solid var(--brand-pink, #ec4899);
      border-radius: 8px;
      font-size: 0.85rem;
      display: inline-block;
      color: var(--brand-pink, #ec4899);
    }
    .ttu-events-section {
      padding-top: 40px;
    }
    .ttu-events-heading {
      margin-bottom: 12px;
    }
    .featured-event-image {
      aspect-ratio: 16/10;
      border-radius: 12px;
    }
    .filter-bar {
      display: flex;
      overflow-x: auto;
      gap: 8px;
      padding: 0 16px;
      -webkit-overflow-scrolling: touch;
      justify-content: flex-start;
    }
    .filter-bar .filter-btn {
      flex-shrink: 0;
      white-space: nowrap;
      padding: 8px 20px;
      font-size: 0.85rem;
      border-radius: 20px;
    }
  }
</style>

  <!-- TTU Events Section -->
  <section class="ttu-events-section py-20 bg-gray-50 dark:bg-gray-900">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <span class="inline-block px-4 py-1 bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-300 text-sm font-bold rounded-full uppercase tracking-wider mb-4">Table Tennis Ulster</span>
        <h2 class="ttu-events-heading text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4">Upcoming TTU Events</h2>
        <p class="text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">Major tournaments and events across Ulster. Click to add to your calendar.</p>
      </div>

      <!-- Filter Bar -->
      <section class="sticky top-24 z-40 bg-gray-50 dark:bg-gray-900 py-6 border-y border-gray-100 dark:border-gray-800 mb-12">
        <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-10">
          <div class="filter-bar flex flex-wrap items-center gap-3">
            <button class="filter-btn px-5 py-2 rounded-full bg-primary text-white font-bold text-sm transition-all duration-200" data-filter="all">All Events</button>
            <button class="filter-btn px-5 py-2 rounded-full bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-300 font-bold text-sm hover:bg-blue-200 dark:hover:bg-blue-800 transition-all duration-200" data-filter="tournament">Tournaments</button>
            <button class="filter-btn px-5 py-2 rounded-full bg-green-100 dark:bg-green-900 text-green-700 dark:text-green-300 font-bold text-sm hover:bg-green-200 dark:hover:bg-green-800 transition-all duration-200" data-filter="coaching">Coaching</button>
            <button class="filter-btn px-5 py-2 rounded-full bg-orange-100 dark:bg-orange-900 text-orange-700 dark:text-orange-300 font-bold text-sm hover:bg-orange-200 dark:hover:bg-orange-800 transition-all duration-200" data-filter="social">Social</button>
          </div>
        </div>
      </section>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">

        <!-- Mar 5 -->
        <div class="event-card group bg-white dark:bg-gray-800 rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-all" data-category="tournament">
          <div class="event-card-date">
            <span class="text-3xl font-black text-white">05 MAR</span>
          </div>
          <div class="p-6">
            <span class="text-xs font-bold text-blue-600 dark:text-blue-400 uppercase">Tournament</span>
            <h3 class="text-lg font-bold text-gray-900 dark:text-white mt-1 mb-2">Kingfisher SE Regional</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">South Lakes Leisure Centre, Craigavon</p>
            <a href="https://www.google.com/calendar/event?eid=ampkbjVxMXBiMXRqN2V1czVuZHQ3bjVhazQgY2xhd2Rib3Rna0Bt" target="_blank" rel="noopener noreferrer" class="calendar-link text-primary font-bold text-sm hover:underline">+ Add to Calendar</a>
          </div>
        </div>

        <!-- Mar 14 -->
        <div class="event-card group bg-white dark:bg-gray-800 rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-all" data-category="tournament">
          <div class="event-card-date">
            <span class="text-3xl font-black text-white">14 MAR</span>
          </div>
          <div class="p-6">
            <span class="text-xs font-bold text-purple-600 dark:text-purple-400 uppercase">Junior</span>
            <h3 class="text-lg font-bold text-gray-900 dark:text-white mt-1 mb-2">Ulster Junior Event</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">South Lakes Leisure Centre, Craigavon</p>
            <span class="text-gray-400 text-sm">10:00 AM - 5:00 PM</span>
          </div>
        </div>

        <!-- Mar 15 -->
        <div class="event-card group bg-white dark:bg-gray-800 rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-all" data-category="tournament">
          <div class="event-card-date">
            <span class="text-3xl font-black text-white">15 MAR</span>
          </div>
          <div class="p-6">
            <span class="text-xs font-bold text-purple-600 dark:text-purple-400 uppercase">Junior</span>
            <h3 class="text-lg font-bold text-gray-900 dark:text-white mt-1 mb-2">Ulster Junior Event</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">South Lakes Leisure Centre, Craigavon</p>
            <span class="text-gray-400 text-sm">10:00 AM - 5:00 PM</span>
          </div>
        </div>

        <!-- Mar 19 -->
        <div class="event-card group bg-white dark:bg-gray-800 rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-all" data-category="coaching">
          <div class="event-card-date">
            <span class="text-3xl font-black text-white">19 MAR</span>
          </div>
          <div class="p-6">
            <span class="text-xs font-bold text-green-600 dark:text-green-400 uppercase">Coaching</span>
            <h3 class="text-lg font-bold text-gray-900 dark:text-white mt-1 mb-2">TTU Coaching Course</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">Lisburn Racquets Club</p>
            <span class="text-gray-400 text-sm">9:00 AM - 5:00 PM</span>
          </div>
        </div>

        <!-- Mar 26 -->
        <div class="event-card group bg-white dark:bg-gray-800 rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-all" data-category="social">
          <div class="event-card-date">
            <span class="text-3xl font-black text-white">26 MAR</span>
          </div>
          <div class="p-6">
            <span class="text-xs font-bold text-orange-600 dark:text-orange-400 uppercase">Social</span>
            <h3 class="text-lg font-bold text-gray-900 dark:text-white mt-1 mb-2">TTU Annual Dinner</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">Crown Plaza, Belfast</p>
            <span class="text-gray-400 text-sm">7:00 PM - Late</span>
          </div>
        </div>

        <!-- Apr 4 -->
        <div class="event-card group bg-white dark:bg-gray-800 rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-all" data-category="tournament">
          <div class="event-card-date">
            <span class="text-3xl font-black text-white">04 APR</span>
          </div>
          <div class="p-6">
            <span class="text-xs font-bold text-pink-600 dark:text-pink-400 uppercase">Tournament</span>
            <h3 class="text-lg font-bold text-gray-900 dark:text-white mt-1 mb-2">Ulster Senior Open</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">Lisburn Racquets Club</p>
            <a href="https://www.google.com/calendar/event?eid=OW5obnFlNnJzc2JpaTJyM2sxYWY1M3NoZzggY2xhd2Rib3Rna0Bt" target="_blank" rel="noopener noreferrer" class="calendar-link text-primary font-bold text-sm hover:underline">+ Add to Calendar</a>
          </div>
        </div>

        <!-- Apr 20 -->
        <div class="event-card group bg-white dark:bg-gray-800 rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-all" data-category="tournament">
          <div class="event-card-date">
            <span class="text-3xl font-black text-white">20 APR</span>
          </div>
          <div class="p-6">
            <span class="text-xs font-bold text-red-600 dark:text-red-400 uppercase">Tournament</span>
            <h3 class="text-lg font-bold text-gray-900 dark:text-white mt-1 mb-2">Kingfisher National</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">National Stadium, Dublin</p>
            <a href="https://www.google.com/calendar/event?eid=OW5obnFlNnJzc2JpaTJyM2sxYWY1M3NoZzggY2xhd2Rib3Rna0Bt" target="_blank" rel="noopener noreferrer" class="calendar-link text-primary font-bold text-sm hover:underline">+ Add to Calendar</a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const filterButtons = document.querySelectorAll('.filter-btn') as NodeListOf<HTMLElement>;
    const eventCards = document.querySelectorAll('.event-card') as NodeListOf<HTMLElement>;
    
    filterButtons.forEach((button) => {
      button.addEventListener('click', function(this: HTMLElement) {
        // Remove active class from all buttons
        filterButtons.forEach((btn) => {
          btn.classList.remove('bg-primary', 'text-white');
          btn.classList.add('bg-surface-light', 'dark:bg-surface-dark', 'text-gray-600', 'dark:text-gray-300');
        });
        
        // Add active class to clicked button
        this.classList.remove('bg-surface-light', 'dark:bg-surface-dark', 'text-gray-600', 'dark:text-gray-300');
        this.classList.add('bg-primary', 'text-white');
        
        const filter = this.getAttribute('data-filter');
        
        // Filter event cards
        eventCards.forEach((card) => {
          if (filter === 'all') {
            card.style.display = 'block';
          } else {
            const category = card.getAttribute('data-category');
            if (category === filter) {
              card.style.display = 'block';
            } else {
              card.style.display = 'none';
            }
          }
        });
      });
    });
  });
</script>
