<script>
  document.addEventListener('DOMContentLoaded', function() {
    const filterButtons = document.querySelectorAll('.filter-btn') as NodeListOf<HTMLElement>;
    const eventCards = document.querySelectorAll('.event-card') as NodeListOf<HTMLElement>;
    const featuredCard = document.querySelector('.featured-event-card');
    const emptyState = document.getElementById('events-empty-state');

    function isPastDate(yyyyMmDd) {
      const parts = yyyyMmDd.split('-').map(Number);
      if (parts.length !== 3 || parts.some(isNaN)) return false;
      const eventDate = new Date(parts[0], parts[1] - 1, parts[2]);
      const today = new Date();
      today.setHours(0, 0, 0, 0);
      return eventDate.getTime() < today.getTime();
    }

    function isCardVisible(card) {
      const d = card.getAttribute('data-event-date');
      if (d && isPastDate(d)) return false;
      return true;
    }

    function refreshEmptyState() {
      if (!emptyState) return;
      if (featuredCard && !isCardVisible(featuredCard)) {
        featuredCard.style.display = 'none';
      } else if (featuredCard) {
        featuredCard.style.display = '';
      }
      const anyVisible = Array.from(eventCards).some(c => isCardVisible(c) && c.style.display !== 'none');
      emptyState.classList.toggle('hidden', anyVisible);
    }

    eventCards.forEach((card) => {
      if (!isCardVisible(card)) card.style.display = 'none';
    });
    refreshEmptyState();

    filterButtons.forEach((button) => {
      button.addEventListener('click', function() {
        filterButtons.forEach((btn) => {
          btn.classList.remove('bg-primary', 'text-white');
          btn.classList.add('bg-surface-light', 'dark:bg-surface-dark', 'text-gray-600', 'dark:text-gray-300');
        });
        this.classList.remove('bg-surface-light', 'dark:bg-surface-dark', 'text-gray-600', 'dark:text-gray-300');
        this.classList.add('bg-primary', 'text-white');

        const filter = this.getAttribute('data-filter');

        eventCards.forEach((card) => {
          if (!isCardVisible(card)) {
            card.style.display = 'none';
            return;
          }
          if (filter === 'all') {
            card.style.display = 'block';
          } else {
            const category = card.getAttribute('data-category');
            card.style.display = (category === filter) ? 'block' : 'none';
          }
        });
        refreshEmptyState();
      });
    });
  });
</script>
