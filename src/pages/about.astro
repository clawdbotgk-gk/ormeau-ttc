---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="About Us - Ormeau Table Tennis Club" description="Learn about Ormeau Table Tennis Club's history, our coaches Keith and Gervis Knox, and why we're Belfast's premier table tennis facility.">
  <Header />
<script is:inline>
    (function() {
      const path = window.location.pathname;
      document.querySelectorAll('.nav-link').forEach(link => {
        const href = link.getAttribute('href');
        if ((path === '/' && href === '/') || href === path || href === path + '/') {
          link.classList.add('text-primary', 'dark:text-primary');
        }
      });
    })();
  </script><!-- Hero Section -->
  <section class="relative bg-background-dark text-white overflow-hidden">
    <div class="absolute inset-0 bg-black/70 z-10 md:bg-black/70"></div>
    <div class="absolute inset-0 bg-[url('https://xkwg7luliofrc1cs.public.blob.vercel-storage.com/Images/first%20world%20record%20.jpg')] bg-cover bg-center z-0"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/50 to-black/30 z-10 md:hidden"></div>
    <div class="relative z-20 max-w-7xl mx-auto px-6 sm:px-8 lg:px-10 pt-[80px] sm:pt-40 md:pt-48 pb-16 sm:pb-40 md:pb-48">
      <div class="max-w-3xl">
        <span class="inline-block py-1 px-4 rounded-full bg-primary/20 border border-primary/30 text-primary text-sm font-bold mb-6 uppercase tracking-widest">Est. 2013</span>
        <h1 class="text-[2rem] sm:text-4xl md:text-6xl font-bold tracking-tight mb-6 sm:mb-8 leading-tight"> Belfast's Award-Winning <br/><span class="text-primary">Table Tennis Club</span> </h1>
        <p class="text-base sm:text-lg md:text-xl text-gray-300 leading-relaxed font-light mb-8 sm:mb-10"> Founded in 2013, Ormeau Table Tennis Club has grown from a local initiative into one of Ireland's most successful sporting communities. Our journey is built on a passion for excellence, inclusivity, and the drive to bring world-class table tennis to the heart of Belfast. </p>
      </div>
    </div>
  </section>

  <!-- Why Play Table Tennis -->
  <section class="py-24 bg-white dark:bg-background-dark">
    <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-10">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Why Play Table Tennis?</h2>
        <div class="w-[60px] h-1 bg-primary mx-auto rounded-full"></div>
      </div>
      <div class="grid grid-cols-2 gap-4 md:grid-cols-4 md:gap-6">
        <div class="p-5 md:p-8 rounded-xl md:rounded-2xl bg-[#262626] border border-gray-800 text-center flex flex-col items-center">
          <span class="material-symbols-outlined text-3xl md:text-4xl text-primary mb-3 md:mb-4">speed</span>
          <h3 class="font-bold text-base md:text-lg mb-2">Maintain Stamina</h3>
          <p class="text-[0.85rem] leading-[1.5] text-gray-600 dark:text-gray-400">Excellent cardiovascular exercise that keeps your heart rate up and improves endurance.</p>
        </div>
        <div class="p-5 md:p-8 rounded-xl md:rounded-2xl bg-[#262626] border border-gray-800 text-center flex flex-col items-center">
          <span class="material-symbols-outlined text-3xl md:text-4xl text-primary mb-3 md:mb-4">fitness_center</span>
          <h3 class="font-bold text-base md:text-lg mb-2">Increase Strength</h3>
          <p class="text-[0.85rem] leading-[1.5] text-gray-600 dark:text-gray-400">Builds core stability and lower body strength through explosive lateral movements.</p>
        </div>
        <div class="p-5 md:p-8 rounded-xl md:rounded-2xl bg-[#262626] border border-gray-800 text-center flex flex-col items-center">
          <span class="material-symbols-outlined text-3xl md:text-4xl text-primary mb-3 md:mb-4">psychology</span>
          <h3 class="font-bold text-base md:text-lg mb-2">Sharpen Reflexes</h3>
          <p class="text-[0.85rem] leading-[1.5] text-gray-600 dark:text-gray-400">Enhances hand-eye coordination and mental alertness through fast-paced rallies.</p>
        </div>
        <div class="p-5 md:p-8 rounded-xl md:rounded-2xl bg-[#262626] border border-gray-800 text-center flex flex-col items-center">
          <span class="material-symbols-outlined text-3xl md:text-4xl text-primary mb-3 md:mb-4">mood</span>
          <h3 class="font-bold text-base md:text-lg mb-2">It's Fun</h3>
          <p class="text-[0.85rem] leading-[1.5] text-gray-600 dark:text-gray-400">A highly social sport that is easy to pick up but offers a lifetime of mastery.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Adult Coaching -->
  <section class="py-16 md:py-24 pb-10 md:pb-24 pt-10 md:pt-24 bg-white dark:bg-background-dark border-t border-white/10 md:border-t-0">
    <div class="max-w-7xl mx-auto px-0 md:px-6 sm:px-8 lg:px-10">
      <div class="flex flex-col md:flex-row items-center md:gap-16">
        <div class="md:w-1/2 w-full rounded-xl overflow-hidden">
          <img alt="Adult Coaching" class="rounded-none md:rounded-3xl shadow-2xl w-full object-cover aspect-[16/10] md:aspect-square" src="https://xkwg7luliofrc1cs.public.blob.vercel-storage.com/Images/hall.jpg"/>
        </div>
        <div class="md:w-1/2 px-4 md:px-0 py-6 md:py-0">
          <h2 class="text-[1.75rem] md:text-4xl font-bold mb-6">Adult Coaching Programs</h2>
          <p class="text-gray-600 dark:text-gray-400 mb-8 leading-relaxed"> Whether you're a complete beginner or looking to refine your competitive edge, our adult coaching sessions provide professional guidance in a structured environment. We focus on technique, tactical awareness, and physical conditioning. </p>
          <a href="/contact" class="inline-block w-full md:w-auto px-8 py-4 bg-primary text-white font-bold rounded-lg md:rounded-full hover:bg-primary-hover transition-colors shadow-lg shadow-primary/30 text-center" style="padding-top: 16px; padding-bottom: 16px;">Register Your Interest</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Junior Development -->
  <section class="py-16 md:py-24 pb-10 md:pb-24 pt-10 md:pt-24 bg-surface-light dark:bg-surface-dark border-t border-white/10 md:border-t-0">
    <div class="max-w-7xl mx-auto px-0 md:px-6 sm:px-8 lg:px-10 flex flex-col md:flex-row-reverse items-center md:gap-16">
      <div class="md:w-1/2 w-full rounded-xl overflow-hidden">
        <img alt="Junior Coaching" class="rounded-none md:rounded-3xl shadow-2xl w-full object-cover aspect-[16/10] md:aspect-square" src="https://xkwg7luliofrc1cs.public.blob.vercel-storage.com/Images/501666182_1270912608373940_3135244361618778947_n.jpg"/>
      </div>
      <div class="md:w-1/2 px-4 md:px-0 py-6 md:py-0">
        <h2 class="text-[1.75rem] md:text-4xl font-bold mb-6">Junior Development</h2>
        <p class="text-gray-600 dark:text-gray-400 mb-8 leading-relaxed"> Our junior academy is the heart of the club. We nurture young talent from ages 6 to 18, offering a pathway from foundational skills to elite national competition. Our coaches are fully vetted and passionate about youth development. </p>
        <a href="/contact" class="inline-block w-full md:w-auto px-8 py-4 bg-primary text-white font-bold rounded-lg md:rounded-full hover:bg-primary-hover transition-colors shadow-lg shadow-primary/30 text-center" style="padding-top: 16px; padding-bottom: 16px;">Register Your Interest</a>
      </div>
    </div>
  </section>

  <!-- Social Play -->
  <section class="py-16 md:py-24 pb-10 md:pb-24 pt-10 md:pt-24 bg-white dark:bg-background-dark border-t border-white/10 md:border-t-0">
    <div class="max-w-7xl mx-auto px-0 md:px-6 sm:px-8 lg:px-10 flex flex-col md:flex-row items-center md:gap-16">
      <div class="md:w-1/2 w-full rounded-xl overflow-hidden">
        <img alt="Social Play" class="rounded-none md:rounded-3xl shadow-2xl w-full object-cover aspect-[16/10] md:aspect-square" src="https://scontent-lhr8-1.xx.fbcdn.net/v/t1.6435-9/67394003_2426293830786092_693504615483703296_n.jpg?_nc_cat=107&ccb=1-7&_nc_sid=f798df&_nc_ohc=hvlRSSWBYtgQ7kNvwGtL3Ug&_nc_oc=AdmaPz35oNgVBv6TEsTWHGGjOzFQYw-GLBFq07Fr0RSmhtgcQxCtlhFWDYk7jqr6CFHwg-G7tQb3chVqCY7xmSm2&_nc_zt=23&_nc_ht=scontent-lhr8-1.xx&_nc_gid=uXe3LwM8lpvrkmc8saOVcg&oh=00_AfuxYGRWRU-LFOaYkzdZSAMzFbRyVCIAhI6UX83vDPvOsw&oe=69C2CB09"/>
      </div>
      <div class="md:w-1/2 px-4 md:px-0 py-6 md:py-0">
        <h2 class="text-[1.75rem] md:text-4xl font-bold mb-6">Social Play & Community</h2>
        <p class="text-gray-600 dark:text-gray-400 mb-8 leading-relaxed"> Not looking for formal coaching? Join our social sessions where the focus is on fun and meeting new people. Open to all levels, these sessions are a great way to stay active in a relaxed, friendly atmosphere. </p>
        <a href="/contact" class="inline-block w-full md:w-auto px-8 py-4 bg-primary text-white font-bold rounded-lg md:rounded-full hover:bg-primary-hover transition-colors shadow-lg shadow-primary/30 text-center" style="padding-top: 16px; padding-bottom: 16px;">Join a Session</a>
      </div>
    </div>
  </section>

  <!-- Schools -->
  <section class="py-16 md:py-24 pb-10 md:pb-24 pt-10 md:pt-24 bg-surface-light dark:bg-surface-dark border-t border-white/10 md:border-t-0">
    <div class="max-w-7xl mx-auto px-0 md:px-6 sm:px-8 lg:px-10 flex flex-col md:flex-row-reverse items-center md:gap-16">
      <div class="md:w-1/2 w-full rounded-xl overflow-hidden">
        <img alt="Schools Program" class="rounded-none md:rounded-3xl shadow-2xl w-full object-cover aspect-[16/10] md:aspect-square" src="https://scontent-lhr6-1.xx.fbcdn.net/v/t1.6435-9/64291187_2350638618351614_1999614920500445184_n.jpg?_nc_cat=110&ccb=1-7&_nc_sid=7b2446&_nc_ohc=kCEt-4d3bxQQ7kNvwGlXLw0&_nc_oc=AdnTExJ1aax4gHC4_X6wCyFK3yDaEw9lcIy9pHUnGG7btBNlsGkSN3oOZ1e7n4p0yn9LNssnZDCiOsn_bnXXMSt8&_nc_zt=23&_nc_ht=scontent-lhr6-1.xx&_nc_gid=JxYoj6cpKPucqKVIS61Vqw&oh=00_AfsPKiG0u6K3FhMyxZLJfqddKSkLZk2c6rNooRIB_kyrgQ&oe=69C2D3E5"/>
      </div>
      <div class="md:w-1/2 px-4 md:px-0 py-6 md:py-0">
        <h2 class="text-[1.75rem] md:text-4xl font-bold mb-6">Schools Partnerships</h2>
        <p class="text-gray-600 dark:text-gray-400 mb-8 leading-relaxed"> We work closely with local schools to introduce students to the sport of table tennis. From after-school clubs to intensive PE workshops, our coaches bring the equipment and expertise to inspire the next generation. </p>
        <a href="/contact" class="inline-block w-full md:w-auto px-8 py-4 bg-primary text-white font-bold rounded-lg md:rounded-full hover:bg-primary-hover transition-colors shadow-lg shadow-primary/30 text-center" style="padding-top: 16px; padding-bottom: 16px;">Contact Us</a>
      </div>
    </div>
  </section>

  <!-- Corporate -->
  <section class="py-16 md:py-24 pb-10 md:pb-24 pt-10 md:pt-24 bg-white dark:bg-background-dark border-t border-white/10 md:border-t-0">
    <div class="max-w-7xl mx-auto px-0 md:px-6 sm:px-8 lg:px-10 flex flex-col md:flex-row items-center md:gap-16">
      <div class="md:w-1/2 w-full mt-6 md:mt-0">
        <h2 class="text-[1.75rem] md:text-4xl font-bold mb-6">Corporate & Charity Events</h2>
        <p class="text-gray-600 dark:text-gray-400 mb-8 leading-relaxed"> Looking for a unique team-building experience or a venue for a charity fundraiser? Ormeau TTC offers bespoke packages for organizations, combining the excitement of the sport with our world-class facilities. </p>
        <a href="/contact" class="inline-block w-full md:w-auto px-8 py-4 bg-primary text-white font-bold rounded-lg md:rounded-full hover:bg-primary-hover transition-colors shadow-lg shadow-primary/30 text-center" style="padding-top: 16px; padding-bottom: 16px;">Contact Us</a>
      </div>
      <div class="md:w-1/2 w-full mt-6 md:mt-0 rounded-xl overflow-hidden">
        <img alt="Corporate Events" class="rounded-none md:rounded-3xl shadow-2xl w-full object-cover aspect-[16/10] md:aspect-square" src="https://xkwg7luliofrc1cs.public.blob.vercel-storage.com/Images/corporate%20league%20.jpg"/>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
