---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pageTitle = "Ormeau Table Tennis Club - Belfast's Premier Table Tennis Club";
const pageDescription = "Join Belfast's premier table tennis club. Professional coaching for all ages, from beginners to elite players. Based at 113 The Mount, Belfast.";
---

<Layout title={pageTitle} description={pageDescription}>
  <Fragment slot="head">
    <link rel="preload" as="image" href="https://xkwg7luliofrc1cs.public.blob.vercel-storage.com/Images/Par%20Gerell%20Ormeau%20.jpg" fetchpriority="high" />
  </Fragment>
  <!-- Skip Link for Keyboard Users -->
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-primary focus:text-white focus:rounded-lg focus:font-bold">
    Skip to main content
  </a>

  <Header />


  <!-- Newsletter Form Handler -->
  <script is:inline>
    const newsletterForm = document.getElementById('newsletter-form');
    if (newsletterForm) {
      newsletterForm.addEventListener('submit', function(e) {
        e.preventDefault();
        const form = this;
        const status = document.getElementById('newsletter-status');
        const submitButton = form.querySelector('button[type="submit"]');
        const formData = new FormData(form);

        submitButton.disabled = true;
        submitButton.innerHTML = 'Please wait...';
        status.classList.remove('hidden', 'text-red-500', 'text-green-500');
        status.textContent = 'Sending...';

        fetch(form.action, {
          method: form.method,
          body: formData,
          headers: { 'Accept': 'application/json' }
        }).then(response => {
          if (response.ok) {
            status.classList.add('text-green-500');
            status.textContent = 'Thanks for subscribing! Check your email to confirm.';
            form.reset();
          } else {
            return response.json().then(data => {
              status.classList.add('text-red-500');
              status.textContent = data.error || 'Oops! There was a problem submitting your form';
            });
          }
        }).catch(() => {
          status.classList.add('text-red-500');
          status.textContent = 'Oops! There was a problem submitting your form';
        }).finally(() => {
          submitButton.disabled = false;
          submitButton.innerHTML = 'Subscribe';
        });
      });
    }
  </script>

  <section id="main-content" class="relative bg-background-dark text-white overflow-hidden min-h-screen flex items-center">
    <div class="absolute inset-0 bg-black/60 z-10"></div>
    <img
      id="hero-bg"
      class="absolute inset-0 w-full h-full object-cover z-0"
      src="https://xkwg7luliofrc1cs.public.blob.vercel-storage.com/Images/Par%20Gerell%20Ormeau%20.jpg"
      alt="Ormeau Table Tennis Club hero"
      fetchpriority="high"
      decoding="async"
    />
    <div class="relative z-20 max-w-5xl mx-auto px-4 sm:px-6 lg:px-10 py-20 sm:py-32 flex flex-col items-center text-center">
      <span class="inline-block py-2 px-4 sm:px-6 rounded-full bg-primary/20 border border-primary/40 backdrop-blur-md text-xs sm:text-sm font-bold mb-6 sm:mb-10 uppercase tracking-[0.1em] sm:tracking-[0.2em] text-primary">Table Tennis For Everyone</span>
      <h1 class="text-4xl sm:text-5xl md:text-8xl font-bold tracking-tight mb-6 sm:mb-10 leading-[1.1] max-w-5xl"> ORMEAU <span class="text-primary">Table Tennis Club</span> <span class="block text-2xl sm:text-3xl md:text-5xl mt-2 sm:mt-4 font-light">Belfast</span> </h1>
      <p class="text-base sm:text-xl md:text-2xl text-gray-200 max-w-2xl mb-10 sm:mb-16 font-light leading-relaxed px-2"> Whether you're starting your journey or pushing for the podium, Ormeau provides the environment, coaching, and community you need to thrive. </p>
      <div class="flex flex-col sm:flex-row items-stretch sm:items-center justify-center w-full max-w-md gap-3 sm:gap-6 px-4 sm:px-0">
        <a class="px-6 sm:px-8 py-3 sm:py-4 rounded-full bg-primary text-white font-bold text-base sm:text-lg hover:bg-primary-hover transition-all duration-300 shadow-2xl shadow-primary/40 transform hover:-translate-y-1 text-center" class="nav-link" href="/join"> Start Playing </a>
        <a class="px-6 sm:px-8 py-3 sm:py-4 rounded-full bg-transparent border-2 border-white/30 text-white font-bold text-base sm:text-lg hover:bg-white hover:text-black hover:border-white transition-all duration-300 flex items-center justify-center gap-2 text-center" href="#how-the-club-works"> How The Club Works </a>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="py-16 sm:py-24 bg-[#1a1a1a]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-10">
      <div class="grid md:grid-cols-2 gap-8 sm:gap-16 items-center">
        <div class="order-2 md:order-1 relative">
          <div class="absolute -top-4 -left-4 w-full h-full border-2 border-primary rounded-3xl z-0 hidden md:block"></div>
          <div class="relative z-10 rounded-2xl overflow-hidden shadow-2xl" style="border-radius: 12px; overflow: hidden;">
            <img alt="Club Atmosphere" class="w-full h-full object-cover" style="border-radius: 12px;" src="https://xkwg7luliofrc1cs.public.blob.vercel-storage.com/Images/group%20pic%20hero%20.jpg"/>
          </div>
        </div>
        <div class="order-1 md:order-2 text-center md:text-left flex flex-col items-center md:items-start">
          <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-6 sm:mb-8 leading-tight">More Than Just A <span class="text-primary">Club</span>,<br/>A Place To Grow.</h2>
          <div class="w-[60px] h-1.5 bg-primary rounded-full mb-4 md:mb-8"></div>
          <p class="text-lg text-gray-300 mb-6 leading-relaxed"> Ormeau Table Tennis Club isn't just about hitting a ball back and forth. It's about personal development, resilience, and community. We've built a space where players of all ages come together to learn, compete, and support one another. </p>
          <p class="text-lg text-gray-300 mb-10 leading-relaxed"> From our humble beginnings to becoming a powerhouse in British table tennis, our core mission remains the same: to provide the best possible environment for everyone to enjoy the sport. </p>
          <a class="inline-flex items-center text-white font-bold text-lg underline underline-offset-4 decoration-2 decoration-primary/80 hover:text-primary hover:decoration-primary py-3 px-0 inline-block" class="nav-link" href="/about" style="padding: 14px 0;"> Learn More About Our Story <span class="material-icons ml-2" aria-hidden="true">arrow_forward</span> </a>
        </div>
      </div>
    </div>
  </section>

  <!-- How The Club Works -->
  <section class="py-16 sm:py-24 bg-[#262626]" id="how-the-club-works">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-10">
      <div class="text-center mb-12 sm:mb-20">
        <span class="text-white font-bold tracking-widest uppercase text-xs sm:text-sm">Your Journey</span>
        <h2 class="text-3xl sm:text-4xl font-bold mt-2 mb-4 sm:mb-6 text-white">How The Club Works</h2>
        <p class="text-gray-400 max-w-2xl mx-auto text-base sm:text-lg px-4 text-white/70">We have a structured pathway designed to help every player find their level and enjoy the game.</p>
      </div>
      <h2 class="sr-only">Club Pathway Steps</h2>
      <div class="grid md:grid-cols-3 gap-4 sm:gap-10">
        <div class="bg-[#1a1a1a] p-6 sm:p-10 rounded-2xl sm:rounded-3xl shadow-sm hover:shadow-xl transition-all duration-300 group border-b-4 border-primary border border-white/10 flex flex-col items-center sm:items-start text-center sm:text-left">
          <div class="w-14 h-14 sm:w-16 sm:h-16 rounded-2xl bg-primary/10 flex items-center justify-center text-primary mb-6 sm:mb-8 group-hover:bg-primary group-hover:text-white transition-colors">
            <span class="material-symbols-outlined text-3xl sm:text-4xl" aria-hidden="true">school</span>
          </div>
          <h3 class="text-xl sm:text-2xl font-bold mb-3 sm:mb-4">Start with Coaching</h3>
          <p class="text-sm sm:text-base text-gray-400 leading-relaxed mb-6"> Beginners join our foundation classes. Learn the basics, grip, and movement in a fun, supportive group setting. </p>
        </div>
        <div class="bg-[#1a1a1a] p-6 sm:p-10 rounded-2xl sm:rounded-3xl shadow-sm hover:shadow-xl transition-all duration-300 group border-b-4 border-gray-700 hover:border-primary border border-white/10 flex flex-col items-center sm:items-start text-center sm:text-left">
          <div class="w-14 h-14 sm:w-16 sm:h-16 rounded-2xl bg-primary/10 flex items-center justify-center text-primary mb-6 sm:mb-8 group-hover:bg-primary group-hover:text-white transition-colors">
            <span class="material-symbols-outlined text-3xl sm:text-4xl" aria-hidden="true">trending_up</span>
          </div>
          <h3 class="text-xl sm:text-2xl font-bold mb-3 sm:mb-4">Progress at Your Pace</h3>
          <p class="text-sm sm:text-base text-gray-400 leading-relaxed mb-6"> Move up to intermediate squads as you improve. Participate in internal leagues and start testing your skills. </p>
        </div>
        <div class="bg-[#1a1a1a] p-6 sm:p-10 rounded-2xl sm:rounded-3xl shadow-sm hover:shadow-xl transition-all duration-300 group border-b-4 border-gray-700 hover:border-primary border border-white/10 flex flex-col items-center sm:items-start text-center sm:text-left">
          <div class="w-14 h-14 sm:w-16 sm:h-16 rounded-2xl bg-primary/10 flex items-center justify-center text-primary mb-6 sm:mb-8 group-hover:bg-primary group-hover:text-white transition-colors">
            <span class="material-symbols-outlined text-3xl sm:text-4xl" aria-hidden="true">trophy</span>
          </div>
          <h3 class="text-xl sm:text-2xl font-bold mb-3 sm:mb-4">Opportunities to Go Further</h3>
          <p class="text-sm sm:text-base text-gray-400 leading-relaxed mb-6"> Elite coaching for those aiming for national selection. Represent the club in the British League and international events. </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Coaching Section -->
  <section class="py-16 sm:py-24 bg-[#1a1a1a] relative overflow-hidden">
    <div class="absolute right-0 top-0 w-1/3 h-full bg-[#262626]/50 hidden lg:block"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-10 relative z-10">
      <div class="grid lg:grid-cols-2 gap-8 sm:gap-16 items-center">
        <div class="order-1 lg:order-1 text-center lg:text-left flex flex-col items-center lg:items-start">
          <span class="text-white font-bold tracking-widest uppercase text-sm">Coaching</span>
          <h2 class="text-4xl md:text-5xl font-bold mt-2 mb-8 text-white">Built By Players, For Players</h2>
          <p class="text-lg text-gray-300 mb-8 max-w-2xl mx-auto lg:mx-0"> Keith and Gervis Knox didn't just build a club — they built the coaching environment they wished they'd had. Both played for Ulster and Ireland before dedicating themselves to coaching, and that playing experience shapes everything about how sessions are run at Ormeau. </p>
          <ul class="space-y-5 sm:space-y-6 mb-10 w-full max-w-2xl mx-auto lg:mx-0">
            <li class="flex flex-col items-center lg:flex-row lg:items-start">
              <span class="material-icons text-4xl sm:text-6xl text-primary/10 absolute top-4 sm:top-6 right-4 sm:right-6" aria-hidden="true">check_circle</span>
              <div>
                <h3 class="font-bold text-lg">Coaches who've been there</h3>
                <p class="text-gray-500 dark:text-gray-400 text-sm">Our head coaches represented Ulster and Ireland before making coaching their career.</p>
              </div>
            </li>
            <li class="flex flex-col items-center lg:flex-row lg:items-start">
              <span class="material-icons text-4xl sm:text-6xl text-primary/10 absolute top-4 sm:top-6 right-4 sm:right-6" aria-hidden="true">check_circle</span>
              <div>
                <h3 class="font-bold text-lg">Individual attention in every session</h3>
                <p class="text-gray-500 dark:text-gray-400 text-sm">Small group sizes mean every player is seen, guided, and challenged.</p>
              </div>
            </li>
            <li class="flex flex-col items-center lg:flex-row lg:items-start">
              <span class="material-icons text-4xl sm:text-6xl text-primary/10 absolute top-4 sm:top-6 right-4 sm:right-6" aria-hidden="true">check_circle</span>
              <div>
                <h3 class="font-bold text-lg">A pathway that actually works</h3>
                <p class="text-gray-500 dark:text-gray-400 text-sm">From your first session to the British Premier League — we've walked players through every step.</p>
              </div>
            </li>
            <li class="flex flex-col items-center lg:flex-row lg:items-start">
              <span class="material-icons text-4xl sm:text-6xl text-primary/10 absolute top-4 sm:top-6 right-4 sm:right-6" aria-hidden="true">check_circle</span>
              <div>
                <h3 class="font-bold text-lg">Coaching for every level</h3>
                <p class="text-gray-500 dark:text-gray-400 text-sm">Whether you're a complete beginner or pushing for national selection, there's a session built for you.</p>
              </div>
            </li>
          </ul>
          <a class="px-8 py-4 rounded-full bg-primary text-white font-bold text-lg hover:bg-primary-hover transition shadow-lg inline-block w-full sm:w-auto text-center mt-2" href="/join"> Register Your Interest </a>
        </div>
        <div class="order-2 lg:order-2 relative h-[400px] sm:h-[500px] lg:h-[600px] rounded-2xl lg:rounded-3xl overflow-hidden shadow-2xl mt-8 lg:mt-0">
          <img alt="Keith Knox" class="absolute inset-0 w-full h-full object-cover" src="/keith.jpg" decoding="async"/>
          <div class="absolute bottom-0 left-0 right-0 p-6 bg-black/80">
            <p class="font-bold text-xl">Keith Knox</p>
            <p class="text-primary font-medium text-sm">Head Performance Coach</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Champions Section -->
  <section class="py-16 sm:py-24 bg-black text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-10">
      <div class="text-center mb-10 sm:mb-16">
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 sm:mb-6">Proven Pathways</h2>
        <p class="text-gray-400 text-base sm:text-lg max-w-2xl mx-auto px-4">From our club to the world stage. We are proud of our champions.</p>
      </div>
      <div class="mb-12 sm:mb-20 rounded-2xl sm:rounded-3xl overflow-hidden relative aspect-video md:aspect-[21/9] group shadow-2xl ring-1 ring-white/10">
        <img alt="British League Premier Champions" class="w-full h-full object-cover object-top opacity-80 group-hover:scale-105 transition-transform duration-1000 ease-out" src="https://xkwg7luliofrc1cs.public.blob.vercel-storage.com/Images/Prem%20Winners%20.jpg"/>
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
        <div class="absolute bottom-0 left-0 w-full p-8 md:p-12">
          <div class="max-w-3xl transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
            <span class="inline-block py-1 px-3 rounded-full bg-primary/20 text-primary text-xs font-bold uppercase tracking-wider border border-primary/30 mb-4 backdrop-blur-sm">Historic Win</span>
            <h3 class="text-3xl md:text-5xl font-bold mb-2 text-white drop-shadow-md">British League Premier Champions</h3>
            <p class="text-primary text-xl md:text-2xl font-medium mb-8 drop-shadow-md">2022-23 Season</p>
            <a href="https://www.tabletennisengland.co.uk/news/2023/ormeau-crowned-champions-as-2022-23-sbl-premier-division-comes-to-a-close/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 bg-white text-black font-bold text-lg rounded-full hover:bg-gray-100 hover:scale-105 transition-all duration-300 shadow-lg hover:shadow-white/30">
              Read The Story <span class="material-icons text-sm" aria-hidden="true">arrow_forward</span>
            </a>
          </div>
        </div>
      </div>
      <!-- Champions Carousel (mobile) / Grid (desktop) -->
      <div class="champions-grid overflow-x-auto snap-x snap-mandatory flex gap-4 pb-4 -mx-4 px-4 md:mx-0 md:px-0 md:grid md:grid-cols-3 md:gap-8 md:overflow-visible md:pb-0">
        <div class="champion-card group relative overflow-hidden rounded-2xl bg-gray-900 aspect-[4/3] md:aspect-[3/4] min-w-[85vw] md:min-w-0 snap-center shadow-lg hover:shadow-primary/20 transition-all duration-500">
          <img alt="Owen Cathcart" class="absolute inset-0 w-full h-full object-cover rounded-xl opacity-60 group-hover:opacity-100 transition duration-500 scale-100 group-hover:scale-110" src="https://scontent-lhr6-1.xx.fbcdn.net/v/t1.6435-9/29356593_2161628553848072_6140789986070364160_n.jpg?_nc_cat=102&ccb=1-7&_nc_sid=f798df&_nc_ohc=aQujp0WKy_wQ7kNvwGIvoZW&_nc_oc=Admuy7icN44zYz9mWUsGyKx-G9c6F4U3oh1gB_4q0hR5CWvqijBVc98YSZ9NLL_yB6j19kCOObl963dj6jeq2SSl&_nc_zt=23&_nc_ht=scontent-lhr6-1.xx&_nc_gid=ypsOkhgTRCGZYR-dzW-CuA&oh=00_Aft8bzH8t1I70h_xRvke254EN3Ov6FHyTg8VnGsYlmu1iQ&oe=69C2CA36"/>
          <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent opacity-80 group-hover:opacity-100 transition-opacity duration-300"></div>
          <div class="absolute bottom-0 left-0 p-6 w-full transform translate-y-2 group-hover:translate-y-0 transition-transform duration-300">
            <h3 class="text-2xl md:text-3xl font-bold text-white mb-1">Owen Cathcart</h3>
            <p class="text-primary font-medium text-sm md:text-base">30+ World Tour Medals</p>
          </div>
        </div>
        <div class="champion-card group relative overflow-hidden rounded-2xl bg-gray-900 aspect-[4/3] md:aspect-[3/4] min-w-[85vw] md:min-w-0 snap-center shadow-lg hover:shadow-primary/20 transition-all duration-500">
          <img alt="Sophie Earley" class="absolute inset-0 w-full h-full object-cover rounded-xl opacity-60 group-hover:opacity-100 transition duration-500 scale-100 group-hover:scale-110" src="https://marypeterstrust.org/wp-content/uploads/2022/07/Sophie-Earley-2.jpg"/>
          <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent opacity-80 group-hover:opacity-100 transition-opacity duration-300"></div>
          <div class="absolute bottom-0 left-0 p-6 w-full transform translate-y-2 group-hover:translate-y-0 transition-transform duration-300">
            <h3 class="text-2xl md:text-3xl font-bold text-white mb-1">Sophie Earley</h3>
            <p class="text-primary font-medium text-sm md:text-base">2x European Youth Medalist</p>
          </div>
        </div>
        <div class="champion-card group relative overflow-hidden rounded-2xl bg-gray-900 aspect-[4/3] md:aspect-[3/4] min-w-[85vw] md:min-w-0 snap-center shadow-lg hover:shadow-primary/20 transition-all duration-500">
          <img alt="Peadar Sheridan" class="absolute inset-0 w-full h-full object-cover rounded-xl opacity-60 group-hover:opacity-100 transition duration-500 scale-100 group-hover:scale-110" src="https://xkwg7luliofrc1cs.public.blob.vercel-storage.com/Images/peadar%20.jpg"/>
          <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent opacity-80 group-hover:opacity-100 transition-opacity duration-300"></div>
          <div class="absolute bottom-0 left-0 p-6 w-full transform translate-y-2 group-hover:translate-y-0 transition-transform duration-300">
            <h3 class="text-2xl md:text-3xl font-bold text-white mb-1">Peadar Sheridan</h3>
            <p class="text-primary font-medium text-sm md:text-base">European No.1 U13</p>
          </div>
        </div>
      </div>
      <!-- Dot indicators -->
      <div class="flex justify-center mt-6 md:hidden gap-2">
        <span class="w-3 h-3 rounded-full bg-primary"></span>
        <span class="w-3 h-3 rounded-full bg-gray-300"></span>
        <span class="w-3 h-3 rounded-full bg-gray-300"></span>
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="py-16 sm:py-24 bg-[#262626]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-10">
      <h2 class="text-2xl sm:text-3xl font-bold text-center mb-10 sm:mb-16">What They Say</h2>
      <div class="relative">
        <!-- Right edge gradient shadow -->
        <div class="absolute right-0 top-0 bottom-0 w-12 bg-gradient-to-l from-[#262626] to-transparent z-10 pointer-events-none md:hidden"></div>
        <div class="overflow-x-auto snap-x snap-mandatory flex gap-4 pb-4 -mx-4 px-4 md:mx-0 md:px-0 md:grid md:grid-cols-3 md:gap-8 md:overflow-visible md:pb-0">
          <div class="bg-[#1a1a1a] p-6 sm:p-8 md:p-10 rounded-2xl shadow-sm relative flex flex-col min-w-[90vw] md:min-w-0 snap-center hover:-translate-y-2 transition-transform duration-300 border border-white/5 hover:border-primary/30">
            <span class="material-icons text-4xl sm:text-6xl text-primary/10 absolute top-4 sm:top-6 right-4 sm:right-6" aria-hidden="true">format_quote</span>
            <p class="text-base sm:text-lg md:text-xl text-gray-300 mb-8 italic relative z-10 flex-grow leading-relaxed md:text-left text-center">"The coaching standard at Ormeau is second to none. They have created a professional environment that is still welcoming to everyone."</p>
            <div class="flex flex-col md:flex-row items-center md:items-center gap-4 mt-auto pt-6 border-t border-white/10 text-center md:text-left">
              <img alt="Jeff Harrison" class="w-14 h-14 rounded-full object-cover" src="/jeff-harrison.png" decoding="async" loading="lazy"/>
              <div>
                <h3 class="font-bold text-white">Jeff Harrison</h3>
                <p class="text-xs text-white/80 uppercase font-bold tracking-wider">Club Member</p>
              </div>
            </div>
          </div>
          <div class="bg-[#1a1a1a] p-6 sm:p-8 md:p-10 rounded-2xl shadow-sm relative flex flex-col min-w-[90vw] md:min-w-0 snap-center hover:-translate-y-2 transition-transform duration-300 border border-white/5 hover:border-primary/30">
            <span class="material-icons text-4xl sm:text-6xl text-primary/10 absolute top-4 sm:top-6 right-4 sm:right-6" aria-hidden="true">format_quote</span>
            <p class="text-base sm:text-lg md:text-xl text-gray-300 mb-8 italic relative z-10 flex-grow leading-relaxed md:text-left text-center">"I've really enjoyed playing social table tennis for over 10 years at the club. It's great way to keep fit and good fun!"</p>
            <div class="flex flex-col md:flex-row items-center md:items-center gap-4 mt-auto pt-6 border-t border-white/10 text-center md:text-left">
              <img alt="Deirdre Sealy" class="w-14 h-14 rounded-full object-cover" src="https://scontent-lhr8-1.xx.fbcdn.net/v/t1.6435-9/67394003_2426293830786092_693504615483703296_n.jpg?_nc_cat=107&ccb=1-7&_nc_sid=f798df&_nc_ohc=hvlRSSWBYtgQ7kNvwGtL3Ug&_nc_oc=AdmaPz35oNgVBv6TEsTWHGGjOzFQYw-GLBFq07Fr0RSmhtgcQxCtlhFWDYk7jqr6CFHwg-G7tQb3chVqCY7xmSm2&_nc_zt=23&_nc_ht=scontent-lhr8-1.xx&_nc_gid=uXe3LwM8lpvrkmc8saOVcg&oh=00_AfuxYGRWRU-LFOaYkzdZSAMzFbRyVCIAhI6UX83vDPvOsw&oe=69C2CB09"/>
