---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Strandtown Table Tennis - Ormeau Table Tennis Club" description="Join Strandtown's premier table tennis program. Master fundamentals while having fun, participate in awards program and mini-competitions. Part of a championship legacy.">
  <Header />
  <section class="relative bg-background-dark text-white overflow-hidden">
    <div class="absolute inset-0 bg-black/70 z-10"></div>
    <div class="absolute inset-0 bg-[url('https://xkwg7luliofrc1cs.public.blob.vercel-storage.com/Images/strandtown.jpg')] bg-cover bg-center z-0"></div>
    <div class="relative z-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-10 py-20 sm:py-32 md:py-40">
      <div class="max-w-3xl mx-auto text-center">
        <span class="inline-block py-2 px-4 rounded-full bg-primary/20 border border-primary/30 text-primary text-xs sm:text-sm font-bold mb-4 sm:mb-6 uppercase tracking-widest">Schools Coaching</span>
        <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight mb-6 sm:mb-8 leading-tight"> Strandtown <span class="text-primary">Table Tennis</span> </h1>
        <p class="text-base sm:text-lg md:text-xl text-gray-300 leading-relaxed font-light mb-8 sm:mb-10"> The kids will master the fundamentals while having fun, and participate in mini-competitions. </p>
        <a href="#register" class="inline-flex items-center gap-2 px-6 sm:px-8 py-3 sm:py-4 bg-primary text-white font-bold rounded-full hover:bg-primary-hover transition-all duration-300 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 text-sm sm:text-base">
          <span class="material-icons text-lg sm:text-xl">how_to_reg</span>
          Register Now
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 sm:py-24 bg-white dark:bg-background-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 lg:px-10">
      <div class="text-center mb-12 sm:mb-16">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold mb-4">Program Features</h2>
        <p class="text-gray-500 text-base sm:text-lg max-w-2xl mx-auto">Everything your child needs to develop their table tennis skills and build confidence.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 sm:gap-8 mb-16">
        <!-- Feature 1 -->
        <div class="text-center group">
          <div class="bg-primary/10 w-16 sm:w-20 h-16 sm:h-20 rounded-full flex items-center justify-center mx-auto mb-4 sm:mb-6 group-hover:bg-primary transition-all duration-300">
            <svg class="w-6 h-6 sm:w-8 sm:h-8 text-primary group-hover:text-white transition-all duration-300" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="12" cy="8" rx="6" ry="7.5" fill="currentColor" stroke="currentColor" stroke-width="1"/>
            <rect x="10" y="14" width="4" height="8" fill="currentColor" rx="1"/>
            <line x1="12" y1="2" x2="12" y2="14" stroke="white" stroke-width="1"/>
            <line x1="7" y1="6" x2="17" y2="10" stroke="white" stroke-width="1"/>
            <line x1="7" y1="10" x2="17" y2="6" stroke="white" stroke-width="1"/>
          </svg>
          </div>
          <h3 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3">Master Fundamentals</h3>
          <p class="text-sm sm:text-base text-gray-600 dark:text-gray-400">Professional coaching focused on developing core table tennis techniques while making learning fun and engaging.</p>
        </div>
        
        <!-- Feature 2 -->
        <div class="text-center group">
          <div class="bg-primary/10 w-16 sm:w-20 h-16 sm:h-20 rounded-full flex items-center justify-center mx-auto mb-4 sm:mb-6 group-hover:bg-primary transition-all duration-300">
            <span class="material-icons text-2xl sm:text-3xl text-primary group-hover:text-white transition-all duration-300">school</span>
          </div>
          <h3 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3">Learn</h3>
          <p class="text-sm sm:text-base text-gray-600 dark:text-gray-400">In our sessions, the coach will be providing all the rules and information to try to fully understand the sport of table tennis.</p>
        </div>
        
        <!-- Feature 3 -->
        <div class="text-center group">
          <div class="bg-primary/10 w-16 sm:w-20 h-16 sm:h-20 rounded-full flex items-center justify-center mx-auto mb-4 sm:mb-6 group-hover:bg-primary transition-all duration-300">
            <span class="material-icons text-2xl sm:text-3xl text-primary group-hover:text-white transition-all duration-300">leaderboard</span>
          </div>
          <h3 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3">Mini-Competitions</h3>
          <p class="text-sm sm:text-base text-gray-600 dark:text-gray-400">Regular friendly competitions that build confidence and sportsmanship in a supportive environment.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 sm:py-24 bg-surface-light dark:bg-surface-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 lg:px-10">
      <div class="text-center mb-12 sm:mb-16">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold mb-4">Session Schedule</h2>
        <p class="text-gray-500 text-base sm:text-lg max-w-2xl mx-auto">Choose from our available sessions. Limited spaces available - book early to avoid disappointment.</p>
      </div>
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 sm:gap-8">
        <!-- Monday Afterschool -->
        <div class="bg-white dark:bg-background-dark rounded-3xl shadow-xl overflow-hidden border-2 border-green-500">
          <div class="bg-green-500 text-white p-6 text-center">
            <div class="flex items-center justify-center gap-2 mb-2">
              <span class="material-icons">event_available</span>
              <span class="font-bold text-xl">Monday Afterschool</span>
            </div>
            <p class="text-sm opacity-90">10 Week Block Booking</p>
          </div>
          <div class="p-4 sm:p-6 lg:p-8">
            <div class="flex items-center gap-3 mb-4 sm:mb-6">
              <span class="material-icons text-primary">schedule</span>
              <div>
                <p class="font-semibold text-sm sm:text-base">Time: 3-4 pm</p>
                <p class="text-gray-500 text-xs sm:text-sm">Assembly Hall</p>
              </div>
            </div>
            <div class="bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-xl p-3 sm:p-4 mb-4 sm:mb-6">
              <div class="flex items-center gap-2">
                <span class="material-icons text-green-600">check_circle</span>
                <span class="font-bold text-green-600 text-sm sm:text-base">AVAILABLE FOR BOOKING</span>
              </div>
            </div>
            <div class="space-y-3 sm:space-y-4">
              <div class="border-b border-gray-100 dark:border-gray-800 pb-3 sm:pb-4">
                <div class="flex items-center justify-between mb-2">
                  <p class="font-semibold text-primary text-sm sm:text-base">April:</p>
                  <a href="https://calendar.google.com/calendar/render?action=TEMPLATE&text=Strandtown+Monday+Table+Tennis&dates=20250413T150000/20250413T160000,20250420T150000/20250420T160000,20250427T150000/20250427T160000&details=Monday+afternoon+table+tennis+coaching+at+Strandtown+School%0ATime:+3-4+pm%0ALocation:+Assembly+Hall&location=Strandtown+School,+Assembly+Hall" target="_blank" class="text-green-600 hover:text-green-700 text-xs sm:text-sm font-medium flex items-center gap-1">
                    <span class="material-icons text-sm">calendar_month</span>
                    Add to Calendar
                  </a>
                </div>
                <p class="text-xs sm:text-sm text-gray-600 dark:text-gray-400">13th, 20th & 27th</p>
              </div>
              <div class="border-b border-gray-100 dark:border-gray-800 pb-3 sm:pb-4">
                <div class="flex items-center justify-between mb-2">
                  <p class="font-semibold text-primary text-sm sm:text-base">May:</p>
                  <a href="https://calendar.google.com/calendar/render?action=TEMPLATE&text=Strandtown+Monday+Table+Tennis&dates=20250511T150000/20250511T160000,20250518T150000/20250518T160000&details=Monday+afternoon+table+tennis+coaching+at+Strandtown+School%0ATime:+3-4+pm%0ALocation:+Assembly+Hall&location=Strandtown+School,+Assembly+Hall" target="_blank" class="text-green-600 hover:text-green-700 text-xs sm:text-sm font-medium flex items-center gap-1">
                    <span class="material-icons text-sm">calendar_month</span>
                    Add to Calendar
                  </a>
                </div>
                <p class="text-xs sm:text-sm text-gray-600 dark:text-gray-400">11th & 18th</p>
              </div>
              <div class="pb-3 sm:pb-4">
                <div class="flex items-center justify-between mb-2">
                  <p class="font-semibold text-primary text-sm sm:text-base">June:</p>
                  <a href="https://calendar.google.com/calendar/render?action=TEMPLATE&text=Strandtown+Monday+Table+Tennis&dates=20250601T150000/20250601T160000,20250608T150000/20250608T160000,20250615T150000/20250615T160000,20250622T150000/20250622T160000,20250629T150000/20250629T160000&details=Monday+afternoon+table+tennis+coaching+at+Strandtown+School%0ATime:+3-4+pm%0ALocation:+Assembly+Hall&location=Strandtown+School,+Assembly+Hall" target="_blank" class="text-green-600 hover:text-green-700 text-xs sm:text-sm font-medium flex items-center gap-1">
                    <span class="material-icons text-sm">calendar_month</span>
                    Add to Calendar
                  </a>
                </div>
                <p class="text-xs sm:text-sm text-gray-600 dark:text-gray-400">1st, 8th, 15th, 22nd & 29th</p>
              </div>
            </div>
            <a href="#register" class="group w-full py-3 sm:py-4 bg-gradient-to-r from-green-500 to-green-600 text-white font-bold rounded-xl hover:from-green-600 hover:to-green-700 transition-all duration-300 text-center mt-4 sm:mt-6 shadow-lg shadow-green-500/25 hover:shadow-xl hover:shadow-green-600/40 transform hover:-translate-y-0.5 relative overflow-hidden">
              <span class="relative z-10 flex items-center justify-center gap-2 pt-1 text-sm sm:text-base">
                <span class="material-icons text-sm sm:text-lg">calendar_today</span>
                Book Monday Sessions
              </span>
              <div class="absolute inset-0 bg-gradient-to-r from-white/0 to-white/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            </a>
          </div>
        </div>

        <!-- Friday Afterschool -->
        <div class="bg-white dark:bg-background-dark rounded-3xl shadow-xl overflow-hidden border-2 border-green-500">
          <div class="bg-green-500 text-white p-6 text-center">
            <div class="flex items-center justify-center gap-2 mb-2">
              <span class="material-icons">event_available</span>
              <span class="font-bold text-xl">Friday Afterschool</span>
            </div>
            <p class="text-sm opacity-90">11 Week Block Booking</p>
          </div>
          <div class="p-4 sm:p-6 lg:p-8">
            <div class="flex items-center gap-3 mb-4 sm:mb-6">
              <span class="material-icons text-primary">schedule</span>
              <div>
                <p class="font-semibold text-sm sm:text-base">Time: 1.45-2.45 pm</p>
                <p class="text-gray-500 text-xs sm:text-sm">Assembly Hall</p>
              </div>
            </div>
            <div class="bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-xl p-3 sm:p-4 mb-4 sm:mb-6">
              <div class="flex items-center gap-2">
                <span class="material-icons text-green-600">check_circle</span>
                <span class="font-bold text-green-600 text-sm sm:text-base">AVAILABLE FOR BOOKING</span>
              </div>
            </div>
            <div class="space-y-3 sm:space-y-4">
              <div class="border-b border-gray-100 dark:border-gray-800 pb-3 sm:pb-4">
                <div class="flex items-center justify-between mb-2">
                  <p class="font-semibold text-primary text-sm sm:text-base">April:</p>
                  <a href="https://calendar.google.com/calendar/render?action=TEMPLATE&text=Strandtown+Friday+Table+Tennis&dates=20250410T134500/20250410T144500,20250417T134500/20250417T144500,20250424T134500/20250424T144500&details=Friday+afternoon+table+tennis+coaching+at+Strandtown+School%0ATime:+1.45-2.45+pm%0ALocation:+Assembly+Hall&location=Strandtown+School,+Assembly+Hall" target="_blank" class="text-green-600 hover:text-green-700 text-xs sm:text-sm font-medium flex items-center gap-1">
                    <span class="material-icons text-sm">calendar_month</span>
                    Add to Calendar
                  </a>
                </div>
                <p class="text-xs sm:text-sm text-gray-600 dark:text-gray-400">10th, 17th & 24th</p>
              </div>
              <div class="border-b border-gray-100 dark:border-gray-800 pb-3 sm:pb-4">
                <div class="flex items-center justify-between mb-2">
                  <p class="font-semibold text-primary text-sm sm:text-base">May:</p>
                  <a href="https://calendar.google.com/calendar/render?action=TEMPLATE&text=Strandtown+Friday+Table+Tennis&dates=20250501T134500/20250501T144500,20250508T134500/20250508T144500,20250515T134500/20250515T144500,20250529T134500/20250529T144500&details=Friday+afternoon+table+tennis+coaching+at+Strandtown+School%0ATime:+1.45-2.45+pm%0ALocation:+Assembly+Hall&location=Strandtown+School,+Assembly+Hall" target="_blank" class="text-green-600 hover:text-green-700 text-xs sm:text-sm font-medium flex items-center gap-1">
                    <span class="material-icons text-sm">calendar_month</span>
                    Add to Calendar
                  </a>
                </div>
                <p class="text-xs sm:text-sm text-gray-600 dark:text-gray-400">1st, 8th, 15th & 29th</p>
              </div>
              <div class="pb-3 sm:pb-4">
                <div class="flex items-center justify-between mb-2">
                  <p class="font-semibold text-primary text-sm sm:text-base">June:</p>
                  <a href="https://calendar.google.com/calendar/render?action=TEMPLATE&text=Strandtown+Friday+Table+Tennis&dates=20250605T134500/20250605T144500,20250612T134500/20250612T144500,20250619T134500/20250619T144500,20250626T134500/20250626T144500&details=Friday+afternoon+table+tennis+coaching+at+Strandtown+School%0ATime:+1.45-2.45+pm%0ALocation:+Assembly+Hall&location=Strandtown+School,+Assembly+Hall" target="_blank" class="text-green-600 hover:text-green-700 text-xs sm:text-sm font-medium flex items-center gap-1">
                    <span class="material-icons text-sm">calendar_month</span>
                    Add to Calendar
                  </a>
                </div>
                <p class="text-xs sm:text-sm text-gray-600 dark:text-gray-400">5th, 12th, 19th & 26th</p>
              </div>
            </div>
            <a href="#register" class="group w-full py-3 sm:py-4 bg-gradient-to-r from-green-500 to-green-600 text-white font-bold rounded-xl hover:from-green-600 hover:to-green-700 transition-all duration-300 text-center mt-4 sm:mt-6 shadow-lg shadow-green-500/25 hover:shadow-xl hover:shadow-green-600/40 transform hover:-translate-y-0.5 relative overflow-hidden">
              <span class="relative z-10 flex items-center justify-center gap-2 pt-1 text-sm sm:text-base">
                <span class="material-icons text-sm sm:text-lg">calendar_today</span>
                Book Friday Sessions
              </span>
              <div class="absolute inset-0 bg-gradient-to-r from-white/0 to-white/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="register" class="py-16 sm:py-24 bg-white dark:bg-background-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 lg:px-10">
      <div class="text-center mb-12 sm:mb-16">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold mb-4">Register for Strandtown Table Tennis</h2>
        <p class="text-gray-500 text-base sm:text-lg max-w-2xl mx-auto">Complete the form below to secure your place in our schools coaching program.</p>
      </div>
      
      <div class="max-w-4xl mx-auto">
        <div class="bg-gray-50 dark:bg-gray-800 rounded-2xl p-4 sm:p-6 md:p-8 shadow-xl">
          <iframe src="https://www.cognitoforms.com/f/nR0HQjg5VUqZ_2t6O8kL5g/27" allow="payment" style="border:0;width:100%;" height="1200" class="sm:h-[1400px] md:h-[1780px]"></iframe>
          <script src="https://www.cognitoforms.com/f/iframe.js"></script>
        </div>
      </div>
    </div>
  </section>

  <section class="relative py-20 sm:py-32 overflow-hidden bg-primary">
    <div class="absolute inset-0 opacity-10 grayscale mix-blend-overlay">
      <img class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDTr5ZYUqSr67umNFQBjUXdmYvuyqDAzBbNKd4Kq1wktWGLcYn5ogtLA7y7YVdR4d7tLOaq3b9DIwTKuiuvoavDonQeZoVEG-eZyLb52qd2OZZfzsJ7TlRmBiF5aJ9omD6fYoAD3MfFJnZRO-U4F9_rAvj6eZjzAFLJwjGCgTnYW1J8aEWajqLHG6L4_nDwTnllpT7T0kBXD90R4J3vMoYWHfim4zkO_OGLzzGPmNvdr_7RasQ7z1jAaCOudsHoYD1A1KFSW4roR7Sc" alt="Table Tennis Competition Background">
    </div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 text-center text-white">
      <h2 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold mb-6 sm:mb-8">Strandtown Table Tennis</h2>
      <p class="text-lg sm:text-xl opacity-90 mb-8 sm:mb-12 font-light max-w-2xl mx-auto">Be part of Strandtown's proud table tennis tradition. Spaces are limited for Term 3 - secure your child's place today.</p>
      <div class="flex flex-col sm:flex-row justify-center gap-4 sm:gap-6">
        <a href="/contact" class="px-8 sm:px-12 py-4 sm:py-5 bg-white text-primary font-bold rounded-full hover:bg-gray-100 transition-all shadow-2xl uppercase tracking-widest text-xs sm:text-sm">Ask A Question</a>
      </div>
    </div>
  </section>
  <Footer />
</Layout>
