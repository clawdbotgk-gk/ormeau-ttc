---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Little Wing Junior League - Ormeau Table Tennis Club" description="Join the Little Wing Junior League at Ormeau Table Tennis Club. Junior team competition for ages 10-16, Sundays 2-4pm in Belfast.">
  <Header />
<script is:inline>
    (function() {
      const path = window.location.pathname;
      document.querySelectorAll('.nav-link').forEach(link => {
        const href = link.getAttribute('href');
        if ((path === '/' && href === '/') || href === path || href === path + '/') {
          link.classList.add('text-primary', 'dark:text-primary');
        }
      });
    })();
  </script>

  <!-- Hero Section -->
  <section class="relative bg-background-dark text-white overflow-hidden">
    <div class="absolute inset-0 bg-black/40 z-10 md:bg-black/40"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-black/20 to-black/10 z-10 md:hidden"></div>
    <div class="relative z-20 max-w-7xl mx-auto px-6 sm:px-8 lg:px-10 pt-[200px] sm:pt-48 md:pt-64 pb-16 sm:pb-24 md:pb-32">
      <div class="max-w-4xl">
        <span class="inline-block py-1 px-4 rounded-full bg-primary/20 border border-primary/30 text-primary text-sm font-bold mb-6 uppercase tracking-widest">New Junior League</span>
        <h1 class="text-[2rem] sm:text-4xl md:text-6xl font-bold tracking-tight mb-6 sm:mb-8 leading-tight"> Little Wing <span class="text-primary">Junior League</span> </h1>
        <p class="text-base sm:text-lg md:text-xl text-gray-300 leading-relaxed font-light mb-8 sm:mb-10"> Join the new Little Wing Junior League - junior team table tennis for ages 10-16. Teams of 2 compete in a Davis Cup format with two divisions by ability. Four exciting Sunday afternoons of competition. </p>
        
        <div class="grid sm:grid-cols-2 gap-4 mb-8 sm:mb-10">
          <div class="bg-[#262626] border border-gray-800 rounded-xl p-6">
            <div class="text-primary font-semibold mb-2">📅 Dates</div>
            <div class="text-gray-300">26 April • 10 May • 24 May • 7 June</div>
          </div>
          <div class="bg-[#262626] border border-gray-800 rounded-xl p-6">
            <div class="text-primary font-semibold mb-2">🏓 Format</div>
            <div class="text-gray-300">Davis Cup • 2 Singles + Doubles • Best of 3</div>
          </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-4">
          <a href="#register" class="px-8 py-4 bg-primary text-white font-bold rounded-lg md:rounded-full hover:bg-primary-hover transition-colors shadow-lg shadow-primary/30 text-center">Enter a Team</a>
          <a href="/contact" class="px-8 py-4 bg-transparent border-2 border-white/30 text-white font-bold rounded-lg md:rounded-full hover:bg-white hover:text-black hover:border-white transition-all text-center">Ask a Question</a>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="py-24 bg-white dark:bg-background-dark">
    <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-10">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">What is the Little Wing Junior League?</h2>
        <div class="w-[60px] h-1 bg-primary mx-auto rounded-full"></div>
      </div>

      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-gray-600 dark:text-gray-400 mb-6 leading-relaxed">
            The Little Wing Junior League is a new junior team competition hosted by Ormeau Table Tennis Club. It's designed to give young players more matches, more team experience, and a brilliant atmosphere across four Sunday afternoons.
          </p>
          <p class="text-gray-600 dark:text-gray-400 mb-8 leading-relaxed">
            Players can enter with their own partner, or we can help pair players together. Entries from other clubs are welcome.
          </p>

          <h3 class="text-xl font-bold mb-4 text-primary">Why Enter:</h3>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <span class="material-symbols-outlined text-primary text-lg mt-0.5">check_circle</span>
              <span class="text-gray-600 dark:text-gray-400">Great match practice in a team environment</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="material-symbols-outlined text-primary text-lg mt-0.5">check_circle</span>
              <span class="text-gray-600 dark:text-gray-400">Two divisions to keep competition level appropriate</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="material-symbols-outlined text-primary text-lg mt-0.5">check_circle</span>
              <span class="text-gray-600 dark:text-gray-400">Fun way for juniors to represent their club</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="material-symbols-outlined text-primary text-lg mt-0.5">check_circle</span>
              <span class="text-gray-600 dark:text-gray-400">Prizes for winners & runners-up</span>
            </li>
          </ul>
        </div>

        <div class="bg-[#262626] border border-gray-800 rounded-2xl p-8">
          <h3 class="text-xl font-bold mb-6 text-white">League Details</h3>
          <div class="space-y-4">
            <div class="flex items-center gap-3">
              <span class="material-symbols-outlined text-primary">group</span>
              <div>
                <div class="text-white font-semibold">Ages</div>
                <div class="text-gray-400">10-16 years old</div>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <span class="material-symbols-outlined text-primary">sports_tennis</span>
              <div>
                <div class="text-white font-semibold">Format</div>
                <div class="text-gray-400">Davis Cup (2 singles + doubles)</div>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <span class="material-symbols-outlined text-primary">schedule</span>
              <div>
                <div class="text-white font-semibold">Time</div>
                <div class="text-gray-400">Sundays 2:00-4:00pm</div>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <span class="material-symbols-outlined text-primary">trophy</span>
              <div>
                <div class="text-white font-semibold">Divisions</div>
                <div class="text-gray-400">2 levels by ability</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Registration Section -->
  <section id="register" class="py-16 sm:py-24 bg-background-dark">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-10">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-bold mb-6 text-white">Enter a Team</h2>
        <div class="w-24 h-1.5 bg-primary rounded-full mx-auto mb-8"></div>
      </div>

      <div class="bg-surface-dark rounded-2xl p-8 border border-white/10">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
          <div class="bg-[#262626] border border-gray-800 rounded-xl p-6 text-center">
            <span class="material-symbols-outlined text-2xl text-primary mb-2">payments</span>
            <div class="text-sm text-gray-400 mb-1">Entry fee</div>
            <div class="text-lg font-bold text-primary">£40 per team<br><span class="text-sm text-gray-300">(£20 per player)</span></div>
          </div>
          <div class="bg-[#262626] border border-gray-800 rounded-xl p-6 text-center">
            <span class="material-symbols-outlined text-2xl text-primary mb-2">group</span>
            <div class="text-sm text-gray-400 mb-1">Ages</div>
            <div class="text-lg font-bold text-primary">10–16</div>
          </div>
          <div class="bg-[#262626] border border-gray-800 rounded-xl p-6 text-center">
            <span class="material-symbols-outlined text-2xl text-primary mb-2">groups</span>
            <div class="text-sm text-gray-400 mb-1">Limited spaces</div>
            <div class="text-lg font-bold text-primary">5 teams per division</div>
          </div>
          <div class="bg-[#262626] border border-gray-800 rounded-xl p-6 text-center">
            <span class="material-symbols-outlined text-2xl text-primary mb-2">schedule</span>
            <div class="text-sm text-gray-400 mb-1">Entry deadline</div>
            <div class="text-lg font-bold text-primary">13 April 2026</div>
          </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="SIGNUP_URL" class="px-8 py-4 rounded-full bg-primary text-white font-bold text-lg hover:bg-primary-hover transition-all duration-300 shadow-2xl shadow-primary/40 transform hover:-translate-y-1 text-center">
            Sign Up Now
          </a>
          <a href="/contact" class="px-8 py-4 rounded-full bg-transparent border-2 border-white/30 text-white font-bold text-lg hover:bg-white hover:text-black hover:border-white transition-all duration-300 text-center">
            Have A Question?
          </a>
        </div>

        <p class="text-sm text-gray-400 text-center mt-6">
          Fixtures and divisions will be confirmed after entries close.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="py-16 sm:py-24 bg-surface-dark">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-10">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-bold mb-6 text-white">Questions?</h2>
        <div class="w-24 h-1.5 bg-primary rounded-full mx-auto mb-8"></div>
      </div>

      <div class="bg-background-dark rounded-2xl p-8 border border-white/10 text-center">
        <p class="text-lg text-gray-300 mb-8">
          Message us and we'll help you enter a team or find a partner.
        </p>

        <div class="space-y-4">
          <div>
            <a href="mailto:ormeautt@live.co.uk" class="text-primary font-bold text-lg hover:underline">
              ormeautt@live.co.uk
            </a>
          </div>
        </div>

        <div class="mt-8">
          <a href="#register" class="px-8 py-4 rounded-full bg-primary text-white font-bold text-lg hover:bg-primary-hover transition-all duration-300 shadow-2xl shadow-primary/40 transform hover:-translate-y-1 inline-block">
            Back to Registration
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
