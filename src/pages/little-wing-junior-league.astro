---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Little Wing Junior League - Ormeau Table Tennis Club" description="Join the Little Wing Junior League at Ormeau Table Tennis Club. Junior team competition for ages 10-16, Sundays 2-4pm in Belfast.">
  <Header />
<script is:inline>
    (function() {
      const path = window.location.pathname;
      document.querySelectorAll('.nav-link').forEach(link => {
        const href = link.getAttribute('href');
        if ((path === '/' && href === '/') || href === path || href === path + '/') {
          link.classList.add('text-primary', 'dark:text-primary');
        }
      });
    })();
  </script>

  <div class="pb-[5.5rem] md:pb-0">
  <!-- Hero Section -->
  <section class="relative bg-background-dark text-white overflow-hidden">
    <div class="absolute inset-0 bg-black/40 z-10 md:bg-black/40"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-black/20 to-black/10 z-10 md:hidden"></div>
    <div class="relative z-20 max-w-7xl mx-auto px-6 sm:px-8 lg:px-10 pt-[200px] sm:pt-48 md:pt-64 pb-16 sm:pb-24 md:pb-32">
      <div class="max-w-4xl">
        <span class="inline-block py-1 px-4 rounded-full bg-primary/20 border border-primary/30 text-primary text-sm font-bold mb-6 uppercase tracking-widest">New Junior League</span>
        <h1 class="text-[2rem] sm:text-4xl md:text-6xl font-bold tracking-tight mb-6 sm:mb-8 leading-tight"> Little Wing <span class="text-primary">Junior League</span> </h1>
        <p class="text-base sm:text-lg md:text-xl text-gray-300 leading-relaxed font-light mb-4 sm:mb-5"> Little Wing Junior League — a new 4-week junior team competition for ages 10–16 at Ormeau Table Tennis Club. Enter with a partner or ask us to pair you up. Sunday afternoons, two ability divisions, and plenty of match play. </p>
        <p class="text-base sm:text-lg text-gray-200 leading-relaxed font-normal mb-8 sm:mb-10"> You can join with a partner, or contact us and we'll help pair you with another player. </p>
        
        <div class="grid sm:grid-cols-2 gap-4 mb-8 sm:mb-10">
          <div class="bg-[#262626] border border-gray-800 rounded-xl p-6">
            <div class="text-primary font-semibold mb-2">📅 Dates</div>
            <div class="text-gray-300">26 April • 10 May • 24 May • 7 June</div>
          </div>
          <div class="bg-[#262626] border border-gray-800 rounded-xl p-6">
            <div class="text-primary font-semibold mb-2">🏓 Format</div>
            <div class="text-gray-300">Davis Cup • 2 Singles + Doubles • Best of 3</div>
          </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-4">
          <a href="https://buy.stripe.com/00w28r2vW6q9eAP4L0gfu34" target="_blank" rel="noopener noreferrer" class="px-8 py-4 bg-primary text-white font-bold rounded-lg md:rounded-full hover:bg-primary-hover transition-colors shadow-lg shadow-primary/30 text-center">Register for the Junior League</a>
          <a href="/contact" class="px-8 py-4 bg-transparent border-2 border-white/30 text-white font-bold rounded-lg md:rounded-full hover:bg-white hover:text-black hover:border-white transition-all text-center">Ask a Question</a>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="py-14 md:py-24 bg-white dark:bg-background-dark">
    <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-10">
      <div class="text-center mb-10 md:mb-16">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold mb-4">What is the Little Wing Junior League?</h2>
        <div class="w-[60px] h-1 bg-primary mx-auto rounded-full"></div>
      </div>

      <div class="grid md:grid-cols-2 gap-10 md:gap-16 items-start">
        <div>
          <p class="text-gray-600 dark:text-gray-400 mb-6 leading-relaxed">
            A junior team league at Ormeau Table Tennis Club: four Sunday afternoons of match play, team experience, and a lively club atmosphere. Bring a partner or we'll help pair you—players from other clubs are welcome.
          </p>

          <h3 class="text-lg font-bold mb-3 text-primary">Why enter</h3>
          <ul class="space-y-2.5">
            <li class="flex items-start gap-3">
              <span class="material-symbols-outlined text-primary text-lg mt-0.5 shrink-0">check_circle</span>
              <span class="text-gray-600 dark:text-gray-400 text-[15px] sm:text-base">Team-based match practice</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="material-symbols-outlined text-primary text-lg mt-0.5 shrink-0">check_circle</span>
              <span class="text-gray-600 dark:text-gray-400 text-[15px] sm:text-base">Two ability divisions</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="material-symbols-outlined text-primary text-lg mt-0.5 shrink-0">check_circle</span>
              <span class="text-gray-600 dark:text-gray-400 text-[15px] sm:text-base">Represent your club</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="material-symbols-outlined text-primary text-lg mt-0.5 shrink-0">check_circle</span>
              <span class="text-gray-600 dark:text-gray-400 text-[15px] sm:text-base">Prizes for winners and runners-up</span>
            </li>
          </ul>
        </div>

        <div class="space-y-3">
          <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-1">League details</h3>
          <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-[#262626] p-4 sm:p-5 flex items-start gap-3 shadow-sm">
            <span class="material-symbols-outlined text-primary shrink-0">group</span>
            <div class="min-w-0">
              <div class="text-gray-900 dark:text-white font-semibold text-sm sm:text-base">Ages</div>
              <div class="text-gray-600 dark:text-gray-400 text-sm sm:text-base">10–16 years old</div>
            </div>
          </div>
          <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-[#262626] p-4 sm:p-5 flex items-start gap-3 shadow-sm">
            <span class="material-symbols-outlined text-primary shrink-0">sports_tennis</span>
            <div class="min-w-0">
              <div class="text-gray-900 dark:text-white font-semibold text-sm sm:text-base">Format</div>
              <div class="text-gray-600 dark:text-gray-400 text-sm sm:text-base">Davis Cup (2 singles + doubles)</div>
            </div>
          </div>
          <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-[#262626] p-4 sm:p-5 flex items-start gap-3 shadow-sm">
            <span class="material-symbols-outlined text-primary shrink-0">schedule</span>
            <div class="min-w-0">
              <div class="text-gray-900 dark:text-white font-semibold text-sm sm:text-base">Time</div>
              <div class="text-gray-600 dark:text-gray-400 text-sm sm:text-base">Sundays 2:00–4:00pm</div>
            </div>
          </div>
          <div class="rounded-xl border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-[#262626] p-4 sm:p-5 flex items-start gap-3 shadow-sm">
            <span class="material-symbols-outlined text-primary shrink-0">trophy</span>
            <div class="min-w-0">
              <div class="text-gray-900 dark:text-white font-semibold text-sm sm:text-base">Divisions</div>
              <div class="text-gray-600 dark:text-gray-400 text-sm sm:text-base">Two levels by ability</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Registration Section -->
  <section id="register" class="py-16 sm:py-24 bg-background-dark">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-10">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-bold mb-6 text-white">Register for the Junior League</h2>
        <div class="w-24 h-1.5 bg-primary rounded-full mx-auto mb-8"></div>
      </div>

      <div class="bg-surface-dark rounded-2xl p-8 border border-white/10">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
          <div class="bg-[#262626] border border-gray-800 rounded-xl p-6 text-center">
            <span class="material-symbols-outlined text-2xl text-primary mb-2">payments</span>
            <div class="text-sm text-gray-400 mb-1">Entry fee</div>
            <div class="text-lg font-bold text-primary">£40 per team<br><span class="text-sm text-gray-300">(£20 per player)</span></div>
          </div>
          <div class="bg-[#262626] border border-gray-800 rounded-xl p-6 text-center">
            <span class="material-symbols-outlined text-2xl text-primary mb-2">group</span>
            <div class="text-sm text-gray-400 mb-1">Ages</div>
            <div class="text-lg font-bold text-primary">10–16</div>
          </div>
          <div class="bg-[#262626] border border-gray-800 rounded-xl p-6 text-center">
            <span class="material-symbols-outlined text-2xl text-primary mb-2">groups</span>
            <div class="text-sm text-gray-400 mb-1">Limited spaces</div>
            <div class="text-lg font-bold text-primary">5 teams per division</div>
          </div>
        </div>

        <div class="mb-8 rounded-xl border border-white/10 bg-[#262626] p-6 sm:p-8 text-left">
          <h3 class="text-lg font-bold text-white mb-3">What happens next?</h3>
          <p class="text-gray-300 leading-relaxed">Once entries close, we'll finalise divisions, confirm fixtures, and contact all players.</p>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="https://buy.stripe.com/00w28r2vW6q9eAP4L0gfu34" target="_blank" rel="noopener noreferrer" class="px-8 py-4 rounded-full bg-primary text-white font-bold text-lg hover:bg-primary-hover transition-all duration-300 shadow-2xl shadow-primary/40 transform hover:-translate-y-1 text-center">
            Sign Up Now
          </a>
          <a href="/contact" class="px-8 py-4 rounded-full bg-transparent border-2 border-white/30 text-white font-bold text-lg hover:bg-white hover:text-black hover:border-white transition-all duration-300 text-center">
            Have A Question?
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="py-16 sm:py-24 bg-surface-dark">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-10">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-bold mb-6 text-white">Questions?</h2>
        <div class="w-24 h-1.5 bg-primary rounded-full mx-auto mb-8"></div>
      </div>

      <div class="bg-background-dark rounded-2xl p-8 border border-white/10 text-center">
        <p class="text-lg text-gray-300 mb-8">
          Message us and we'll help you register or find a partner.
        </p>

        <div class="space-y-4">
          <div>
            <a href="mailto:ormeautt@live.co.uk" class="text-primary font-bold text-lg hover:underline">
              ormeautt@live.co.uk
            </a>
          </div>
        </div>

        <div class="mt-8">
          <a href="#register" class="px-8 py-4 rounded-full bg-primary text-white font-bold text-lg hover:bg-primary-hover transition-all duration-300 shadow-2xl shadow-primary/40 transform hover:-translate-y-1 inline-block">
            Back to Registration
          </a>
        </div>
      </div>
    </div>
  </section>
  </div>

  <!-- Mobile sticky CTA -->
  <nav
    aria-label="Register for the Junior League"
    class="fixed bottom-0 left-0 right-0 z-50 md:hidden border-t border-white/10 bg-background-dark/95 backdrop-blur-md supports-[backdrop-filter]:bg-background-dark/80"
  >
    <div class="max-w-7xl mx-auto px-4 pt-3 pb-[max(0.75rem,env(safe-area-inset-bottom))]">
      <a
        href="https://buy.stripe.com/00w28r2vW6q9eAP4L0gfu34"
        target="_blank"
        rel="noopener noreferrer"
        class="flex w-full items-center justify-center rounded-full bg-primary px-4 py-3.5 text-center text-base font-bold text-white shadow-lg shadow-primary/25 hover:bg-primary-hover transition-colors"
      >
        Register for the Junior League
      </a>
    </div>
  </nav>

  <div class="pb-[5.5rem] md:pb-0">
    <Footer />
  </div>
</Layout>
