---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<style is:global>
  @media (max-width: 768px) {
    .legend-container {
      display: flex;
      flex-wrap: wrap;
      gap: 12px 20px;
      justify-content: center;
      padding: 16px;
    }
    .legend-item {
      font-size: 0.8rem;
    }
    .legend-item span:first-child {
      width: 10px;
      height: 10px;
      min-width: 10px;
    }
    .day-tabs {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      gap: 8px;
      padding: 0 16px 16px;
      -webkit-overflow-scrolling: touch;
      position: relative;
    }
    .day-tabs::after {
      content: '';
      position: absolute;
      right: 0;
      top: 0;
      bottom: 0;
      width: 40px;
      background: linear-gradient(to right, transparent, #1a1a1a 80%);
      pointer-events: none;
    }
    .day-tab {
      flex-shrink: 0;
      scroll-snap-align: start;
      min-width: auto;
      padding: 10px 20px;
      font-size: 0.85rem;
    }
    .session-card {
      border-radius: 12px;
      padding: 20px;
      border-left-width: 4px;
    }
    .session-card .card-status {
      position: absolute;
      top: 12px;
      right: 12px;
      font-size: 0.7rem;
      font-weight: 700;
      padding: 4px 12px;
      border-radius: 20px;
      text-transform: uppercase;
      background: #ef4444;
      color: white;
    }
    .session-card .card-status.status-available {
      background: #22c55e;
    }
    .session-card .card-status.status-invite {
      background: #eab308;
      color: #1f2937;
    }
    .session-card .card-status-bottom {
      display: none;
    }
    .hero-section {
      padding-top: 80px;
    }
    .hero-subtitle {
      margin-bottom: 24px;
    }
    .cta-section {
      padding: 48px 24px;
    }
    .cta-heading, .cta-subtext {
      margin-bottom: 24px;
    }
    .cta-button {
      padding: 16px 32px;
      font-size: 1.1rem;
      font-weight: 600;
    }
  }
</style>

<Layout title="Timetable - Ormeau Table Tennis Club" description="View Ormeau Table Tennis Club's weekly timetable.">
  <Header />
<script is:inline>
    (function() {
      const menuBtn = document.getElementById('mobile-menu-btn');
      const closeBtn = document.getElementById('mobile-menu-close');
      const mobileMenu = document.getElementById('mobile-menu');
      
      function toggleMenu() {
        if (mobileMenu.classList.contains('translate-x-full')) {
          mobileMenu.classList.remove('translate-x-full');
        } else {
          mobileMenu.classList.add('translate-x-full');
        }
      }
      
      if (menuBtn) {
        menuBtn.addEventListener('click', toggleMenu);
      }
      
      if (closeBtn) {
        closeBtn.addEventListener('click', function() {
          mobileMenu.classList.add('translate-x-full');
        });
      }
    })();
  </script><!-- Hero Section -->
  <section class="hero-section relative bg-background-dark text-white overflow-hidden">
    <div class="absolute inset-0 bg-black/70 z-10"></div>
    <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1534158914592-062992fbe900?ixlib=rb-1.2.1&auto=format&fit=crop&w=1950&q=80')] bg-cover bg-center z-0"></div>
    <div class="relative z-20 max-w-7xl mx-auto px-6 sm:px-8 lg:px-10 py-32 md:py-40">
      <div class="max-w-3xl">
        <h1 class="text-5xl md:text-7xl font-bold mb-6">Training <span class="text-primary">Timetable</span></h1>
        <p class="hero-subtitle text-xl text-gray-300">Find the perfect session for your skill level and schedule.</p>
