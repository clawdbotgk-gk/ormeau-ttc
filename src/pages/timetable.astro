  <Footer />

  <script is:inline>
    // Smart filter: Auto-select current day based on UK time
    function getCurrentDayUK() {
      const now = new Date();
      // Convert to UK time (GMT/BST)
      const ukTime = new Date(now.toLocaleString("en-US", {timeZone: "Europe/London"}));
      const days = ['sunday', 'monday', 'tuesday', 'wednesday', 'thursday', 'friday', 'saturday'];
      return days[ukTime.getDay()];
    }

    function setActiveDay(dayName) {
      document.querySelectorAll('.day-tab').forEach(t => {
        t.classList.remove('bg-primary', 'text-white', 'ring-4', 'ring-primary/30', 'shadow-xl', 'shadow-primary/40', 'scale-105');
        t.classList.add('bg-gray-200', 'dark:bg-gray-700', 'text-gray-700', 'dark:text-gray-300');
      });
      
      const activeTab = document.querySelector(`[data-day="${dayName}"]`);
      if (activeTab) {
        activeTab.classList.remove('bg-gray-200', 'dark:bg-gray-700', 'text-gray-700', 'dark:text-gray-300');
        activeTab.classList.add('bg-primary', 'text-white', 'ring-4', 'ring-primary/30', 'shadow-xl', 'shadow-primary/40', 'scale-105');
      }
      
      document.querySelectorAll('.timetable-day').forEach(t => t.classList.add('hidden'));
      const activeDay = document.getElementById(dayName);
      if (activeDay) {
        activeDay.classList.remove('hidden');
      }
    }

    // Initialize with current day
    const currentDay = getCurrentDayUK();
    setActiveDay(currentDay);

    // Add click handlers
    document.querySelectorAll('.day-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        const day = tab.dataset.day;
        setActiveDay(day);
      });
    });
  </script>
