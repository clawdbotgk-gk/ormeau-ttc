---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

const pageTitle = "Club Champions - Ormeau Table Tennis Club";
const pageDescription = "Celebrating the champions of Ormeau Table Tennis Club. Honoring individual and team achievements from our club's history.";
---

<Layout title={pageTitle} description={pageDescription}>
  <!-- Navigation -->
  <nav class="sticky top-0 z-50 bg-background-light/95 dark:bg-background-dark/95 backdrop-blur-md border-b border-gray-100 dark:border-gray-800" aria-label="Main navigation">
    <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-10">
      <div class="flex justify-between items-center h-28">
        <div class="flex-shrink-0 flex items-center group cursor-pointer gap-4">
          <div class="relative overflow-hidden rounded-xl shadow-sm transition-transform duration-300 group-hover:scale-105">
            <img alt="Ormeau Logo" class="h-14 w-auto block dark:hidden" src="https://ormeautabletennis.com/wp-content/uploads/2021/12/logoOrmeauInverse@2x-e1508851762736.png"/>
            <img alt="Ormeau Logo" class="h-14 w-auto hidden dark:block" src="https://ormeautabletennis.com/wp-content/uploads/2021/12/logoOrmeauInverse@2x-e1508851762736.png"/>
          </div>
        </div>
        <div class="hidden md:flex flex-1 justify-center space-x-12">
          <a class="text-gray-600 dark:text-gray-300 hover:text-primary dark:hover:text-primary font-medium text-lg transition-all duration-200 nav-link" href="/">Home</a>
          <a class="text-gray-600 dark:text-gray-300 hover:text-primary dark:hover:text-primary font-medium text-lg transition-all duration-200 nav-link" href="/about">About</a>
          <div class="relative group">
            <button type="button" class="text-gray-600 dark:text-gray-300 hover:text-primary dark:hover:text-primary font-medium text-lg transition-all duration-200 cursor-pointer flex items-center gap-1" aria-expanded="false" aria-haspopup="true" aria-label="Club menu">
              Club <span class="material-icons text-sm" aria-hidden="true">expand_more</span>
            </button>
            <div class="absolute left-0 top-full pt-2 hidden group-hover:block group-focus-within:block z-50">
              <div class="bg-white dark:bg-gray-800 rounded-lg shadow-xl py-2 min-w-40">
                <a class="block px-4 py-2 text-gray-700 dark:text-gray-200 hover:bg-primary/10 hover:text-primary" href="/timetable">Timetable</a>
                <a class="block px-4 py-2 text-gray-700 dark:text-gray-200 hover:bg-primary/10 hover:text-primary" href="/events">Events</a>
                <a class="block px-4 py-2 text-gray-700 dark:text-gray-200 hover:bg-primary/10 hover:text-primary" href="/teams">Teams</a>
                <a class="block px-4 py-2 text-gray-700 dark:text-gray-200 hover:bg-primary/10 hover:text-primary" href="/champions">Champions</a>
                <a class="block px-4 py-2 text-gray-700 dark:text-gray-200 hover:bg-primary/10 hover:text-primary" href="/partners">Partners</a>
              </div>
            </div>
          </div>
          <a class="text-gray-600 dark:text-gray-300 hover:text-primary dark:hover:text-primary font-medium text-lg transition-all duration-200 nav-link" href="/contact">Contact</a>
        </div>
        <div class="hidden md:flex items-center">
          <a class="px-8 py-3.5 rounded-full bg-primary text-white font-bold hover:bg-primary-hover transition-all duration-300 shadow-lg shadow-primary/25 hover:shadow-primary/40 transform hover:-translate-y-0.5 active:translate-y-0" href="/join">Join Now</a>
        </div>
        <div class="md:hidden flex items-center">
          <button id="mobile-menu-btn" class="md:hidden flex items-center text-gray-700 dark:text-gray-300 hover:text-primary focus:outline-none p-2">
            <span class="material-icons text-3xl" aria-hidden="true">menu</span>
          </button>
        </div>
      </div>
    </div>
  </nav>

  <!-- Mobile Menu Panel -->
  <div id="mobile-menu" class="fixed inset-0 z-40 bg-background-light dark:bg-background-dark transform translate-x-full transition-transform duration-300 md:hidden">
    <div class="flex flex-col h-full pt-20 px-6">
      <div class="flex justify-end mb-8">
        <button id="mobile-menu-close" class="p-2 text-gray-700 dark:text-gray-300">
          <span class="material-icons text-3xl">close</span>
        </button>
      </div>
      <nav class="sticky top-0 z-50 flex flex-col space-y-6 text-xl">
        <a href="/" class="text-gray-700 dark:text-gray-300 font-semibold hover:text-primary">Home</a>
        <a href="/about" class="text-gray-700 dark:text-gray-300 font-semibold hover:text-primary">About</a>
        <a href="/timetable" class="text-gray-700 dark:text-gray-300 font-semibold hover:text-primary">Timetable</a>
        <a href="/events" class="text-gray-700 dark:text-gray-300 font-semibold hover:text-primary">Events</a>
        <a href="/teams" class="text-gray-700 dark:text-gray-300 font-semibold hover:text-primary">Teams</a>
        <a href="/champions" class="text-gray-700 dark:text-gray-300 font-semibold hover:text-primary">Champions</a>
        <a href="/contact" class="text-gray-700 dark:text-gray-300 font-semibold hover:text-primary">Contact</a>
        <a href="/join" class="mt-4 px-6 py-3 bg-primary text-white font-bold text-center rounded-full hover:bg-primary-hover">Join Now</a>
      </nav>
    </div>
  </div>

  <script is:inline>
    (function() {
      const menuBtn = document.getElementById('mobile-menu-btn');
      const closeBtn = document.getElementById('mobile-menu-close');
      const mobileMenu = document.getElementById('mobile-menu');
      if (menuBtn) {
        menuBtn.addEventListener('click', function() { mobileMenu.classList.remove('translate-x-full'); });
      }
      if (closeBtn) {
        closeBtn.addEventListener('click', function() { mobileMenu.classList.add('translate-x-full'); });
      }
    })();
  </script>

  <script is:inline>
    (function() {
      const path = window.location.pathname;
      document.querySelectorAll('.nav-link').forEach(link => {
        const href = link.getAttribute('href');
        if ((path === '/' && href === '/') || href === path || href === path + '/') {
          link.classList.add('text-primary', 'dark:text-primary');
        }
      });
    })();
  </script>

  <!-- Hero Title Section -->
  <section class="py-20 bg-background-light dark:bg-background-dark">
    <div class="max-w-7xl mx-auto px-6 text-center">
      <h2 class="text-5xl md:text-7xl font-black mb-6 tracking-tight text-gray-900 dark:text-white">
        CLUB <span class="text-primary">CHAMPIONS</span>
      </h2>
      <p class="max-w-2xl mx-auto text-gray-600 dark:text-gray-400 text-lg leading-relaxed">
        Celebrating the spirit, dedication, and excellence of our athletes. A tribute to those who have etched their names into the history of Ormeau Table Tennis Club.
      </p>
    </div>
  </section>

  <!-- Split Lists Container -->
  <section class="py-12 bg-background-light dark:bg-background-dark">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <!-- Left Column: Club Singles Champions -->
        <section class="space-y-8">
          <div class="sticky top-28 bg-background-light dark:bg-background-dark py-4 z-10 border-b-2 border-primary/20 flex items-center justify-between">
            <h3 class="text-2xl font-extrabold flex items-center gap-3 text-gray-900 dark:text-white">
              <span class="material-icons text-primary">person</span> Club Singles Champions
            </h3>

          </div>
          <div class="space-y-4">
            <!-- 2025 Open Singles Winner -->
            <div class="group flex flex-col gap-4 p-4 rounded-xl hover:bg-white dark:hover:bg-gray-800 transition-all border border-transparent hover:border-primary/10">
              <div class="flex items-center gap-6">
                <div class="text-3xl font-light text-primary/30 group-hover:text-primary transition-colors">2025</div>
                <div class="flex-grow">
                  <h4 class="text-xl font-bold group-hover:text-primary transition-colors text-gray-900 dark:text-white">Adam Faulkner</h4>
                  <p class="text-sm text-gray-500 uppercase tracking-tighter">Open Singles Winner</p>
                </div>
                <span class="material-icons text-primary opacity-0 group-hover:opacity-100 transition-opacity">military_tech</span>
              </div>
              <p class="text-sm text-gray-600 dark:text-gray-300 pl-2">A key player in our Premier British League team, claimed the title after an unforgettable final against Conor Nugent. Conor led 10–7 in the fourth set, but Adam produced a remarkable comeback, eventually sealing the match in a dramatic fifth set.</p>
              <div class="relative h-[500px] w-full rounded-xl overflow-hidden shadow-lg">
                <img alt="2025 Open Singles Winner" class="w-full h-full object-cover" src="/adam-singles-winner.jpg"/>
              </div>
            </div>
            <!-- 2025 Masters 40s Winner -->
            <div class="group flex flex-col gap-4 p-4 rounded-xl hover:bg-white dark:hover:bg-gray-800 transition-all border border-transparent hover:border-primary/10">
              <div class="flex items-center gap-6">
                <div class="text-3xl font-light text-primary/30 group-hover:text-primary transition-colors">2025</div>
                <div class="flex-grow">
                  <h4 class="text-xl font-bold group-hover:text-primary transition-colors text-gray-900 dark:text-white">Brendan O'Fiaich</h4>
                  <p class="text-sm text-gray-500 uppercase tracking-tighter">Masters 40s Winner</p>
                </div>
                <span class=" opacity-0 groupmaterial-icons text-primary-hover:opacity-100 transition-opacity">military_tech</span>
              </div>
              <p class="text-sm text-gray-600 dark:text-gray-300 pl-2">Brendan O'Fiaich produced a dominant performance in the final, defeating Chris White 3–0 to lift the Masters 40s title.</p>
              <div class="relative h-[500px] w-full rounded-xl overflow-hidden shadow-lg">
                <img alt="2025 Masters 40s Winner" class="w-full h-full object-cover" src="/brendan-masters-winner.jpg"/>
              </div>
            </div>
            <!-- 2025 B' Singles Winner -->
            <div class="group flex flex-col gap-4 p-4 rounded-xl hover:bg-white dark:hover:bg-gray-800 transition-all border border-transparent hover:border-primary/10">
              <div class="flex items-center gap-6">
                <div class="text-3xl font-light text-primary/30 group-hover:text-primary transition-colors">2025</div>
                <div class="flex-grow">
                  <h4 class="text-xl font-bold group-hover:text-primary transition-colors text-gray-900 dark:text-white">Daniel Flanagan</h4>
                  <p class="text-sm text-gray-500 uppercase tracking-tighter">B' Singles Winner</p>
                </div>
                <span class="material-icons text-primary opacity-0 group-hover:opacity-100 transition-opacity">military_tech</span>
              </div>
              <p class="text-sm text-gray-600 dark:text-gray-300 pl-2">Daniel Flanagan capped off a strong campaign with a convincing 3–0 win over Chris White in the final.</p>
              <div class="relative h-[500px] w-full rounded-xl overflow-hidden shadow-lg">
                <img alt="2025 B' Singles Winner" class="w-full h-full object-cover" src="/daniel-singles-winner.jpg"/>
              </div>
            </div>
            <!-- 2025 Under 19s Mixed Singles Winner -->
            <div class="group flex flex-col gap-4 p-4 rounded-xl hover:bg-white dark:hover:bg-gray-800 transition-all border border-transparent hover:border-primary/10">
              <div class="flex items-center gap-6">
                <div class="text-3xl font-light text-primary/30 group-hover:text-primary transition-colors">2025</div>
                <div class="flex-grow">
                  <h4 class="text-xl font-bold group-hover:text-primary transition-colors text-gray-900 dark:text-white">Alex Lo</h4>
                  <p class="text-sm text-gray-500 uppercase tracking-tighter">Under 19s Mixed Singles Winner</p>
                </div>
                <span class="material-icons text-primary opacity-0 group-hover:opacity-100 transition-opacity">military_tech</span>
              </div>
              <p class="text-sm text-gray-600 dark:text-gray-300 pl-2">Alex Lo claimed the Under 19s title with a 3–1 victory over Christopher Allsop in the final.</p>
              <div class="relative h-80 w-full rounded-xl overflow-hidden shadow-lg">
                <img alt="2025 Under 19s Winner" class="w-full h-full object-cover" src="/alex-u19-winner.jpg"/>
              </div>
            </div>
          </div>
        </section>

        <!-- Right Column: Club Team Champions -->
        <section class="space-y-8">
          <div class="sticky top-28 bg-background-light dark:bg-background-dark py-4 z-10 border-b-2 border-primary/20 flex items-center justify-between">
            <h3 class="text-2xl font-extrabold flex items-center gap-3 text-gray-900 dark:text-white">
              <span class="material-icons text-primary">groups</span> Club Team Champions
            </h3>

          </div>
          <div class="space-y-4">
            <!-- 2025 Open Team Winners -->
            <div class="group flex flex-col gap-4 p-4 rounded-xl hover:bg-white dark:hover:bg-gray-800 transition-all border border-transparent hover:border-primary/10">
              <div class="flex items-center gap-6">
                <div class="text-3xl font-light text-primary/30 group-hover:text-primary transition-colors">2025</div>
                <div class="flex-grow">
                  <h4 class="text-xl font-bold group-hover:text-primary transition-colors text-gray-900 dark:text-white">Conor Nugent's Sharks</h4>
                  <p class="text-sm text-gray-500 uppercase tracking-tighter">Open Team Winners</p>
                </div>
                <span class="material-icons text-primary opacity-0 group-hover:opacity-100 transition-opacity">military_tech</span>
              </div>
              <p class="text-sm text-gray-600 dark:text-gray-300 pl-2">Conor Nugent's Sharks edged out Toby Caldwell's Warriors 3-2 in a stunning final that went all the way to the deciding doubles. Conor and Rebecca clinched it 11-9 in the fifth against Toby and Harsha in front of a packed and cheering crowd. Huge congrats to Conor, Rebecca, and Matthew on taking the title, and well played to runners-up Toby, Harsha, and Alex.</p>
              <div class="relative h-80 w-full rounded-xl overflow-hidden shadow-lg">
                <img alt="2025 Team Winners" class="w-full h-full object-cover" src="/team-winners-2025.jpg"/>
              </div>
            </div>
            <!-- 2025 Junior Team Winners -->
            <div class="group flex flex-col gap-4 p-4 rounded-xl hover:bg-white dark:hover:bg-gray-800 transition-all border border-transparent hover:border-primary/10">
              <div class="flex items-center gap-6">
                <div class="text-3xl font-light text-primary/30 group-hover:text-primary transition-colors">2025</div>
                <div class="flex-grow">
                  <h4 class="text-xl font-bold group-hover:text-primary transition-colors text-gray-900 dark:text-white">Grace Looney's Spartans</h4>
                  <p class="text-sm text-gray-500 uppercase tracking-tighter">Junior Team Winners</p>
                </div>
                <span class="material-icons text-primary opacity-0 group-hover:opacity-100 transition-opacity">military_tech</span>
              </div>
              <p class="text-sm text-gray-600 dark:text-gray-300 pl-2">Grace Looney's Spartans took home the title with a 4-1 victory over Niamh Mason's Raptors. Jack starred for the Spartans, winning all three of his matches (one singles, two doubles). A special mention goes to Yara, who competed for the Raptors as one of the youngest players in the tournament at just 9 years old! Hats off to Spartans teammates Grace, Jack, and James, and well done to Neve, Rafferty, and Yara from the Raptors.</p>
              <div class="relative h-80 w-full rounded-xl overflow-hidden shadow-lg">
                <img alt="2025 Junior Team Winners" class="w-full h-full object-cover" src="/grace-team-winners.jpg"/>
              </div>
            </div>
            <!-- 2025 Senior Team Winners -->
            <div class="group flex flex-col gap-4 p-4 rounded-xl hover:bg-white dark:hover:bg-gray-800 transition-all border border-transparent hover:border-primary/10">
              <div class="flex items-center gap-6">
                <div class="text-3xl font-light text-primary/30 group-hover:text-primary transition-colors">2025</div>
                <div class="flex-grow">
                  <h4 class="text-xl font-bold group-hover:text-primary transition-colors text-gray-900 dark:text-white">Jeff Harrison's Falcons</h4>
                  <p class="text-sm text-gray-500 uppercase tracking-tighter">Senior Team Winners</p>
                </div>
                <span class="material-icons text-primary opacity-0 group-hover:opacity-100 transition-opacity">military_tech</span>
              </div>
              <p class="text-sm text-gray-600 dark:text-gray-300 pl-2">Jeff Harrison's Falcons claimed the title with a 3-2 win over the Avengers. With Avengers captain Brendan Popplestone unavailable for the final, Chris White stepped in to help take it to the wire. Congratulations to Jeff, Pawel, and Bei on the win—and well done to Brendan, Chris, Jennifer, and Voon for a brilliant run to the final.</p>
              <div class="relative h-80 w-full rounded-xl overflow-hidden shadow-lg">
                <img alt="2025 Senior Team Winners" class="w-full h-full object-cover" src="/jeff-team-winners.jpg"/>
              </div>
            </div>
          </div>
        </section>
      </div>

      <!-- Hall of Fame Callout -->
      <div class="mt-24 p-12 rounded-3xl bg-primary/5 border border-primary/20 flex flex-col md:flex-row items-center gap-10">
        <div class="flex-grow">
          <h4 class="text-3xl font-bold mb-4 text-gray-900 dark:text-white">Want to see the full historical archives?</h4>
          <p class="text-gray-600 dark:text-gray-400">Our records date back to 1985. Discover the legends who built our club from the ground up.</p>
        </div>
        <button class="bg-primary text-white px-8 py-4 rounded-xl text-lg font-bold hover:bg-primary-hover transition-colors whitespace-nowrap">Explore Full History</button>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
