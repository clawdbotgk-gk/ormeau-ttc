---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pageTitle = "Club Champions - Ormeau Table Tennis Club";
const pageDescription = "Celebrating the champions of Ormeau Table Tennis Club. Honoring individual and team achievements from our club's history.";
---

<Layout title={pageTitle} description={pageDescription}>
  <Header />

  <!-- Hero Title Section -->
  <section class="pt-[40px] pb-6 xs:pb-[24px] bg-[#1a1a1a]">
    <div class="max-w-7xl mx-auto px-6 text-center">
      <h2 class="text-3xl xs:text-[32px] md:text-7xl font-black mb-4 xs:mb-6 tracking-tight text-gray-900 dark:text-white">
        <span class="xs:text-[32px]">CLUB</span> <span class="text-primary xs:text-[36px]">CHAMPIONS</span>
      </h2>
      <p class="max-w-2xl mx-auto text-gray-600 dark:text-gray-400 text-sm xs:text-base leading-normal xs:leading-relaxed px-5 xs:px-0">
        Celebrating the spirit, dedication, and excellence of our athletes. A tribute to those who have etched their names into the history of Ormeau Table Tennis Club.
      </p>
    </div>
  </section>

  <!-- Split Lists Container -->
  <section class="py-12 bg-background-light dark:bg-background-dark">
    <div class="max-w-7xl mx-auto px-2 sm:px-4 md:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-start">
        <!-- Left Column: Club Singles Champions -->
        <section class="space-y-8">
          <div class="bg-[#1a1a1a] py-4 border-b-2 border-primary/20 flex flex-col items-center">
            <h3 class="text-2xl xs:text-[20px] font-extrabold xs:font-bold flex items-center gap-3 text-gray-900 dark:text-white xs:mb-6 text-center">
              <span class="material-icons text-primary">person</span> Club Singles Champions
            </h3>

          </div>
          <div class="space-y-4">
            <!-- 2025 Open Singles Winner -->
            <div class="group flex flex-col gap-4 p-4 rounded-xl hover:bg-white dark:hover:bg-gray-800 transition-all border border-transparent hover:border-primary/10 md:bg-white/3 md:rounded-[12px] md:p-5 md:px-4 md:mb-5">
              <div class="flex xs:flex-col items-center xs:items-start gap-2 xs:gap-6">
                <div class="text-sm xs:text-3xl font-bold text-[#ff3366] xs:font-light xs:text-primary/30 xs:group-hover:text-primary transition-all tracking-[1px] xs:tracking-normal mb-1 xs:mb-0">2025</div>
                <div class="flex-grow text-center xs:text-left">
                  <h4 class="text-base xs:text-xl font-bold group-hover:text-primary transition-colors text-gray-900 dark:text-white">Adam Faulkner</h4>
                  <p class="text-[11px] xs:text-sm text-gray-500 dark:text-white/50 uppercase tracking-[1.5px] xs:tracking-tighter">Open Singles Winner</p>
                </div>
                <span class="material-icons text-primary opacity-0 group-hover:opacity-100 transition-opacity">military_tech</span>
              </div>
              <p class="text-sm xs:text-[14px] text-gray-600 dark:text-gray-300 xs:text-white/75 xs:leading-[1.6] xs:my-3 xs:my-4 xs:p-0 pl-2">A key player in our Premier British League team, claimed the title after an unforgettable final against Conor Nugent. Conor led 10–7 in the fourth set, but Adam produced a remarkable comeback, eventually sealing the match in a dramatic fifth set.</p>
              <div class="relative h-[500px] xs:max-h-[280px] xs:overflow-hidden xs:rounded-[12px] xs:mt-4 xs:mb-8 w-full rounded-xl overflow-hidden shadow-lg">
                <img alt="2025 Open Singles Winner" class="w-full h-full xs:aspect-[4/3] xs:object-cover object-cover" src="/adam-singles-winner.jpg"/>
              </div>
            </div>
            <!-- 2025 Masters 40s Winner -->
            <div class="group flex flex-col gap-4 p-4 rounded-xl hover:bg-white dark:hover:bg-gray-800 transition-all border border-transparent hover:border-primary/10 md:bg-white/3 md:rounded-[12px] md:p-5 md:px-4 md:mb-5">
              <div class="flex xs:flex-col items-center xs:items-start gap-2 xs:gap-6">
                <div class="text-sm xs:text-3xl font-bold text-[#ff3366] xs:font-light xs:text-primary/30 xs:group-hover:text-primary transition-all tracking-[1px] xs:tracking-normal mb-1 xs:mb-0">2025</div>
                <div class="flex-grow text-center">
                  <h4 class="text-base xs:text-xl font-bold group-hover:text-primary transition-colors text-gray-900 dark:text-white">Brendan O'Fiaich</h4>
                  <p class="text-[11px] xs:text-sm text-gray-500 dark:text-white/50 uppercase tracking-[1.5px] xs:tracking-tighter">Masters 40s Winner</p>
                </div>
                <span class="opacity-0 group-hover:opacity-100 material-icons text-primary transition-opacity">military_tech</span>
              </div>
              <p class="text-sm xs:text-[14px] text-gray-600 dark:text-gray-300 xs:text-white/75 xs:leading-[1.6] xs:my-3 xs:my-4 xs:p-0 pl-2">Brendan O'Fiaich produced a dominant performance in the final, defeating Chris White 3–0 to lift the Masters 40s title.</p>
              <div class="relative h-[500px] xs:max-h-[280px] xs:overflow-hidden xs:rounded-[12px] xs:mt-4 xs:mb-8 w-full rounded-xl overflow-hidden shadow-lg">
                <img alt="2025 Masters 40s Winner" class="w-full h-full xs:aspect-[4/3] xs:object-cover object-cover" src="/brendan-masters-winner.jpg"/>
              </div>
            </div>
            <!-- 2025 B' Singles Winner -->
            <div class="group flex flex-col gap-4 p-4 rounded-xl hover:bg-white dark:hover:bg-gray-800 transition-all border border-transparent hover:border-primary/10 md:bg-white/3 md:rounded-[12px] md:p-5 md:px-4 md:mb-5">
              <div class="flex xs:flex-col items-center xs:items-start gap-2 xs:gap-6">
                <div class="text-sm xs:text-3xl font-bold text-[#ff3366] xs:font-light xs:text-primary/30 xs:group-hover:text-primary transition-all tracking-[1px] xs:tracking-normal mb-1 xs:mb-0">2025</div>
                <div class="flex-grow text-center xs:text-left">
                  <h4 class="text-base xs:text-xl font-bold group-hover:text-primary transition-colors text-gray-900 dark:text-white">Daniel Flanagan</h4>
                  <p class="text-[11px] xs:text-sm text-gray-500 dark:text-white/50 uppercase tracking-[1.5px] xs:tracking-tighter">B' Singles Winner</p>
                </div>
                <span class="material-icons text-primary opacity-0 group-hover:opacity-100 transition-opacity">military_tech</span>
              </div>
              <p class="text-sm xs:text-[14px] text-gray-600 dark:text-gray-300 xs:text-white/75 xs:leading-[1.6] xs:my-3 xs:my-4 xs:p-0 pl-2">Daniel Flanagan capped off a strong campaign with a convincing 3–0 win over Chris White in the final.</p>
              <div class="relative h-[500px] xs:max-h-[280px] xs:overflow-hidden xs:rounded-[12px] xs:mt-4 xs:mb-8 w-full rounded-xl overflow-hidden shadow-lg">
                <img alt="2025 B' Singles Winner" class="w-full h-full xs:aspect-[4/3] xs:object-cover object-cover" src="/daniel-singles-winner.jpg"/>
              </div>
            </div>
            <!-- 2025 Under 19s Mixed Singles Winner -->
            <div class="group flex flex-col gap-4 p-4 rounded-xl hover:bg-white dark:hover:bg-gray-800 transition-all border border-transparent hover:border-primary/10 md:bg-white/3 md:rounded-[12px] md:p-5 md:px-4 md:mb-5">
              <div class="flex xs:flex-col items-center xs:items-start gap-2 xs:gap-6">
                <div class="text-sm xs:text-3xl font-bold text-[#ff3366] xs:font-light xs:text-primary/30 xs:group-hover:text-primary transition-all tracking-[1px] xs:tracking-normal mb-1 xs:mb-0">2025</div>
                <div class="flex-grow text-center xs:text-left">
                  <h4 class="text-base xs:text-xl font-bold group-hover:text-primary transition-colors text-gray-900 dark:text-white">Alex Lo</h4>
                  <p class="text-[11px] xs:text-sm text-gray-500 dark:text-white/50 uppercase tracking-[1.5px] xs:tracking-tighter">Under 19s Mixed Singles Winner</p>
                </div>
                <span class="material-icons text-primary opacity-0 group-hover:opacity-100 transition-opacity">military_tech</span>
              </div>
              <p class="text-sm xs:text-[14px] text-gray-600 dark:text-gray-300 xs:text-white/75 xs:leading-[1.6] xs:my-3 xs:my-4 xs:p-0 pl-2">Alex Lo claimed the Under 19s title with a 3–1 victory over Christopher Allsop in the final.</p>
              <div class="relative h-80 xs:max-h-[280px] xs:overflow-hidden xs:rounded-[12px] xs:mt-4 xs:mb-8 w-full rounded-xl overflow-hidden shadow-lg">
                <img alt="2025 Under 19s Winner" class="w-full h-full xs:aspect-[4/3] xs:object-cover object-cover" src="/alex-u19-winner.jpg"/>
              </div>
            </div>
          </div>
        </section>

        <!-- Right Column: Club Team Champions -->
        <section class="space-y-8 md:border-t md:border-white/10 md:pt-8 md:mt-10">
          <div class="bg-[#1a1a1a] py-4 border-b-2 border-primary/20 flex flex-col items-center">
            <h3 class="text-2xl xs:text-[20px] font-extrabold xs:font-bold flex items-center gap-3 text-gray-900 dark:text-white xs:mb-6 text-center">
              <span class="material-icons text-primary">groups</span> Club Team Champions
            </h3>

          </div>
          <div class="space-y-4">
            <!-- 2025 Open Team Winners -->
            <div class="group flex flex-col gap-4 p-4 rounded-xl hover:bg-white dark:hover:bg-gray-800 transition-all border border-transparent hover:border-primary/10 md:bg-white/3 md:rounded-[12px] md:p-5 md:px-4 md:mb-5">
              <div class="flex xs:flex-col items-center xs:items-start gap-2 xs:gap-6">
                <div class="text-sm xs:text-3xl font-bold text-[#ff3366] xs:font-light xs:text-primary/30 xs:group-hover:text-primary transition-all tracking-[1px] xs:tracking-normal mb-1 xs:mb-0">2025</div>
                <div class="flex-grow text-center xs:text-left">
                  <h4 class="text-base xs:text-xl font-bold group-hover:text-primary transition-colors text-gray-900 dark:text-white">Conor Nugent's Sharks</h4>
                  <p class="text-[11px] xs:text-sm text-gray-500 dark:text-white/50 uppercase tracking-[1.5px] xs:tracking-tighter">Open Team Winners</p>
                </div>
                <span class="material-icons text-primary opacity-0 group-hover:opacity-100 transition-opacity">military_tech</span>
              </div>
              <p class="text-sm xs:text-[14px] text-gray-600 dark:text-gray-300 xs:text-white/75 xs:leading-[1.6] xs:my-3 xs:my-4 xs:p-0 pl-2">Conor Nugent's Sharks edged out Toby Caldwell's Warriors 3-2 in a stunning final that went all the way to the deciding doubles. Conor and Rebecca clinched it 11-9 in the fifth against Toby and Harsha in front of a packed and cheering crowd. Huge congrats to Conor, Rebecca, and Matthew on taking the title, and well played to runners-up Toby, Harsha, and Alex.</p>
              <div class="relative h-80 xs:max-h-[280px] xs:overflow-hidden xs:rounded-[12px] xs:mt-4 xs:mb-8 w-full rounded-xl overflow-hidden shadow-lg">
                <img alt="2025 Team Winners" class="w-full h-full xs:aspect-[4/3] xs:object-cover object-cover" src="/team-winners-2025.jpg"/>
              </div>
            </div>
            <!-- 2025 Junior Team Winners -->
            <div class="group flex flex-col gap-4 p-4 rounded-xl hover:bg-white dark:hover:bg-gray-800 transition-all border border-transparent hover:border-primary/10 md:bg-white/3 md:rounded-[12px] md:p-5 md:px-4 md:mb-5">
              <div class="flex xs:flex-col items-center xs:items-start gap-2 xs:gap-6">
                <div class="text-sm xs:text-3xl font-bold text-[#ff3366] xs:font-light xs:text-primary/30 xs:group-hover:text-primary transition-all tracking-[1px] xs:tracking-normal mb-1 xs:mb-0">2025</div>
                <div class="flex-grow text-center xs:text-left">
                  <h4 class="text-base xs:text-xl font-bold group-hover:text-primary transition-colors text-gray-900 dark:text-white">Grace Looney's Spartans</h4>
                  <p class="text-[11px] xs:text-sm text-gray-500 dark:text-white/50 uppercase tracking-[1.5px] xs:tracking-tighter">Junior Team Winners</p>
                </div>
                <span class="material-icons text-primary opacity-0 group-hover:opacity-100 transition-opacity">military_tech</span>
              </div>
              <p class="text-sm xs:text-[14px] text-gray-600 dark:text-gray-300 xs:text-white/75 xs:leading-[1.6] xs:my-3 xs:my-4 xs:p-0 pl-2">Grace Looney's Spartans took home the title with a 4-1 victory over Niamh Mason's Raptors. Jack starred for the Spartans, winning all three of his matches (one singles, two doubles). A special mention goes to Yara, who competed for the Raptors as one of the youngest players in the tournament at just 9 years old! Hats off to Spartans teammates Grace, Jack, and James, and well done to Neve, Rafferty, and Yara from the Raptors.</p>
              <div class="relative h-80 xs:max-h-[280px] xs:overflow-hidden xs:rounded-[12px] xs:mt-4 xs:mb-8 w-full rounded-xl overflow-hidden shadow-lg">
                <img alt="2025 Junior Team Winners" class="w-full h-full xs:aspect-[4/3] xs:object-cover object-cover" src="/grace-team-winners.jpg"/>
              </div>
            </div>
            <!-- 2025 Senior Team Winners -->
            <div class="group flex flex-col gap-4 p-4 rounded-xl hover:bg-white dark:hover:bg-gray-800 transition-all border border-transparent hover:border-primary/10 md:bg-white/3 md:rounded-[12px] md:p-5 md:px-4 md:mb-5">
              <div class="flex xs:flex-col items-center xs:items-start gap-2 xs:gap-6">
                <div class="text-sm xs:text-3xl font-bold text-[#ff3366] xs:font-light xs:text-primary/30 xs:group-hover:text-primary transition-all tracking-[1px] xs:tracking-normal mb-1 xs:mb-0">2025</div>
                <div class="flex-grow text-center xs:text-left">
                  <h4 class="text-base xs:text-xl font-bold group-hover:text-primary transition-colors text-gray-900 dark:text-white">Jeff Harrison's Falcons</h4>
                  <p class="text-[11px] xs:text-sm text-gray-500 dark:text-white/50 uppercase tracking-[1.5px] xs:tracking-tighter">Senior Team Winners</p>
                </div>
                <span class="material-icons text-primary opacity-0 group-hover:opacity-100 transition-opacity">military_tech</span>
              </div>
              <p class="text-sm xs:text-[14px] text-gray-600 dark:text-gray-300 xs:text-white/75 xs:leading-[1.6] xs:my-3 xs:my-4 xs:p-0 pl-2">Jeff Harrison's Falcons claimed the title with a 3-2 win over the Avengers. With Avengers captain Brendan Popplestone unavailable for the final, Chris White stepped in to help take it to the wire. Congratulations to Jeff, Pawel, and Bei on the win—and well done to Brendan, Chris, Jennifer, and Voon for a brilliant run to the final.</p>
              <div class="relative h-80 xs:max-h-[280px] xs:overflow-hidden xs:rounded-[12px] xs:mt-4 xs:mb-8 w-full rounded-xl overflow-hidden shadow-lg">
                <img alt="2025 Senior Team Winners" class="w-full h-full xs:aspect-[4/3] xs:object-cover object-cover" src="/jeff-team-winners.jpg"/>
              </div>
            </div>
          </div>
        </section>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
