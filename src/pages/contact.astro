---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
// Cognito Forms embed
---

<Layout title="Contact Us - Ormeau Table Tennis Club" description="Get in touch with Ormeau Table Tennis Club. Contact us for membership inquiries, coaching sessions, and general enquiries at 113 The Mount, Belfast.">
  <Header />
<script is:inline>
    (function() {
      const path = window.location.pathname;
      document.querySelectorAll('.nav-link').forEach(link => {
        const href = link.getAttribute('href');
        if ((path === '/' && href === '/') || href === path || href === path + '/') {
          link.classList.add('text-primary', 'dark:text-primary');
        }
      });
    })();
  </script><!-- Hero Section -->
  <section class="relative bg-background-dark text-white overflow-hidden min-h-[60vh] flex items-center justify-center">
    <div class="absolute inset-0 bg-black/50 z-10"></div>
    <div class="absolute inset-0 bg-[url('/corporate-league.jpg')] bg-cover bg-top md:bg-center z-0"></div>
    <div class="relative z-20 max-w-4xl mx-auto px-6 sm:px-8 lg:px-10 py-32 flex flex-col items-center text-center">
      <span class="inline-block py-2 px-6 rounded-full bg-primary/20 border border-primary/40 backdrop-blur-md text-sm font-bold mb-8 uppercase tracking-[0.3em] text-primary">Get In Touch</span>
      <h1 class="text-6xl md:text-8xl font-bold tracking-tight mb-8 leading-tight"> Connect With <span class="text-primary">Us</span> </h1>
      <p class="text-xl md:text-2xl text-gray-200 max-w-2xl mb-12 font-light leading-relaxed"> Have a question about membership, coaching, or club activities? We'd love to hear from you. Get in touch today. </p>
      <div class="flex flex-col items-center w-full max-w-sm gap-4">
        <a href="#contact-form" class="animate-bounce mt-8">
          <span class="material-icons text-3xl md:text-4xl text-white/70 hover:text-white">keyboard_double_arrow_down</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Contact Form -->
  <section class="py-24 bg-white dark:bg-background-dark" id="contact-form">
    <div class="max-w-4xl mx-auto px-6 sm:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold mb-4">Send us a Message</h2>
        <p class="text-gray-500 dark:text-gray-400">We'll get back to you as soon as possible.</p>
      </div>
      
      <form name="contact" method="POST" data-netlify="true" class="space-y-6" id="contact-form">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6">
          <!-- First Name -->
          <div>
            <label for="first-name" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">First Name</label>
            <input type="text" id="first-name" name="first-name" required
              class="w-full px-4 py-[14px] rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-transparent transition text-base" />
          </div>
          <!-- Last Name -->
          <div>
            <label for="last-name" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Last Name</label>
            <input type="text" id="last-name" name="last-name" required
              class="w-full px-4 py-[14px] rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-transparent transition text-base" />
          </div>
        </div>
        
        <div>
          <label for="email" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Email Address</label>
          <input type="email" id="email" name="email" required
            class="w-full px-4 py-[14px] rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-transparent transition text-base" />
        </div>
        
        <div>
          <label for="phone" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Phone Number</label>
          <input type="tel" id="phone" name="phone"
            class="w-full px-4 py-[14px] rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-transparent transition text-base" />
        </div>
        
        <!-- Enquiring For - Card-style radio buttons -->
        <fieldset class="space-y-3">
          <legend class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Are you enquiring for yourself?</legend>
          <div class="flex flex-col sm:flex-row gap-3">
            <label class="flex-1 cursor-pointer">
              <input type="radio" name="enquiring_for_self" value="yes" required class="peer sr-only" />
              <div class="px-5 py-3 rounded-lg border-2 border-gray-300 dark:border-gray-600 text-center text-gray-700 dark:text-gray-300 peer-checked:border-primary peer-checked:text-primary font-medium transition-all hover:border-gray-400">
                Yes, for me
              </div>
            </label>
            <label class="flex-1 cursor-pointer">
              <input type="radio" name="enquiring_for_self" value="no" class="peer sr-only" />
              <div class="px-5 py-3 rounded-lg border-2 border-gray-300 dark:border-gray-600 text-center text-gray-700 dark:text-gray-300 peer-checked:border-primary peer-checked:text-primary font-medium transition-all hover:border-gray-400">
                No, for someone else
              </div>
            </label>
          </div>
        </fieldset>
        
        <!-- Table Tennis Level Dropdown -->
        <div class="relative">
          <label for="table-tennis-level" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Describe Level of Table Tennis</label>
          <select id="table-tennis-level" name="table-tennis-level"
            class="w-full px-4 py-[14px] rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-transparent transition appearance-none text-base pr-10">
            <option value="">Select your level</option>
            <option value="beginner">Beginner</option>
            <option value="intermediate">Intermediate</option>
            <option value="advanced">Advanced</option>
            <option value="elite">Elite / Competitive</option>
            <option value="junior">Junior / Youth</option>
            <option value="coaching">Coaching Inquiry</option>
            <option value="other">Other</option>
          </select>
          <span class="material-icons absolute right-3 top-[38px] text-gray-400 pointer-events-none">expand_more</span>
        </div>
        
        <div>
          <label for="message" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Message</label>
          <textarea id="message" name="message" rows="5"
            class="w-full px-4 py-[14px] rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary focus:border-transparent transition text-base"
            placeholder="How can we help you?"></textarea>
        </div>
        
        <button type="submit" class="w-full px-6 py-4 rounded-lg bg-primary text-white font-semibold hover:bg-primary-hover transition-all duration-300 shadow-lg shadow-primary/25 hover:shadow-primary/40 flex items-center justify-center gap-2">
          <span>Send Message</span>
          <span class="material-icons animate-spin hidden">sync</span>
        </button>
      </form>
    </div>
  </section>

  <!-- Location Section -->
  <section class="py-16 md:py-24 bg-[#262626]" id="location">
    <div class="max-w-7xl mx-auto px-0 md:px-6 sm:px-8 lg:px-10">
      <div class="grid md:grid-cols-2 gap-12 md:gap-16">
        <div class="flex flex-col text-center md:text-left">
          <span class="text-primary font-bold tracking-widest uppercase text-sm mb-4 px-4 md:px-0">Find Us</span>
          <h3 class="text-2xl md:text-3xl font-bold mb-6 px-4 md:px-0">Our Belfast Facility</h3>
          <div class="bg-gray-200 dark:bg-gray-800 overflow-hidden mb-6 md:mb-8 shadow-inner rounded-2xl" style="height: 300px;">
            <iframe 
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2304.246704158926!2d-5.951917923428!3d54.5917474729791!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x486108d6eb2f83df%3A0x6b12cc703e83336c!2s113%20The%20Mount%2C%20Belfast%20BT5%204ND!5e0!3m2!1sen!2suk!4v1700000000000!5m2!1sen!2suk" 
              width="100%" 
              height="100%" 
              style="border:0;" 
              allowfullscreen="" 
              loading="lazy" 
              referrerpolicy="no-referrer-when-downgrade">
            </iframe>
          </div>
          <div class="flex flex-col items-center md:items-start gap-4 px-4 md:px-0">
            <div class="w-12 h-12 rounded-2xl bg-primary/10 flex items-center justify-center text-primary shrink-0">
              <span class="material-icons">place</span>
            </div>
            <div class="text-center md:text-left">
              <p class="text-xl font-bold text-gray-900 dark:text-white">113 The Mount</p>
              <p class="text-gray-600 dark:text-gray-400">Belfast, BT5 4ND, United Kingdom</p>
            </div>
          </div>
        </div>
        <div class="flex flex-col px-4 md:px-0 text-center md:text-left">
          <span class="text-primary font-bold tracking-widest uppercase text-sm mb-4">Email Us</span>
          <h3 class="text-2xl md:text-3xl font-bold mb-6">General Inquiries</h3>
          <p class="text-lg text-gray-600 dark:text-gray-400 mb-6 md:mb-8 leading-relaxed"> Have a specific question about memberships, elite coaching, or our school programs? Drop us an email and our team will get back to you. </p>
          <a href="mailto:ormeautt@live.co.uk" class="flex items-center justify-center gap-3 w-full px-4 py-4 rounded-lg bg-white/5 border border-white/10 hover:bg-white/10 transition-colors">
            <span class="material-icons text-primary">mail</span>
            <span class="text-primary font-semibold">ormeautt@live.co.uk</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
