            <p class="text-sm leading-relaxed text-gray-600 dark:text-gray-400">Experienced defensive player who has played for Ulster.</p>
          </div>
        </div>

        <!-- Christopher Allsop -->
        <div class="group relative flex flex-col overflow-hidden rounded-2xl bg-white shadow-md transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl hover:ring-2 hover:ring-primary dark:bg-gray-800/80 border border-gray-100 dark:border-gray-700">
          <div class="aspect-[4/5] w-full overflow-hidden bg-gray-100 dark:bg-gray-800 relative">
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent z-10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <img alt="Christopher Allsop" class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110" src="https://xkwg7luliofrc1cs.public.blob.vercel-storage.com/Images/christopher.jpg"/>
          </div>
          <div class="flex flex-1 flex-col p-6 text-center">
            <h3 class="text-xl font-bold text-gray-900 dark:text-white group-hover:text-primary transition-colors duration-300 mb-2">Christopher Allsop</h3>
