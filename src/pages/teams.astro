---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pageTitle = "Our Teams - Ormeau Table Tennis Club";
const pageDescription = "Meet the players representing Ormeau Table Tennis Club at national level. From Premier Division champions to rising junior stars.";
---

<Layout title={pageTitle} description={pageDescription}>
  <Header />
<script is:inline>
    (function() {
      const menuBtn = document.getElementById('mobile-menu-btn');
      const closeBtn = document.getElementById('mobile-menu-close');
      const mobileMenu = document.getElementById('mobile-menu');
      
      function toggleMenu() {
        if (mobileMenu.classList.contains('translate-x-full')) {
          mobileMenu.classList.remove('translate-x-full');
        } else {
          mobileMenu.classList.add('translate-x-full');
        }
      }
      
      if (menuBtn) {
        menuBtn.addEventListener('click', toggleMenu);
      }
      
      if (closeBtn) {
        closeBtn.addEventListener('click', function() {
          mobileMenu.classList.add('translate-x-full');
        });
      }
    })();
  </script><script is:inline>
    (function() {
      const path = window.location.pathname;
      document.querySelectorAll('.nav-link').forEach(link => {
        const href = link.getAttribute('href');
        if ((path === '/' && href === '/') || href === path || href === path + '/') {
          link.classList.add('text-primary', 'dark:text-primary');
        }
      });
    })();
  </script>

  <!-- Hero Section -->
  <section class="relative w-full px-4 md:px-8 pt-8 pb-12">
    <div class="mx-auto max-w-7xl">
      <div class="relative h-[400px] md:h-[500px] w-full overflow-hidden rounded-xl shadow-2xl">
        <img alt="Ormeau TTC Teams" class="h-full w-full object-cover brightness-75" src="https://scontent.fbhd1-1.fna.fbcdn.net/v/t1.6435-9/74599539_2657304704351669_3401317389206290432_n.jpg?_nc_cat=102&ccb=1-7&_nc_sid=f798df&_nc_ohc=78xQ6ACxfdAQ7kNvwFwtDH5&_nc_oc=Adlkn8XzpDEWGVpxN1xzSMHL9o3mwcCnjdCgiuCCK45IOvFr-Fl35OydLxyF-_tpT9iqBTWi9CHOTxS0fRY1cCuP&_nc_zt=23&_nc_ht=scontent.fbhd1-1.fna&_nc_gid=-0C9N0Goo3X2CdgAZnuxKg&oh=00_Aft-tO580mNbri9nEFkihjIQtPjbcRzBzosPJJJblv_tzw&oe=69C3CE52"/>
