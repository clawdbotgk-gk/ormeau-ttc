          <div class="flex flex-1 flex-col p-6 text-center">
            <h3 class="text-xl font-bold text-gray-900 dark:text-white group-hover:text-primary transition-colors duration-300 mb-2">Daryl Strong</h3>
            <p class="text-sm leading-relaxed text-gray-600 dark:text-gray-400">Experienced player who has represented Ireland , and is one of the best masters in the UK.</p>
          </div>
        </div>

        <!-- Jonathan Mooney -->
        <div class="group relative flex flex-col overflow-hidden rounded-2xl bg-white shadow-md transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl hover:ring-2 hover:ring-primary dark:bg-gray-800/80 border border-gray-100 dark:border-gray-700">
