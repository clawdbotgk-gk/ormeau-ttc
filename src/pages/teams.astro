      <div class="mb-12 flex flex-col sm:flex-row sm:items-end justify-between border-b border-gray-200 pb-4 dark:border-gray-800 gap-4 text-center sm:text-left">
        <div>
          <h2 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white">Ladies Team</h2>
