        <a href="https://british.ttleagues.com/league/3794/division/10553" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-6 py-2.5 rounded-full bg-primary text-white font-bold text-sm hover:bg-primary-hover transition-all duration-300 shadow-md shadow-primary/20 transform hover:-translate-y-0.5 whitespace-nowrap">
