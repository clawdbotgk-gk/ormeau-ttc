---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pageTitle = "Our Teams - Ormeau Table Tennis Club";
const pageDescription = "Meet the players representing Ormeau Table Tennis Club at national level. From Premier Division champions to rising junior stars.";
---

<Layout title={pageTitle} description={pageDescription}>
  <Header />
  <style>
    .sticky-nav {
      position: sticky;
      top: 60px;
      z-index: 10;
      background: #1a1a1a;
      padding: 8px 16px;
      display: flex;
      justify-content: center;
      gap: 12px;
    }
    .nav-pill {
      padding: 6px 16px;
      border-radius: 20px;
      background: rgba(255,255,255,0.1);
      color: #fff;
      font-size: 14px;
      font-weight: 500;
      text-decoration: none;
      transition: background 0.2s ease;
    }
    .nav-pill:hover {
      background: rgba(255,255,255,0.2);
    }
    @media (max-width: 768px) {
      .group .aspect-\[4\/5\] img {
        aspect-ratio: 3 / 4;
        object-fit: cover;
        border-radius: 12px 12px 0 0;
      }
    }
    @media (max-width: 480px) {
      .group {
        min-height: auto;
      }
      .group .flex.flex-col {
        padding: 12px 16px;
      }
      .group .flex.flex-col:has(p) {
        padding-bottom: 24px;
      }
      .group .flex.flex-col:not(:has(p)) {
        padding: 12px 16px 12px;
      }
      .grid.grid-cols-1 {
        gap: 16px;
      }
    }
    @media (max-width: 768px) {
      .grid + section,
      section + section {
        border-top: 2px solid rgba(255,255,255,0.1);
        margin: 40px 16px;
        padding-top: 32px;
      }
      section h2 {
        font-size: 22px;
        margin-bottom: 8px;
      }
      section h2 + p {
        font-size: 14px;
        color: rgba(255,255,255,0.7);
      }
    }
    @media (hover: none) {
      .group {
        transition: transform 0.1s ease;
      }
      .group:hover {
        transform: none;
        box-shadow: none;
      }
      .group:active {
        transform: scale(0.98);
      }
      .group:hover .aspect-\[4\/5\] img {
        transform: none;
      }
    }
  </style>

  <!-- Hero Section -->
  <section class="relative w-full px-4 md:px-8 pt-8 pb-12">
    <div class="mx-auto max-w-7xl">
      <div class="relative h-[400px] md:h-[500px] w-full overflow-hidden rounded-xl shadow-2xl">
        <img alt="Ormeau TTC Teams" class="h-full w-full object-cover brightness-75" loading="lazy" src="https://xkwg7luliofrc1cs.public.blob.vercel-storage.com/Images/alexis.jpg"/>
        <div class="absolute inset-0 bg-gradient-to-t from-black/85 to-black/30"></div>
        <div class="absolute inset-0 flex flex-col justify-end p-[20px_16px] md:p-16">
          <h1 class="max-w-3xl text-[28px] font-black leading-tight text-white md:text-6xl tracking-tight">Our Teams</h1>
          <p class="mt-4 max-w-2xl text-[14px] md:text-lg text-gray-200 font-medium" style="line-height: 1.5;">Showcasing the talent and dedication behind Ormeau Table Tennis Club. From our Premier Division champions to our rising junior stars.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Sticky Sub-Navigation -->
  <div class="sticky-nav md:hidden">
    <a href="#premier" class="nav-pill">Premier</a>
    <a href="#ladies" class="nav-pill">Ladies</a>
    <a href="#veterans" class="nav-pill">Veterans</a>
  </div>


  <!-- Premier & Championship Players -->
  <section id="premier" class="py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 flex flex-col sm:flex-row sm:items-end justify-between border-b border-gray-200 pb-4 dark:border-gray-800 gap-4 text-center sm:text-left">
        <div>
          <h2 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white">Premier & Championship Players</h2>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">We have two senior British league teams playing in the Premier Division and also in the Championship Division.</p>
        </div>
        <a href="https://british.ttleagues.com/league/3074/division/8606" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-6 py-2.5 rounded-full bg-primary text-white font-bold text-sm hover:bg-primary-hover transition-all duration-300 shadow-md shadow-primary/20 transform hover:-translate-y-0.5 whitespace-nowrap">
          Check Out Team Results <span class="material-icons text-sm ml-2" aria-hidden="true">open_in_new</span>
        </a>
      </div>
      <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
        <!-- Par Gerell -->
        <div class="group relative flex flex-col overflow-hidden rounded-2xl bg-white shadow-md transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl hover:ring-2 hover:ring-primary dark:bg-gray-800/80 border border-gray-100 dark:border-gray-700">
          <div class="aspect-[4/5] w-full overflow-hidden bg-gray-100 dark:bg-gray-800 relative">
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent z-10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <img alt="Par Gerell" class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110" src="https://www.tabletennisengland.co.uk/content/uploads/2026/02/att.ANwDoXiAYfrZoSR4tV5KRJ9Dh1R7YNV0dyXMpZnXW14-560x420.jpg"/>
          </div>
          <div class="flex flex-1 flex-col p-6 text-center">
            <h3 class="text-xl font-bold text-gray-900 dark:text-white group-hover:text-primary transition-colors duration-300 mb-2">Par Gerell</h3>
            <p class="text-sm leading-relaxed text-gray-600 dark:text-gray-400">Swedish professional player who had 4 medals at the Olympics</p>
          </div>
        </div>

        <!-- Oriol Monzo -->
        <div class="group relative flex flex-col overflow-hidden rounded-2xl bg-white shadow-md transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl hover:ring-2 hover:ring-primary dark:bg-gray-800/80 border border-gray-100 dark:border-gray-700">
          <div class="aspect-[4/5] w-full overflow-hidden bg-gray-100 dark:bg-gray-800 relative">
