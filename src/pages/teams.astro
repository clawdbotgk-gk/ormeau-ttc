          <div class="aspect-[4/5] w-full overflow-hidden bg-gray-100 dark:bg-gray-800 relative">
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent z-10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <img alt="Anjali Singh" loading="lazy" class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110" src="https://xkwg7luliofrc1cs.public.blob.vercel-storage.com/Images/anjali.png"/>
          </div>
          <div class="flex flex-1 flex-col p-6 text-center">
            <h3 class="text-xl font-bold text-gray-900 dark:text-white group-hover:text-primary transition-colors duration-300">Anjali Singh</h3>
          </div>
        </div>

        <!-- Grace Looney -->
        <div class="group relative flex flex-col overflow-hidden rounded-2xl bg-white shadow-md transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl hover:ring-2 hover:ring-primary dark:bg-gray-800/80 border border-gray-100 dark:border-gray-700">
          <div class="aspect-[4/5] w-full overflow-hidden bg-gray-100 dark:bg-gray-800 relative">
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent z-10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <img alt="Grace Looney" loading="lazy" class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110" src="https://xkwg7luliofrc1cs.public.blob.vercel-storage.com/Images/grace%20.jpg"/>
