---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pageTitle = "Easter Camps — Ormeau Table Tennis Club";
const pageDescription = "Easter table tennis camps at Ormeau TTC in Belfast. Our 2026 camps have now finished — dates for next year's camps will be announced here in future.";
---

<Layout title={pageTitle} description={pageDescription}>
  <Header />

  <Fragment slot="head">
    <meta property="og:image" content="https://xkwg7luliofrc1cs.public.blob.vercel-storage.com/Images/performance%20camp.jpg" />
    <meta name="twitter:image" content="https://xkwg7luliofrc1cs.public.blob.vercel-storage.com/Images/performance%20camp.jpg" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "When will next year's Easter camp dates be announced?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Our Easter 2026 camps have now concluded. We will publish dates and booking information for future camps on this page when they are confirmed."
          }
        },
        {
          "@type": "Question",
          "name": "Does my child need to be an Ormeau member to attend?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "When beginner camp runs, it is open to everyone aged 8–12, regardless of club membership. NextGen and Performance camps are invite-only for players already known to the coaching team."
          }
        },
        {
          "@type": "Question",
          "name": "What does invite only mean for NextGen and Performance?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "These camps are reserved for players specifically selected by the Ormeau coaching team based on ability, commitment, and development potential."
          }
        },
        {
          "@type": "Question",
          "name": "Does my child need their own equipment?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Not for the Beginner Camp — we provide bats and balls. For NextGen and Performance camps, players should bring their own bat."
          }
        },
        {
          "@type": "Question",
          "name": "Is there parking at the venue?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "There is limited on-street parking on The Mount and surrounding streets. The venue is well served by public transport."
          }
        }
      ]
    })} />
  </Fragment>

  <!-- Hero -->
  <section class="relative bg-background-dark text-white overflow-hidden min-h-[70vh] flex items-center justify-center" id="top">
    <div class="absolute inset-0 z-0">
      <img
        alt="Ormeau group photo"
        class="w-full h-full object-cover scale-105 filter brightness-50 contrast-125"
        src="https://xkwg7luliofrc1cs.public.blob.vercel-storage.com/Images/performance%20camp.jpg"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/35 to-black/70"></div>
    </div>
    <div class="relative z-10 max-w-6xl mx-auto px-6 py-20 text-center space-y-8">
      <span class="inline-block px-5 py-2 rounded-full bg-primary/20 border border-primary/50 backdrop-blur text-xs md:text-sm font-bold uppercase tracking-[0.35em]">Easter Camps 2026 — concluded</span>
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-black leading-tight">
        Thank You For<br />
        <span class="text-primary">A Great Easter.</span>
      </h1>
      <p class="text-lg md:text-2xl text-gray-100 max-w-3xl mx-auto font-light">
        Our Easter 2026 camps have now finished. We will publish dates and booking details for next year's camps on this page when they are confirmed.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="#beginners" class="w-full sm:w-auto px-8 py-4 rounded-full bg-primary text-white font-bold text-sm tracking-widest uppercase hover:bg-primary-hover transition-all shadow-lg shadow-primary/25">Beginner Camp</a>
        <a href="#camps" class="w-full sm:w-auto px-8 py-4 rounded-full bg-white/10 border border-white/30 text-white font-semibold text-sm tracking-widest uppercase hover:bg-white/20 transition-all">Camp overview</a>
      </div>
    </div>
  </section>

  <!-- Overview -->
  <section class="py-20 bg-surface-dark" id="camps">
    <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-10 space-y-12">
      <div class="text-center max-w-3xl mx-auto space-y-4">
        <span class="inline-block px-4 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold uppercase tracking-[0.35em]">Easter 2026</span>
        <h2 class="text-3xl md:text-5xl font-bold text-white">Three Camps, Every Level.</h2>
        <p class="text-gray-300 text-lg">We ran dedicated camps for beginners, high-potential juniors, and performance players at our facility on The Mount — each session led by qualified coaches with sparring and multiball support. Dates for next year's camps will be announced here in future.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-[#1f1f1f] border border-gray-800 rounded-2xl p-6 space-y-4 shadow-xl">
          <h3 class="text-2xl font-bold text-green-300">Beginner Camp</h3>
          <p class="text-gray-300">A fun, structured introduction to table tennis for children aged 8–12. No experience needed — we provide all the equipment and coaching to get them started.</p>
          <div class="flex flex-wrap gap-2 text-xs text-gray-200">
            <span class="px-3 py-2 rounded-full bg-white/5 border border-white/10">Ages 8–12</span>
            <span class="px-3 py-2 rounded-full bg-white/5 border border-white/10">90 mins/day</span>
            <span class="px-3 py-2 rounded-full bg-white/5 border border-white/10">14 places/week</span>
          </div>
        </div>
        <div class="bg-[#1f1f1f] border border-gray-800 rounded-2xl p-6 space-y-4 shadow-xl">
          <h3 class="text-2xl font-bold text-sky-300">NextGen Camp</h3>
          <p class="text-gray-300">Intensive development camp for our highest potential young players. Focuses on technique, tactical awareness, and competitive readiness with our lead coaching team.</p>
          <div class="flex flex-wrap gap-2 text-xs text-gray-200">
            <span class="px-3 py-2 rounded-full bg-white/5 border border-white/10">By invitation</span>
            <span class="px-3 py-2 rounded-full bg-white/5 border border-white/10">3 hrs/day</span>
            <span class="px-3 py-2 rounded-full bg-white/5 border border-white/10">12 places</span>
          </div>
        </div>
        <div class="bg-[#1f1f1f] border border-gray-800 rounded-2xl p-6 space-y-4 shadow-xl">
          <h3 class="text-2xl font-bold text-amber-300">Performance Camp</h3>
          <p class="text-gray-300">Elite-level training for performance squad players. Advanced drills, match-play scenarios, conditioning, and one-to-one sparring with experienced coaches.</p>
          <div class="flex flex-wrap gap-2 text-xs text-gray-200">
            <span class="px-3 py-2 rounded-full bg-white/5 border border-white/10">By invitation</span>
            <span class="px-3 py-2 rounded-full bg-white/5 border border-white/10">3 hrs/day</span>
            <span class="px-3 py-2 rounded-full bg-white/5 border border-white/10">12 places/week</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Beginner Camp -->
  <section class="py-20 bg-background-dark" id="beginners">
    <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-10 grid lg:grid-cols-2 gap-12 items-center">
      <div class="order-2 lg:order-1 space-y-4">
        <span class="inline-block px-4 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold uppercase tracking-[0.35em]">Open To All</span>
        <h2 class="text-3xl md:text-4xl font-bold text-green-300">Beginner Camp</h2>
        <div class="bg-emerald-950/40 border border-emerald-500/30 rounded-2xl p-5 space-y-2">
          <p class="text-emerald-200 font-semibold text-lg">Easter 2026 beginner camp has now finished.</p>
          <p class="text-gray-300 text-sm">We will publish dates and booking for next year's beginner camp on this page when they are confirmed.</p>
        </div>
        <p class="text-lg text-gray-200">When it runs, beginner camp is the perfect introduction to table tennis for kids aged 8–12. No experience? No problem. Across five mornings they learn grip, stance, basic strokes, serving, and rallying in a supportive environment. All equipment is provided — players bring sports clothing and indoor trainers.</p>
        <div class="grid sm:grid-cols-2 gap-4 text-gray-200">
          <div class="flex items-start gap-3 bg-white/5 border border-white/10 rounded-2xl p-4">
            <span class="material-icons text-primary">groups</span>
            <div class="text-sm">Ages 8–12. Open to all — no club membership required.</div>
          </div>
          <div class="flex items-start gap-3 bg-white/5 border border-white/10 rounded-2xl p-4">
            <span class="material-icons text-primary">schedule</span>
            <div class="text-sm">Typically 9:30am – 11:00am, Monday to Friday (90 minutes per day).</div>
          </div>
          <div class="flex items-start gap-3 bg-white/5 border border-white/10 rounded-2xl p-4">
            <span class="material-icons text-primary">event</span>
            <div class="text-sm">Easter 2026 ran across two weeks; future dates will be announced here.</div>
          </div>
          <div class="flex items-start gap-3 bg-white/5 border border-white/10 rounded-2xl p-4">
            <span class="material-icons text-primary">confirmation_number</span>
            <div class="text-sm">Up to 14 places per week when booking opens.</div>
          </div>
          <div class="flex items-start gap-3 bg-white/5 border border-white/10 rounded-2xl p-4">
            <span class="material-icons text-primary">payments</span>
            <div class="text-sm">Easter 2026 was £75 per week (£15 per day); future pricing may vary.</div>
          </div>
          <div class="flex items-start gap-3 bg-white/5 border border-white/10 rounded-2xl p-4">
            <span class="text-primary text-lg" aria-hidden="true">🏓</span>
            <span class="sr-only">Table tennis bat</span>
            <div class="text-sm">All equipment provided. No experience needed.</div>
          </div>
        </div>
        <div class="bg-[#121212] border border-gray-800 rounded-2xl p-6 space-y-3">
          <h3 class="text-xl font-semibold text-white">What They'll Learn</h3>
          <ul class="space-y-2 text-gray-300 text-sm">
            <li class="flex items-center gap-2"><span class="material-icons text-primary text-base">check_circle</span>How to hold a bat correctly and the ready position</li>
            <li class="flex items-center gap-2"><span class="material-icons text-primary text-base">check_circle</span>Forehand and backhand push and drive</li>
            <li class="flex items-center gap-2"><span class="material-icons text-primary text-base">check_circle</span>Basic serving and returning</li>
            <li class="flex items-center gap-2"><span class="material-icons text-primary text-base">check_circle</span>Simple rally and point play</li>
            <li class="flex items-center gap-2"><span class="material-icons text-primary text-base">check_circle</span>Table tennis rules and etiquette</li>
            <li class="flex items-center gap-2"><span class="material-icons text-primary text-base">check_circle</span>Fun games and mini-competitions throughout the week</li>
          </ul>
        </div>
        <div class="pt-2">
          <p class="text-gray-400 text-sm mb-4">Registration is closed while we prepare next year's camp. Check back here for updates or <a href="/contact" class="text-primary font-semibold hover:underline">contact us</a> with any questions.</p>
        </div>
      </div>
      <div class="order-1 lg:order-2 bg-[#161616] border border-gray-800 rounded-3xl shadow-2xl flex flex-col gap-4 justify-center p-4">
        <img src="https://xkwg7luliofrc1cs.public.blob.vercel-storage.com/Images/camps%201.jpg" alt="Beginner camp" class="w-full h-56 sm:h-64 md:h-80 object-cover rounded-2xl" loading="lazy" />
        <img src="https://xkwg7luliofrc1cs.public.blob.vercel-storage.com/Images/camps%202.jpg" alt="Beginner camp 2" class="w-full h-56 sm:h-64 md:h-80 object-cover rounded-2xl" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- NextGen -->
  <section class="py-20 bg-surface-dark">
    <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-10 grid lg:grid-cols-2 gap-12 items-center">
      <div class="order-2 lg:order-1 space-y-4">
        <span class="inline-block px-4 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold uppercase tracking-[0.35em]">Invite Only</span>
        <h2 class="text-3xl md:text-4xl font-bold text-sky-300">NextGen Camp</h2>
        <div class="bg-sky-950/40 border border-sky-500/30 rounded-2xl p-5 space-y-2 mb-4">
          <p class="text-sky-200 font-semibold">Easter 2026 NextGen camps have now finished.</p>
          <p class="text-gray-300 text-sm">Future invite-only NextGen dates will be communicated to selected players and published here when confirmed.</p>
        </div>
        <p class="text-lg text-gray-200">Intensive development for our most promising young players. Three hours per day of structured coaching, multiball, sparring, and tactical work led by the Ormeau coaching team.</p>
        <div class="grid sm:grid-cols-2 gap-4 text-gray-200">
          <div class="flex items-start gap-3 bg-white/5 border border-white/10 rounded-2xl p-4"><span class="material-icons text-primary">lock</span><div class="text-sm">Invite only — selected by the coaching team.</div></div>
          <div class="flex items-start gap-3 bg-white/5 border border-white/10 rounded-2xl p-4"><span class="material-icons text-primary">schedule</span><div class="text-sm">11:30am – 2:30pm, Monday to Friday (3 hours per day).</div></div>
          <div class="flex items-start gap-3 bg-white/5 border border-white/10 rounded-2xl p-4"><span class="material-icons text-primary">event</span><div class="text-sm">NextGen 1: 30 March – 3 April. NextGen 2: 6 – 10 April.</div></div>
          <div class="flex items-start gap-3 bg-white/5 border border-white/10 rounded-2xl p-4"><span class="material-icons text-primary">confirmation_number</span><div class="text-sm">Limited to 12 places per camp.</div></div>
          <div class="flex items-start gap-3 bg-white/5 border border-white/10 rounded-2xl p-4"><span class="material-icons text-primary">payments</span><div class="text-sm">£100 per week (£20 per day).</div></div>
        </div>
        <div class="bg-[#121212] border border-gray-800 rounded-2xl p-6 space-y-3">
          <h3 class="text-xl font-semibold text-white">What's Covered</h3>
          <ul class="space-y-2 text-gray-300 text-sm">
            <li class="flex items-center gap-2"><span class="material-icons text-primary text-base">check_circle</span>Advanced stroke development and technique refinement</li>
            <li class="flex items-center gap-2"><span class="material-icons text-primary text-base">check_circle</span>Tactical patterns and match-play strategies</li>
            <li class="flex items-center gap-2"><span class="material-icons text-primary text-base">check_circle</span>Multiball and footwork drills</li>
            <li class="flex items-center gap-2"><span class="material-icons text-primary text-base">check_circle</span>Structured sparring with experienced partners</li>
          </ul>
        </div>
        <div class="pt-2">
          <p class="text-gray-400 text-sm">Registration for Easter 2026 has closed. <a href="/contact" class="text-primary font-semibold hover:underline">Contact us</a> if you have questions about future camps.</p>
        </div>
      </div>
      <div class="order-1 lg:order-2 bg-[#161616] border border-gray-800 rounded-3xl overflow-hidden shadow-2xl">
        <img src="https://xkwg7luliofrc1cs.public.blob.vercel-storage.com/Images/nextgen.jpg" alt="NextGen training" class="w-full h-full object-cover" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Performance -->
  <section class="py-20 bg-background-dark">
    <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-10 grid lg:grid-cols-2 gap-12 items-center">
      <div class="bg-[#161616] border border-gray-800 rounded-3xl overflow-hidden shadow-2xl order-2 lg:order-1 flex flex-col gap-4 p-4">
        <img src="https://xkwg7luliofrc1cs.public.blob.vercel-storage.com/Images/performance%20camp%202.jpg" alt="Performance camp 2" class="w-full h-56 sm:h-64 md:h-80 object-cover rounded-2xl" loading="lazy" />
        <img src="https://xkwg7luliofrc1cs.public.blob.vercel-storage.com/Images/performance%20camp%203.jpg" alt="Performance camp 3" class="w-full h-56 sm:h-64 md:h-80 object-cover rounded-2xl" loading="lazy" />
      </div>
      <div class="order-1 lg:order-2 space-y-4">
        <span class="inline-block px-4 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold uppercase tracking-[0.35em]">Invite Only</span>
        <h2 class="text-3xl md:text-4xl font-bold text-amber-300">Performance Camp</h2>
        <div class="bg-amber-950/40 border border-amber-500/30 rounded-2xl p-5 space-y-2 mb-4">
          <p class="text-amber-200 font-semibold">Easter 2026 Performance camps have now finished.</p>
          <p class="text-gray-300 text-sm">Invited players will hear about future performance camps through the coaching team; public dates will appear here when confirmed.</p>
        </div>
        <p class="text-lg text-gray-200">Elite training for performance squad players. Three hours of intensive daily training with lead coaches and dedicated sparring partners — designed to sharpen technique, build match fitness, and prepare for competitions.</p>
        <div class="grid sm:grid-cols-2 gap-4 text-gray-200">
          <div class="flex items-start gap-3 bg-white/5 border border-white/10 rounded-2xl p-4"><span class="material-icons text-primary">lock</span><div class="text-sm">Invite only — for current performance squad players.</div></div>
          <div class="flex items-start gap-3 bg-white/5 border border-white/10 rounded-2xl p-4"><span class="material-icons text-primary">schedule</span><div class="text-sm">3:00pm – 6:00pm, Monday to Friday (3 hours per day).</div></div>
          <div class="flex items-start gap-3 bg-white/5 border border-white/10 rounded-2xl p-4"><span class="material-icons text-primary">event</span><div class="text-sm">Week 1: 30 March – 3 April and Week 2: 6 – 10 April.</div></div>
          <div class="flex items-start gap-3 bg-white/5 border border-white/10 rounded-2xl p-4"><span class="material-icons text-primary">confirmation_number</span><div class="text-sm">Limited to 12 places per week.</div></div>
          <div class="flex items-start gap-3 bg-white/5 border border-white/10 rounded-2xl p-4"><span class="material-icons text-primary">payments</span><div class="text-sm">£100 per week (£20 per day).</div></div>
        </div>
        <div class="bg-[#121212] border border-gray-800 rounded-2xl p-6 space-y-3">
          <h3 class="text-xl font-semibold text-white">What's Covered</h3>
          <ul class="space-y-2 text-gray-300 text-sm">
            <li class="flex items-center gap-2"><span class="material-icons text-primary text-base">check_circle</span>High-intensity match-play and point-building patterns</li>
            <li class="flex items-center gap-2"><span class="material-icons text-primary text-base">check_circle</span>Multiball at competition intensity</li>
            <li class="flex items-center gap-2"><span class="material-icons text-primary text-base">check_circle</span>Physical conditioning and movement work</li>
          </ul>
        </div>
        <div class="pt-2">
          <p class="text-gray-400 text-sm">Registration for Easter 2026 has closed. <a href="/contact" class="text-primary font-semibold hover:underline">Contact us</a> for queries about future performance camps.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Timetable -->
  <section class="py-20 bg-surface-dark" id="timetable">
    <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-10 space-y-10">
      <div class="text-center space-y-3">
        <span class="inline-block px-4 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold uppercase tracking-[0.35em]">Daily Schedule</span>
        <h2 class="text-3xl md:text-4xl font-bold text-white">Camp Timetable</h2>
        <p class="text-gray-300 max-w-3xl mx-auto">Schedule below reflects Easter 2026 (for reference). Future timetables will be published when next year's dates are announced.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-[#1f1f1f] border border-gray-800 rounded-2xl p-6 space-y-4">
          <h3 class="text-xl font-semibold text-white">Week 1 (2026) — Mon 30 March to Fri 3 April</h3>
          <div class="space-y-3">
            <div class="flex items-center justify-between text-gray-200"><span>9:30am – 11:00am</span><span class="font-semibold text-green-300">Beginner Camp</span></div>
            <div class="flex items-center justify-between text-gray-200"><span>11:30am – 2:30pm</span><span class="font-semibold text-sky-300">NextGen 1 - FULL</span></div>
            <div class="flex items-center justify-between text-gray-200"><span>3:00pm – 6:00pm</span><span class="font-semibold text-amber-300">Performance Camp</span></div>
          </div>
        </div>
        <div class="bg-[#1f1f1f] border border-gray-800 rounded-2xl p-6 space-y-4">
          <h3 class="text-xl font-semibold text-white">Week 2 (2026) — Mon 6 April to Fri 10 April</h3>
          <div class="space-y-3">
            <div class="flex items-center justify-between text-gray-200"><span>9:30am – 11:00am</span><span class="font-semibold text-green-300">Beginner Camp</span></div>
            <div class="flex items-center justify-between text-gray-200"><span>11:30am – 2:30pm</span><span class="font-semibold text-sky-300">NextGen 2</span></div>
            <div class="flex items-center justify-between text-gray-200"><span>3:00pm – 6:00pm</span><span class="font-semibold text-amber-300">Performance Camp</span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-20 bg-background-dark" id="pricing">
    <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-10 space-y-12">
      <div class="text-center space-y-3">
        <span class="inline-block px-4 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold uppercase tracking-[0.35em]">Pricing</span>
        <h2 class="text-3xl md:text-4xl font-bold text-white">Camp Pricing</h2>
        <p class="text-gray-400 text-sm max-w-2xl mx-auto">Figures below were for Easter 2026. Pricing for future camps will be confirmed when bookings open.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-[#1f1f1f] border border-gray-800 rounded-2xl p-8 flex flex-col gap-4 shadow-xl">
          <div>
            <h3 class="text-2xl font-bold text-green-300">Beginner Camp</h3>
            <p class="text-gray-400 text-sm">Open to all ages 8–12</p>
          </div>
          <div class="flex items-baseline gap-2">
            <span class="text-4xl font-black text-green-300">£75</span>
            <span class="text-gray-400">/week</span>
          </div>
          <ul class="space-y-2 text-gray-300 text-sm">
            <li class="flex items-center gap-2"><span class="material-icons text-primary text-base">check_circle</span>5 days of coached sessions</li>
            <li class="flex items-center gap-2"><span class="material-icons text-primary text-base">check_circle</span>90 minutes per day</li>
            <li class="flex items-center gap-2"><span class="material-icons text-primary text-base">check_circle</span>All equipment provided</li>
            <li class="flex items-center gap-2"><span class="material-icons text-primary text-base">check_circle</span>Max 14 players per week</li>
            <li class="flex items-center gap-2"><span class="material-icons text-primary text-base">check_circle</span>Fun end-of-week competition</li>
          </ul>
          <div class="pt-2">
            <p class="text-gray-400 text-xs mb-3">Easter 2026 concluded — registration closed. Next year's dates will be announced here.</p>
          </div>
        </div>

        <div class="relative bg-[#1f1f1f] border-2 border-primary rounded-2xl p-8 flex flex-col gap-4 shadow-2xl transform md:scale-105">
          <div class="absolute top-0 left-1/2 -translate-x-1/2 bg-primary text-white px-4 py-1 text-[10px] font-bold uppercase tracking-[0.35em] rounded-b-xl">Invite Only</div>
          <div class="pt-3">
