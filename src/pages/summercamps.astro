---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pageTitle = "Summer Camps 2026 — Ormeau Table Tennis Club";
const pageDescription = "Summer table tennis camps at Ormeau TTC, Belfast — July & August 2026. Booking open now; register via the form on this page. From £75 per child per week. Ages 9–12.";

/** Summer camp weeks (2026) — Beginner to Improver. */
const biWeek1 = "Monday 20 – Friday 24 July 2026";
const biWeek2 = "Monday 10 – Friday 14 August 2026";
const biWeekOptional = "Monday 17 – Friday 21 August 2026";
/** Beginner to Improver — daily session time */
const beginnerCampTime = "10:00–12:00";
---

<Layout title={pageTitle} description={pageDescription}>
  <Header />

  <Fragment slot="head">
    <meta property="og:image" content="https://xkwg7luliofrc1cs.public.blob.vercel-storage.com/Images/camps%201.jpg" />
    <meta name="twitter:image" content="https://xkwg7luliofrc1cs.public.blob.vercel-storage.com/Images/camps%201.jpg" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "When do summer camps run?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Beginner to Improver runs in summer 2026 on: 20–24 July, 10–14 August, and an optional third week 17–21 August (TBC). Sessions are 10:00–12:00 Monday to Friday. Booking is open on the Ormeau website — use the registration form on the summer camps page."
          }
        },
        {
          "@type": "Question",
          "name": "Does my child need to be an Ormeau member to attend?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The Beginner to Improver camp is open to everyone aged 9–12, regardless of club membership."
          }
        },
        {
          "@type": "Question",
          "name": "Does my child need their own equipment?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No — we provide bats and balls for the Beginner to Improver camp."
          }
        },
        {
          "@type": "Question",
          "name": "Is there parking at the venue?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "There is limited on-street parking on The Mount and surrounding streets. The venue is well served by public transport."
          }
        }
      ]
    })} />
  </Fragment>

  <!-- Hero -->
  <section class="relative bg-background-dark text-white overflow-hidden min-h-[70vh] flex items-center justify-center" id="top">
    <div class="absolute inset-0 z-0">
      <img
        alt="Summer camp training at Ormeau TTC"
        class="w-full h-full object-cover scale-105 filter brightness-50 contrast-125"
        src="https://xkwg7luliofrc1cs.public.blob.vercel-storage.com/Images/camps%201.jpg"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/35 to-black/70"></div>
    </div>
    <div class="relative z-10 max-w-6xl mx-auto px-6 py-20 text-center space-y-8">
      <span class="inline-block px-5 py-2 rounded-full bg-primary/20 border border-primary/50 backdrop-blur text-xs md:text-sm font-bold uppercase tracking-[0.35em]">Summer 2026 · Belfast</span>
      <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-black leading-tight max-w-4xl mx-auto">
        Your child's first summer of <span class="text-primary">table tennis</span> starts here
      </h1>
      <p class="text-lg md:text-xl text-gray-100 max-w-2xl mx-auto font-light leading-relaxed">
        Five mornings of coaching, fun, and new skills — ages 9–12, no experience needed. Belfast, July &amp; August 2026.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center flex-wrap pt-2">
        <a href="#register-interest" class="w-full sm:w-auto px-10 py-5 rounded-full bg-primary text-white font-bold text-sm md:text-base tracking-widest uppercase hover:bg-primary-hover transition-all shadow-xl shadow-primary/30">Book now</a>
        <a href="#whats-included" class="w-full sm:w-auto px-8 py-4 rounded-full border-2 border-white/40 text-white font-semibold text-sm tracking-wide hover:bg-white/10 transition-all">See what's included</a>
      </div>
      <p class="text-sm text-green-400 max-w-lg mx-auto">
        <strong class="text-green-300 font-semibold">Booking open now</strong> — register using the form below.
      </p>
    </div>
  </section>

  <!-- Section 1: Beginner to Improver — main offer -->
  <section class="py-16 md:py-24 bg-background-dark scroll-mt-20" id="beginner-improver">
    <div class="max-w-5xl mx-auto px-6 sm:px-8 lg:px-10 space-y-12">
      <div class="text-center space-y-3 max-w-2xl mx-auto">
        <span class="inline-block px-4 py-1 rounded-full bg-primary/15 text-primary text-xs font-bold uppercase tracking-[0.35em]">Beginner to Improver</span>
        <h2 class="text-3xl md:text-4xl font-bold text-white">The camp you can book</h2>
        <p class="text-gray-400 text-sm">Open to everyone aged 9–12 — no club membership required.</p>
      </div>

      <!-- Dates, times, price — single detailed block (only place full specifics appear besides hero tagline) -->
      <div id="schedule" class="rounded-3xl border-2 border-primary/40 bg-gradient-to-br from-emerald-950/40 to-[#121212] p-6 md:p-8 shadow-xl scroll-mt-24">
        <h3 class="text-lg font-semibold text-green-300 mb-4">Dates &amp; times</h3>
        <dl class="grid sm:grid-cols-2 gap-4 text-sm text-gray-300">
          <div class="space-y-1">
            <dt class="text-gray-500 uppercase text-[10px] tracking-wider">Camp 1 · Week 1</dt>
            <dd class="text-gray-100">{biWeek1}</dd>
          </div>
          <div class="space-y-1">
            <dt class="text-gray-500 uppercase text-[10px] tracking-wider">Camp 2 · Week 2</dt>
            <dd class="text-gray-100">{biWeek2}</dd>
          </div>
          <div class="space-y-1 sm:col-span-2">
            <dt class="text-gray-500 uppercase text-[10px] tracking-wider">Camp 3 · Week 3</dt>
            <dd class="text-gray-100">{biWeekOptional}</dd>
          </div>
          <div class="space-y-1 sm:col-span-2">
            <dt class="text-gray-500 uppercase text-[10px] tracking-wider">Daily time</dt>
            <dd class="text-gray-100">{beginnerCampTime} · Monday to Friday · five mornings per week</dd>
          </div>
        </dl>

        <div class="mt-6 pt-6 border-t border-white/10">
          <h3 class="text-lg font-semibold text-green-300 mb-4">Weekly camp pricing</h3>
          <div class="overflow-x-auto rounded-xl border border-white/10">
            <table class="w-full text-sm text-left text-gray-300 min-w-[320px]">
              <caption class="sr-only">Summer camp prices by option</caption>
              <thead>
                <tr class="border-b border-gray-700 bg-black/20">
                  <th scope="col" class="px-4 py-3 font-semibold text-gray-200">Option</th>
                  <th scope="col" class="px-4 py-3 font-semibold text-gray-200 text-right whitespace-nowrap">Price</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-800">
                <tr><td class="px-4 py-2.5">Camp 1 (1 child)</td><td class="px-4 py-2.5 text-right font-medium text-white">£75</td></tr>
                <tr><td class="px-4 py-2.5">Camp 2 (1 child)</td><td class="px-4 py-2.5 text-right font-medium text-white">£75</td></tr>
                <tr><td class="px-4 py-2.5">Camp 3 (1 child)</td><td class="px-4 py-2.5 text-right font-medium text-white">£75</td></tr>
                <tr><td class="px-4 py-2.5">Camp 1 (2 children)</td><td class="px-4 py-2.5 text-right font-medium text-white">£140</td></tr>
                <tr><td class="px-4 py-2.5">Camp 2 (2 children)</td><td class="px-4 py-2.5 text-right font-medium text-white">£140</td></tr>
                <tr><td class="px-4 py-2.5">Camp 3 (2 children)</td><td class="px-4 py-2.5 text-right font-medium text-white">£140</td></tr>
                <tr class="bg-primary/5"><td class="px-4 py-2.5">Two camps (1 child)</td><td class="px-4 py-2.5 text-right font-medium text-primary">£140</td></tr>
                <tr class="bg-primary/5"><td class="px-4 py-2.5">Three camps (1 child)</td><td class="px-4 py-2.5 text-right font-medium text-primary">£200</td></tr>
                <tr class="bg-primary/5"><td class="px-4 py-2.5">Two camps (2 children)</td><td class="px-4 py-2.5 text-right font-medium text-primary">£260</td></tr>
                <tr class="bg-primary/5"><td class="px-4 py-2.5">Three camps (2 children)</td><td class="px-4 py-2.5 text-right font-medium text-primary">£350</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <p class="text-lg text-gray-200 text-center max-w-3xl mx-auto leading-relaxed">
        A full week of coaching, games, and match play in a supportive group — ideal for first-timers or children who want to build confidence. <strong class="text-white">Equipment provided</strong>: we supply bats and balls. <strong class="text-white">You bring</strong>: indoor trainers, comfortable sports clothes, and a water bottle.
      </p>

      <div id="whats-included" class="bg-[#121212] border border-gray-800 rounded-2xl p-6 md:p-8 space-y-4 scroll-mt-24">
        <h3 class="text-xl md:text-2xl font-semibold text-white">What they'll learn</h3>
        <ul class="space-y-2 text-gray-300 text-sm md:text-base">
          <li class="flex items-start gap-2"><span class="material-icons text-primary text-base shrink-0 mt-0.5">check_circle</span><span>How to hold a bat correctly and the ready position</span></li>
          <li class="flex items-start gap-2"><span class="material-icons text-primary text-base shrink-0 mt-0.5">check_circle</span><span>Forehand and backhand push and drive</span></li>
          <li class="flex items-start gap-2"><span class="material-icons text-primary text-base shrink-0 mt-0.5">check_circle</span><span>Serving technique and receiving</span></li>
          <li class="flex items-start gap-2"><span class="material-icons text-primary text-base shrink-0 mt-0.5">check_circle</span><span>Rally building and point play</span></li>
          <li class="flex items-start gap-2"><span class="material-icons text-primary text-base shrink-0 mt-0.5">check_circle</span><span>Introduction to spin and placement</span></li>
          <li class="flex items-start gap-2"><span class="material-icons text-primary text-base shrink-0 mt-0.5">check_circle</span><span>Table tennis rules, etiquette, and fun competitions</span></li>
        </ul>
      </div>

      <div>
        <h3 class="text-lg font-semibold text-white text-center mb-4">Previous Summer Camps</h3>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 rounded-2xl overflow-hidden">
          <img src="https://xkwg7luliofrc1cs.public.blob.vercel-storage.com/Images/camps%201.jpg" alt="Junior players at Ormeau summer camp" class="w-full aspect-square object-cover" loading="lazy" />
          <img src="https://xkwg7luliofrc1cs.public.blob.vercel-storage.com/Images/camps%202.jpg" alt="Coaching on the hall floor" class="w-full aspect-square object-cover" loading="lazy" />
          <img src="https://xkwg7luliofrc1cs.public.blob.vercel-storage.com/Images/hall.jpg" alt="Ormeau TTC hall" class="w-full aspect-square object-cover" loading="lazy" />
          <img src="https://xkwg7luliofrc1cs.public.blob.vercel-storage.com/Images/camps%201.jpg" alt="Summer camp at Ormeau" class="w-full aspect-square object-cover" loading="lazy" />
        </div>
      </div>

      <div id="register-interest" class="rounded-3xl border border-gray-800 bg-[#1a1a1a] p-6 md:p-10 scroll-mt-24">
        <h3 class="text-xl md:text-2xl font-bold text-white text-center mb-2">Booking open now</h3>
        <p class="text-gray-400 text-sm text-center mb-3 max-w-md mx-auto">Complete the registration form below to book your child's place.</p>
        <p class="text-gray-400 text-sm text-center mb-8 max-w-lg mx-auto font-normal">Spaces are limited — once a week is full, it's closed.</p>
        <div class="w-full max-w-2xl mx-auto overflow-hidden rounded-xl bg-white">
          <iframe
            title="Summer camp registration — Cognito Form"
            src="https://www.cognitoforms.com/f/nR0HQjg5VUqZ_2t6O8kL5g/310"
            allow="payment"
            style="border:0;width:100%;"
            height="1171"
          ></iframe>
        </div>
        <script is:inline src="https://www.cognitoforms.com/f/iframe.js"></script>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="#register-interest" class="inline-flex items-center justify-center px-8 py-4 rounded-full bg-primary text-white font-bold text-sm tracking-widest uppercase hover:bg-primary-hover transition-colors shadow-lg">Book now</a>
        <a href="/contact" class="text-gray-400 text-sm hover:text-white transition-colors">Questions? Contact us</a>
      </div>
    </div>
  </section>

  <!-- Section 2: Social proof -->
  <section class="py-16 md:py-20 bg-surface-dark border-t border-gray-800/80" aria-labelledby="social-heading">
    <div class="max-w-5xl mx-auto px-6 sm:px-8 lg:px-10 space-y-12">
      <div class="text-center space-y-3">
        <h2 id="social-heading" class="text-2xl md:text-3xl font-bold text-white">Trusted by local families</h2>
        <p class="text-primary text-lg md:text-xl font-normal">Over 80 juniors joined our camps last summer.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        <blockquote class="bg-[#1a1a1a] border border-gray-800 rounded-2xl p-6 text-gray-300 text-sm leading-relaxed">
          <p class="mb-3">"Our two couldn't wait to go back each morning — the coaches made it so welcoming."</p>
          <footer class="text-gray-500 text-xs">— Parent, Belfast</footer>
        </blockquote>
        <blockquote class="bg-[#1a1a1a] border border-gray-800 rounded-2xl p-6 text-gray-300 text-sm leading-relaxed">
          <p class="mb-3">"Brilliant week — he came home with real confidence and a new hobby."</p>
          <footer class="text-gray-500 text-xs">— Parent, East Belfast</footer>
        </blockquote>
        <blockquote class="bg-[#1a1a1a] border border-gray-800 rounded-2xl p-6 text-gray-300 text-sm leading-relaxed">
          <p class="mb-3">"Professional setup, friendly atmosphere — exactly what we wanted for a first sport."</p>
          <footer class="text-gray-500 text-xs">— Parent, South Belfast</footer>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- Section 3: Practical info (collapsible) -->
  <section class="py-16 md:py-20 bg-background-dark" id="practical" aria-labelledby="practical-heading">
    <div class="max-w-3xl mx-auto px-6 sm:px-8 lg:px-10 space-y-6">
      <div class="text-center space-y-2">
        <h2 id="practical-heading" class="text-2xl md:text-3xl font-bold text-white">Practical information</h2>
        <p class="text-gray-500 text-sm">Drop-downs — tap to expand.</p>
      </div>
      <details class="group bg-[#1f1f1f] border border-gray-800 rounded-2xl overflow-hidden">
        <summary class="flex items-center justify-between p-5 cursor-pointer list-none font-semibold text-white">
          What to bring (Beginner camp)
          <span class="material-icons text-primary transition-transform group-open:rotate-180">expand_more</span>
        </summary>
        <div class="px-5 pb-5 text-gray-300 text-sm space-y-3 border-t border-gray-800 pt-4">
          <p>We provide bats and balls. Please bring:</p>
          <ul class="list-disc list-inside space-y-1 text-gray-400">
            <li>Indoor trainers (non-marking soles) and comfortable sports clothes</li>
            <li>Water bottle</li>
          </ul>
        </div>
      </details>
      <details class="group bg-[#1f1f1f] border border-gray-800 rounded-2xl overflow-hidden">
        <summary class="flex items-center justify-between p-5 cursor-pointer list-none font-semibold text-white">
          Parking &amp; drop-off
          <span class="material-icons text-primary transition-transform group-open:rotate-180">expand_more</span>
        </summary>
        <div class="px-5 pb-5 text-gray-300 text-sm space-y-2 border-t border-gray-800 pt-4">
          <p>113 The Mount, Belfast BT5 4ND. Limited on-street parking nearby; Metro bus routes serve the area.</p>
          <p>Parents are welcome for drop-off and pick-up. We keep spectating to a minimum so sessions stay focused.</p>
        </div>
      </details>
      <details class="group bg-[#1f1f1f] border border-gray-800 rounded-2xl overflow-hidden" id="faq">
        <summary class="flex items-center justify-between p-5 cursor-pointer list-none font-semibold text-white">
          Other questions
          <span class="material-icons text-primary transition-transform group-open:rotate-180">expand_more</span>
        </summary>
        <div class="px-5 pb-5 text-gray-300 text-sm space-y-4 border-t border-gray-800 pt-4">
          <p><strong class="text-white">Membership?</strong> Beginner camp is open to all aged 9–12 — not limited to club members.</p>
          <p><strong class="text-white">Cancellations or injury?</strong> Contact us as soon as you can. Refunds or credits are considered case by case; we cannot guarantee refunds for non-attendance.</p>
          <p><strong class="text-white">Dates and pricing?</strong> See <a href="#schedule" class="text-primary font-medium hover:underline">the schedule box above</a>. For anything else, <a href="/contact" class="text-primary font-medium hover:underline">contact us</a>.</p>
        </div>
      </details>
    </div>
  </section>

  <!-- Footer CTA -->
  <section class="relative py-20 bg-primary overflow-hidden">
    <div class="absolute inset-0 opacity-10 grayscale mix-blend-overlay">
      <img class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDTr5ZYUqSr67umNFQBjUXdmYvuyqDAzBbNKd4Kq1wktWGLcYn5ogtLA7y7YVdR4d7tLOaq3b9DIwTKuiuvoavDonQeZoVEG-eZyLb52qd2OZZfzsJ7TlRmBiF5aJ9omD6fYoAD3MfFJnZRO-U4F9_rAvj6eZjzAFLJwjGCgTnYW1J8aEWajqLHG6L4_nDwTnllpT7T0kBXD90R4J3vMoYWHfim4zkO_OGLzzGPmNvdr_7RasQ7z1jAaCOudsHoYD1A1KFSW4roR7Sc" alt="" loading="lazy" />
    </div>
    <div class="relative max-w-3xl mx-auto px-6 text-center text-white space-y-6">
      <h2 class="text-3xl md:text-4xl font-bold">Booking open now</h2>
      <p class="text-lg md:text-xl font-light opacity-95"><strong class="font-semibold">Beginner to Improver</strong> — use the registration form below. We'll confirm your booking by email. Spaces are limited — once a week is full, it's closed.</p>
      <a href="#register-interest" class="inline-flex items-center justify-center w-full sm:w-auto min-w-[240px] px-10 py-5 rounded-full bg-white text-primary font-bold text-sm md:text-base tracking-widest uppercase hover:bg-gray-100 transition-all shadow-xl">Book now</a>
      <p class="text-sm opacity-80"><a href="#schedule" class="underline decoration-white/40 hover:decoration-white">Dates &amp; times</a> · <a href="/contact" class="underline decoration-white/40 hover:decoration-white">Contact</a></p>
    </div>
  </section>

  <!-- Location -->
  <section class="py-20 bg-surface-dark" id="location">
    <div class="max-w-6xl mx-auto px-6 sm:px-8 lg:px-10 grid lg:grid-cols-2 gap-10 items-center">
      <div class="space-y-4">
        <span class="inline-block px-4 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold uppercase tracking-[0.35em]">Find Us</span>
        <h2 class="text-3xl md:text-4xl font-bold text-white">Ormeau Table Tennis Club</h2>
        <div class="space-y-3 text-gray-200 text-sm">
          <div class="flex items-start gap-3"><span class="material-icons text-primary">place</span><p>113 The Mount, Belfast BT5 4ND</p></div>
          <div class="flex items-start gap-3"><span class="material-icons text-primary">email</span><a href="mailto:ormeautt@live.co.uk" class="hover:text-primary">ormeautt@live.co.uk</a></div>
        </div>
        <p class="text-gray-300">Permanent facility with dedicated tables, coaching space, and easy access from city centre. Reach us by Metro bus routes or limited on-street parking nearby.</p>
      </div>
      <div class="bg-[#1f1f1f] border border-gray-800 rounded-3xl overflow-hidden shadow-2xl h-full min-h-[320px]">
        <iframe
          title="Ormeau Table Tennis Club Map"
          src="https://maps.google.com/maps?q=113%20The%20Mount%2C%20Belfast%20BT5%204ND&t=&z=15&ie=UTF8&iwloc=&output=embed"
          class="w-full h-full min-h-[320px]"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
