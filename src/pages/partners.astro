---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pageTitle = "Partners - Ormeau Table Tennis Club";
const pageDescription = "Meet the sponsors and partners who support Ormeau Table Tennis Club. Together we provide world-class facilities and coaching to our community in Belfast.";
const pageImage = "https://scontent-lhr8-2.xx.fbcdn.net/v/t39.30808-6/540735236_1358210349644165_5176070366626030508_n.jpg";
---

<Layout title={pageTitle} description={pageDescription}>
  <!-- Open Graph -->
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDescription} />
  <meta property="og:image" content={pageImage} />
  <meta property="og:url" content="https://ormeautabletennis.com/partners" />
  <meta property="og:type" content="website" />
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={pageDescription} />
  <meta name="twitter:image" content={pageImage} />
  <Header /><script is:inline>
    (function() {
      const path = window.location.pathname;
      document.querySelectorAll('.nav-link').forEach(link => {
        const href = link.getAttribute('href');
        if ((path === '/' && href === '/') || href === path || href === path + '/') {
          link.classList.add('text-primary', 'dark:text-primary');
        }
      });
    })();
  </script>

  <!-- Hero Section: Community Impact -->
  <section class="relative w-full px-4 md:px-8 pt-8 pb-12">
    <div class="mx-auto max-w-7xl">
      <div class="relative h-[400px] md:h-[500px] w-full overflow-hidden rounded-xl shadow-2xl">
        <img alt="Club members with sponsor banners" class="h-full w-full object-cover brightness-75" src="https://xkwg7luliofrc1cs.public.blob.vercel-storage.com/Images/peadar%20mpt%20.jpg"/>
        <div class="absolute inset-0 bg-gradient-to-t from-background-dark/80 via-transparent to-transparent flex flex-col justify-end p-8 md:p-16">
          <h1 class="max-w-3xl text-4xl font-black leading-tight text-white md:text-6xl tracking-tight">
            Empowering Sport Through <span class="text-primary">Community Support</span>
          </h1>
          <p class="mt-4 max-w-2xl text-lg text-gray-200 font-medium leading-relaxed">
            Our sponsors are more than just logos; they are the backbone of our community. Together, we provide world-class facilities and coaching to over 150 members.
          </p>
        </div>
      </div>
      
      <!-- Impact Quick Stats -->
      <div class="relative -mt-10 mx-auto grid max-w-5xl grid-cols-1 gap-4 px-4 sm:grid-cols-4">
        <div class="flex flex-col items-center justify-center rounded-xl bg-white dark:bg-gray-800 p-6 shadow-xl border border-primary/5">
          <span class="text-primary text-3xl font-black">10+</span>
          <span class="text-sm font-bold uppercase tracking-widest text-gray-500 dark:text-gray-400">Partners</span>
        </div>
        <div class="flex flex-col items-center justify-center rounded-xl bg-white dark:bg-gray-800 p-6 shadow-xl border border-primary/5">
          <span class="text-primary text-3xl font-black">£1000s</span>
          <span class="text-sm font-bold uppercase tracking-widest text-gray-500 dark:text-gray-400">Annual Investment</span>
        </div>
        <div class="flex flex-col items-center justify-center rounded-xl bg-white dark:bg-gray-800 p-6 shadow-xl border border-primary/5">
          <span class="text-primary text-3xl font-black">20+</span>
          <span class="text-sm font-bold uppercase tracking-widest text-gray-500 dark:text-gray-400">Coached Weekly Sessions</span>
        </div>
        <div class="flex flex-col items-center justify-center rounded-xl bg-white dark:bg-gray-800 p-6 shadow-xl border border-primary/5">
          <span class="text-primary text-3xl font-black">150+</span>
          <span class="text-sm font-bold uppercase tracking-widest text-gray-500 dark:text-gray-400">Members</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Partners Grid -->
  <section class="px-4 md:px-8 py-16">
    <div class="mx-auto max-w-7xl">
      <div class="mb-12 flex flex-col items-start justify-between gap-4 md:flex-row md:items-end">
        <div>
          <h2 class="text-3xl font-black tracking-tight text-gray-900 dark:text-white">Our Partners</h2>
          <div class="mt-2 h-1.5 w-24 rounded-full bg-primary"></div>
        </div>
        <p class="max-w-md text-gray-600 dark:text-gray-400 font-medium">
          Working together with organisations that share our vision for table tennis in Belfast and Northern Ireland.
        </p>
      </div>
      
      <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
        <!-- Partner Card 1 -->
        <div class="partner-card group flex flex-col rounded-xl bg-white dark:bg-gray-800 p-8 shadow-md border border-gray-100 dark:border-gray-700">
          <div class="mb-6 flex h-20 items-center justify-center rounded-lg bg-white dark:bg-gray-900 p-4 transition-all group-hover:scale-105">
            <img src="https://logos-api.apistemic.com/domain:mtb-law.co.uk" alt="MTB Law" class="h-full w-auto object-contain" />
          </div>
          <h3 class="mb-2 text-xl font-bold text-gray-900 dark:text-white">McCartan Turkington Breen</h3>
          <p class="mb-6 text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
            A leading full-service law firm in Belfast with almost 50 years of experience.
          </p>
          <a class="mt-auto flex items-center gap-2 text-sm font-bold text-primary hover:gap-3 transition-all" href="https://mtb-law.co.uk/" target="_blank" rel="noopener noreferrer">Visit Website <span class="material-icons text-sm">arrow_forward</span></a>
        </div>
        
        <!-- Partner Card 2 -->
        <div class="partner-card group flex flex-col rounded-xl bg-white dark:bg-gray-800 p-8 shadow-md border border-gray-100 dark:border-gray-700">
          <div class="mb-6 flex h-20 items-center justify-center rounded-lg bg-white dark:bg-gray-900 p-4 transition-all group-hover:scale-105">
            <img src="https://logos-api.apistemic.com/domain:lockton.com" alt="Lockton" class="h-full w-auto object-contain" />
          </div>
          <h3 class="mb-2 text-xl font-bold text-gray-900 dark:text-white">Lockton Insurance</h3>
          <p class="mb-6 text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
            The world's largest independent global insurance broker.
          </p>
          <a class="mt-auto flex items-center gap-2 text-sm font-bold text-primary hover:gap-3 transition-all" href="https://global.lockton.com/offices/uk-belfast" target="_blank" rel="noopener noreferrer">Visit Website <span class="material-icons text-sm">arrow_forward</span></a>
        </div>
        
        <!-- Partner Card 3 -->
        <div class="partner-card group flex flex-col rounded-xl bg-white dark:bg-gray-800 p-8 shadow-md border border-gray-100 dark:border-gray-700">
          <div class="mb-6 flex h-20 items-center justify-center rounded-lg bg-white dark:bg-gray-900 p-4 transition-all group-hover:scale-105">
            <img src="https://glowmetrics.com/wp-content/uploads/2025/09/glowmetrics-logo-2025-1200x345.png" alt="GlowMetrics" class="h-full w-auto object-contain" />
          </div>
          <h3 class="mb-2 text-xl font-bold text-gray-900 dark:text-white">GlowMetrics</h3>
          <p class="mb-6 text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
            Belfast-based digital marketing agency specialising in data analytics and SEO.
          </p>
          <a class="mt-auto flex items-center gap-2 text-sm font-bold text-primary hover:gap-3 transition-all" href="https://glowmetrics.com/" target="_blank" rel="noopener noreferrer">Visit Website <span class="material-icons text-sm">arrow_forward</span></a>
        </div>

        <!-- Partner Card 4 -->
        <div class="partner-card group flex flex-col rounded-xl bg-white dark:bg-gray-800 p-8 shadow-md border border-gray-100 dark:border-gray-700">
          <div class="mb-6 flex h-20 items-center justify-center rounded-lg bg-white dark:bg-gray-900 p-4 transition-all group-hover:scale-105">
            <img src="https://logos-api.apistemic.com/domain:chubb.com" alt="Chubb" class="h-full w-auto object-contain" />
          </div>
          <h3 class="mb-2 text-xl font-bold text-gray-900 dark:text-white">Chubb Insurance</h3>
          <p class="mb-6 text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
            Global leader in insurance providing protection for businesses and employees.
          </p>
          <a class="mt-auto flex items-center gap-2 text-sm font-bold text-primary hover:gap-3 transition-all" href="https://www.chubb.com/uk-en/" target="_blank" rel="noopener noreferrer">Visit Website <span class="material-icons text-sm">arrow_forward</span></a>
        </div>
        
        <!-- Partner Card 5 -->
        <div class="partner-card group flex flex-col rounded-xl bg-white dark:bg-gray-800 p-8 shadow-md border border-gray-100 dark:border-gray-700">
          <div class="mb-6 flex h-20 items-center justify-center rounded-lg bg-white dark:bg-gray-900 p-4 transition-all group-hover:scale-105">
            <img src="https://gmaglogistics.com/wp-content/uploads/elementor/thumbs/logo_png-white-2-p10nxc330joz3rem22n4b9zy3gyjesfq9cqf4l9ji8.png" alt="GMAg Logistics" class="h-full w-auto object-contain" />
          </div>
          <h3 class="mb-2 text-xl font-bold text-gray-900 dark:text-white">GMAg Logistics</h3>
          <p class="mb-6 text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
            Dynamic transport and logistics company operating across Ireland.
          </p>
          <a class="mt-auto flex items-center gap-2 text-sm font-bold text-primary hover:gap-3 transition-all" href="https://gmaglogistics.com/" target="_blank" rel="noopener noreferrer">Visit Website <span class="material-icons text-sm">arrow_forward</span></a>
        </div>

        <!-- Partner Card 6 -->
        <div class="partner-card group flex flex-col rounded-xl bg-white dark:bg-gray-800 p-8 shadow-md border border-gray-100 dark:border-gray-700">
          <div class="mb-6 flex h-20 items-center justify-center rounded-lg bg-white dark:bg-gray-900 p-4 transition-all group-hover:scale-105">
            <img src="https://marypeterstrust.org/wp-content/uploads/2018/07/widget-logo.png" alt="Mary Peters Trust" class="h-full w-auto object-contain" />
          </div>
          <h3 class="mb-2 text-xl font-bold text-gray-900 dark:text-white">Mary Peters Trust</h3>
          <p class="mb-6 text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
            Northern Ireland's leading sports charity supporting young athletes for 50 years.
          </p>
          <a class="mt-auto flex items-center gap-2 text-sm font-bold text-primary hover:gap-3 transition-all" href="https://marypeterstrust.org/" target="_blank" rel="noopener noreferrer">Visit Website <span class="material-icons text-sm">arrow_forward</span></a>
        </div>

        <!-- Partner Card 7 -->
        <div class="partner-card group flex flex-col rounded-xl bg-white dark:bg-gray-800 p-8 shadow-md border border-gray-100 dark:border-gray-700">
          <div class="mb-6 flex h-20 items-center justify-center rounded-lg bg-white dark:bg-gray-900 p-4 transition-all group-hover:scale-105">
            <img src="https://tabletennisulster.com/wp-content/uploads/2024/02/logo1.png" alt="Table Tennis Ulster" class="h-full w-auto object-contain" />
          </div>
          <h3 class="mb-2 text-xl font-bold text-gray-900 dark:text-white">Table Tennis Ulster</h3>
          <p class="mb-6 text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
            The governing body for table tennis in Ulster.
          </p>
          <a class="mt-auto flex items-center gap-2 text-sm font-bold text-primary hover:gap-3 transition-all" href="https://tabletennisulster.com/" target="_blank" rel="noopener noreferrer">Visit Website <span class="material-icons text-sm">arrow_forward</span></a>
        </div>
      </div>
    </div>
  </section>

  <!-- Equipment Sponsor -->
  <section class="px-4 md:px-8 py-16 bg-gray-50 dark:bg-gray-900/50">
    <div class="mx-auto max-w-7xl">
      <div class="mb-12 flex flex-col items-start justify-between gap-4 md:flex-row md:items-end">
        <div>
          <h2 class="text-3xl font-black tracking-tight text-gray-900 dark:text-white">Equipment Sponsor</h2>
          <div class="mt-2 h-1.5 w-24 rounded-full bg-primary"></div>
        </div>
      </div>
      
      <div class="flex justify-center">
        <div class="partner-card group flex flex-col rounded-xl bg-white dark:bg-gray-800 p-8 shadow-md border-2 border-primary max-w-md w-full">
          <div class="mb-6 flex h-24 items-center justify-center rounded-lg bg-white dark:bg-gray-900 p-4 transition-all group-hover:scale-105">
            <img src="https://www.teessport.com/images/modules/promo_units/retina-1744714892-63908400.png" alt="Teesport Equipment" class="h-full w-auto object-contain" />
          </div>
          <h3 class="mb-2 text-xl font-bold text-gray-900 dark:text-white">Teesport Equipment</h3>
          <p class="mb-6 text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
            Leading supplier of quality table tennis tables, bats, nets, and balls. Providing top-tier equipment for our club and competitions.
          </p>
          <a class="mt-auto flex items-center gap-2 text-sm font-bold text-primary hover:gap-3 transition-all" href="https://www.teessport.com/" target="_blank" rel="noopener noreferrer">Visit Website <span class="material-icons text-sm">arrow_forward</span></a>
        </div>
      </div>

      <!-- Teesport Sponsorship Image -->
      <div class="mt-12 flex justify-center">
        <img src="https://xkwg7luliofrc1cs.public.blob.vercel-storage.com/Images/sponsorship%20teessport.jpg" alt="Teesport Sponsorship" class="rounded-xl shadow-lg max-w-2xl w-full" />
      </div>
    </div>
  </section>

  <!-- Call to Action -->
  <section class="px-4 md:px-8 py-20">
    <div class="mx-auto max-w-5xl overflow-hidden rounded-2xl bg-gray-900 text-white shadow-2xl">
      <div class="relative flex flex-col items-center justify-center gap-6 p-12 text-center md:p-20">
        <div class="absolute inset-0 bg-primary/10 opacity-50"></div>
        <h2 class="relative z-10 text-3xl font-black md:text-5xl">Become a Partner</h2>
        <p class="relative z-10 max-w-xl text-lg text-gray-300">
          Join us in building a vibrant sports community. Your support directly impacts youth development and community health.
        </p>
        <div class="relative z-10 mt-4 flex flex-wrap justify-center gap-4">
          <a href="/contact" class="h-14 rounded-full bg-primary px-10 text-lg font-bold shadow-lg shadow-primary/30 hover:scale-105 transition-transform inline-flex items-center">Get In Contact</a>
        </div>
      </div>
    </div>
  </section>
  <Footer />
</Layout>
